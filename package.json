{
  "name": "app",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "mkdir -p app/assets/builds && npm run build && npm run build:css",
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/tailwind.css --minify --config ./config/tailwind.config.js",
    "watch:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/tailwind.css --watch --config ./config/tailwind.config.js",
    "heroku-postbuild": "npm install && npm run build && npm run build:css"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@rails/activestorage": "^7.0.0",
    "@rails/ujs": "^7.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.5",
    "postcss": "^8.5.3",
    "stimulus-character-counter": "^4.2.0",
    "tailwindcss": "^3.4.1",
    "turbolinks": "^5.2.0"
  }
}
