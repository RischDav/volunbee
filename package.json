{
  "name": "app",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/tailwind.css",
    "watch:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/tailwind.css --watch",
    "heroku-postbuild": "yarn build && yarn build:css"
  },
  "dependencies": {
    "22": "^0.0.0",
    "@hotwired/stimulus": "^3.2.2",
    "@rails/activestorage": "^7.0.0",
    "@rails/ujs": "^7.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.24.2",
    "postcss": "^8.5.3",
    "stimulus-character-counter": "^4.2.0",
    "tailwindcss": "^4.0.17",
    "turbolinks": "^5.2.0"
  }
}
