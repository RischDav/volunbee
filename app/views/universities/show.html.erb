<div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-6 xl:px-8 py-4 sm:py-6 lg:py-8">
  <div class="bg-white shadow-lg rounded-lg overflow-hidden">
    <!-- Header -->
    <div class="relative h-48 overflow-hidden">
      <% if @university.cover_image.attached? %>
        <% begin %>
          <%= image_tag @university.cover_image.variant(resize_to_fill: [1200, 300]).processed, alt: "#{@university.name} Cover", class: "absolute inset-0 w-full h-full object-cover" %>
        <% rescue => e %>
          <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-blue-800"></div>
        <% end %>
      <% else %>
        <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-blue-800"></div>
      <% end %>
      <div class="relative h-full flex items-end p-8">
        <div class="flex items-center space-x-6">
          <% if @university.logo.attached? %>
            <div class="w-24 h-24 bg-white rounded-lg shadow-lg flex items-center justify-center overflow-hidden">
              <%= image_tag @university.logo.variant(resize_to_fill: [96, 96]).processed, alt: @university.name, class: "w-full h-full object-cover" %>
            </div>
          <% else %>
            <div class="w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 bg-white rounded-lg shadow-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 sm:w-10 sm:h-10 lg:w-12 lg:h-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
          <% end %>
          <div class="relative inline-block">
            <!-- Visible overlay behind title -->
            <div class="absolute inset-0 bg-black bg-opacity-60 rounded-lg"></div>
            <div class="relative text-white px-4 py-2">
              <h1 class="text-3xl font-bold"><%= @university.name %></h1>
              <% if current_user.university_staff? %>
                <p class="text-gray-200"><%= t('universities.show.staff_view') %></p>
              <% else %>
                <p class="text-gray-200"><%= t('universities.show.student_view') %></p>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="mt-3 sm:mt-0 sm:ml-auto flex space-x-2 sm:space-x-3">
          <% if current_user.university_staff? || current_user.admin? %>
            <%= link_to edit_university_path(@university), class: "inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 bg-white text-blue-700 font-medium text-xs sm:text-sm rounded-lg hover:bg-blue-50 transition-colors duration-200 shadow-md" do %>
              <svg class="w-3 h-3 sm:w-4 sm:h-4 mr-1 sm:mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              <%= t('universities.show.edit_button') %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="p-4 sm:p-6 lg:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Main Information -->
        <div class="lg:col-span-2">
          <div class="space-y-4 sm:space-y-6">
            <!-- Description -->
            <% if @university.description.present? %>
              <div>
                <h2 class="text-xl font-semibold text-gray-900 mb-3"><%= t('universities.show.about_us') %></h2>
                <p class="text-gray-600 leading-relaxed"><%= simple_format(@university.description) %></p>
              </div>
            <% end %>

            <!-- Status -->
            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-3"><%= t('universities.show.status') %></h2>
              <div class="flex items-center">
                <% if @university.released? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <%= t('universities.show.active') %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    <%= t('universities.show.not_activated') %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-gray-50 rounded-lg p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= t('universities.show.contact_information') %></h2>
          <div class="space-y-4">
            <% if @university.email.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:<%= @university.email %>" class="text-blue-600 hover:text-blue-800"><%= @university.email %></a>
              </div>
            <% end %>

            <% if @university.contact_number.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href="tel:<%= @university.contact_number %>" class="text-blue-600 hover:text-blue-800"><%= @university.contact_number %></a>
              </div>
            <% end %>

            <% if @university.contact_person.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span class="text-gray-700"><%= @university.contact_person %></span>
              </div>
            <% end %>

            <% if @university.website.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                <a href="<%= @university.website %>" target="_blank" class="text-blue-600 hover:text-blue-800"><%= t('universities.show.visit_website') %></a>
              </div>
            <% end %>

            <% if @university.instagram_url.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <a href="<%= @university.instagram_url %>" target="_blank" class="text-blue-600 hover:text-blue-800"><%= t('universities.show.instagram') %></a>
              </div>
            <% end %>

            <% if @university.linkedin_url.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <a href="<%= @university.linkedin_url %>" target="_blank" class="text-blue-600 hover:text-blue-800"><%= t('universities.show.linkedin') %></a>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
