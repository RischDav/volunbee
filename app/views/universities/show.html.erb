<div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-6 xl:px-8 py-4 sm:py-6 lg:py-8">
  <div class="bg-white shadow-lg rounded-lg overflow-hidden">
    <!-- Header -->
    <div class="relative h-32 sm:h-40 lg:h-48 bg-gradient-to-r from-blue-600 to-blue-800">
      <div class="absolute inset-0 bg-black bg-opacity-20"></div>
      <div class="relative h-full flex flex-col sm:flex-row items-start sm:items-end p-4 sm:p-6 lg:p-8">
        <div class="flex items-center space-x-3 sm:space-x-4 lg:space-x-6 flex-1">
          <% if @university.logo.attached? %>
            <div class="w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 bg-white rounded-lg shadow-lg flex items-center justify-center overflow-hidden flex-shrink-0">
              <%= image_tag @university.logo, alt: @university.name, class: "w-full h-full object-cover" %>
            </div>
          <% else %>
            <div class="w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 bg-white rounded-lg shadow-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 sm:w-10 sm:h-10 lg:w-12 lg:h-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
          <% end %>
          <div class="text-white">
            <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold"><%= @university.name %></h1>
            <% if current_user.university_staff? %>
              <p class="text-blue-100 text-xs sm:text-sm">Mitarbeiter-Ansicht</p>
            <% else %>
              <p class="text-blue-100 text-xs sm:text-sm">Student</p>
            <% end %>
          </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="mt-3 sm:mt-0 sm:ml-auto flex space-x-2 sm:space-x-3">
          <% if current_user.university_staff? || current_user.admin? %>
            <%= link_to edit_university_path(@university), class: "inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 bg-white text-blue-700 font-medium text-xs sm:text-sm rounded-lg hover:bg-blue-50 transition-colors duration-200 shadow-md" do %>
              <svg class="w-3 h-3 sm:w-4 sm:h-4 mr-1 sm:mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Bearbeiten
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="p-4 sm:p-6 lg:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Main Information -->
        <div class="lg:col-span-2">
          <div class="space-y-4 sm:space-y-6">
            <!-- Description -->
            <% if @university.description.present? %>
              <div>
                <h2 class="text-xl font-semibold text-gray-900 mb-3">Über uns</h2>
                <p class="text-gray-600 leading-relaxed"><%= simple_format(@university.description) %></p>
              </div>
            <% end %>

            <!-- Status -->
            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-3">Status</h2>
              <div class="flex items-center">
                <% if @university.released? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    Aktiv
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    Nicht freigeschaltet
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-gray-50 rounded-lg p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Kontaktinformationen</h2>
          <div class="space-y-4">
            <% if @university.email.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:<%= @university.email %>" class="text-blue-600 hover:text-blue-800"><%= @university.email %></a>
              </div>
            <% end %>

            <% if @university.contact_number.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href="tel:<%= @university.contact_number %>" class="text-blue-600 hover:text-blue-800"><%= @university.contact_number %></a>
              </div>
            <% end %>

            <% if @university.website.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                <a href="<%= @university.website %>" target="_blank" class="text-blue-600 hover:text-blue-800">Website besuchen</a>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
