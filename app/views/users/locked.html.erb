<div class="max-w-lg mx-auto my-8 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold mb-4">Account-Status</h1>

  <% if defined?(@email) %>
    <div class="mb-6">
      <p class="text-gray-700"><strong>E-Mail:</strong> <%= @email %></p>
    </div>
    
    <div class="space-y-4 mb-6">
      <!-- Email-Bestätigung Status -->
      <div class="p-4 border rounded-lg">
        <div class="flex justify-between items-center">
          <h2 class="font-semibold">Email-Bestätigung</h2>
          <% if @email_confirmed %>
            <span class="text-xl">✅</span>
          <% else %>
            <span class="text-xl">⚠️</span>
          <% end %>
        </div>
        <p class="mt-2 text-sm">
          <% if @email_confirmed %>
            Ihre E-Mail-Adresse wurde bestätigt.
          <% else %>
            Wir haben eine Bestätigungsmail an Ihre E-Mail-Adresse geschickt. 
            <br>Keine Mail erhalten? 
            <%= link_to "Bestätigungsmail erneut schicken", new_user_confirmation_path, class: "text-blue-600 underline" %>.
          <% end %>
        </p>
      </div>

      <!-- Admin-Freigabe Status -->
      <div class="p-4 border rounded-lg">
        <div class="flex justify-between items-center">
          <h2 class="font-semibold">Admin-Freigabe</h2>
          <% if @user_released %>
            <span class="text-xl">✅</span>
          <% else %>
            <span class="text-xl">⚠️</span>
          <% end %>
        </div>
        <p class="mt-2 text-sm">
          <% if @user_released %>
            Ihr Account wurde freigegeben. Sie können sich jetzt einloggen.
          <% else %>
            Nach Ihrer E-Mail-Bestätigung muss ein Administrator Ihren Account noch freigeben.
            Dies geschieht in der Regel innerhalb von 24 Stunden.
          <% end %>
        </p>
      </div>
    </div>

    <div class="mt-6 text-center space-y-3">
      <% if @email_confirmed && @user_released %>
        <%= link_to "Zum Login", new_user_session_path, class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700" %>
      <% else %>
        <p class="text-gray-600">Sobald beide Schritte abgeschlossen sind, können Sie sich einloggen und Stellen veröffentlichen.</p>
      <% end %>
      
      <div class="mt-2">
        <%= link_to "Zurück zum Login", new_user_session_path, class: "text-blue-600 hover:text-blue-800 text-sm" %>
      </div>
    </div>
  <% else %>
    <div class="bg-yellow-100 p-4 rounded-lg">
      <p class="text-yellow-700">Keine Benutzerinformationen verfügbar.</p>
    </div>
    
    <div class="mt-6 text-center">
      <%= link_to "Zurück zum Login", new_user_session_path, class: "text-blue-600 hover:text-blue-800 text-sm" %>
    </div>
  <% end %>
</div>