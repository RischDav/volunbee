<div class="mt-8 p-6 bg-white rounded-lg shadow-md border border-slate-200">
  <h1 class="text-2xl font-bold mb-4">Account-Status</h1>
  
  <% if @email_confirmed %>
    <div class="bg-green-100 p-4 rounded-lg mb-4">
      <p class="text-green-700">✅ Email ist bestätigt</p>
    </div>
  <% else %>
    <div class="bg-yellow-100 p-4 rounded-lg mb-4">
      <p class="text-yellow-700">⚠️ Email muss noch bestätigt werden</p>
      <p class="mt-2">Bitte überprüfen Sie Ihr Email-Postfach und klicken Sie auf den Bestätigungslink.</p>
      <p class="mt-2">
        <%= link_to "Bestätigungsmail erneut senden", new_user_confirmation_path, class: "text-blue-600 underline" %>
      </p>
    </div>
  <% end %>
  
  <% if !@user_released %>
    <div class="bg-yellow-100 p-4 rounded-lg">
      <p class="text-yellow-700">⏳ Ihr Account wartet auf Freigabe durch einen Administrator</p>
      <p class="mt-2">Wir werden Sie benachrichtigen, sobald Ihr Account freigeschaltet wurde.</p>
    </div>
  <% end %>
</div>