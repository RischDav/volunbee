<%# app/views/users/locked.html.erb %>
<div class="max-w-lg mx-auto my-8 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold mb-4">Account-Status</h1>
  
  <% if user_signed_in? %>
    <% if !current_user.confirmed? %>
      <div class="bg-yellow-100 p-4 rounded-lg mb-4">
        <p class="text-yellow-700 font-semibold">⚠️ Sie müssen Ihre E-Mail-Adresse bestätigen</p>
        <p class="mt-2">Eine Bestätigungs-E-Mail wurde an <%= current_user.email %> gesendet.</p>
        <p class="mt-2">
          <%= link_to "Bestätigungs-E-Mail erneut senden", new_confirmation_path(resource_name), class: "text-blue-600 underline" %>
        </p>
      </div>
    <% end %>
    
    <% if !current_user.released? %>
      <div class="bg-yellow-100 p-4 rounded-lg">
        <p class="text-yellow-700 font-semibold">⏳ Ihr Account wartet auf Freigabe</p>
        <p class="mt-2">Ein Administrator wird Ihren Account in Kürze freischalten.</p>
      </div>
    <% end %>
    
    <div class="mt-6">
      <%= button_to "Abmelden", destroy_user_session_path, method: :delete, class: "px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300" %>
    </div>
  <% else %>
    <p>Bitte <a href="<%= new_user_session_path %>" class="text-blue-600 underline">melden Sie sich an</a> oder 
       <a href="<%= new_user_registration_path %>" class="text-blue-600 underline">registrieren Sie sich</a>, um fortzufahren.</p>
  <% end %>
</div>