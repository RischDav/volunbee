<div class="min-h-screen bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-8 text-center">
      <div class="mb-4">
        <span class="text-sm font-semibold text-gray-600 bg-gray-200 px-4 py-2 rounded-full">Analytics Dashboard</span>
      </div>
      
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Engagement Insights
      </h1>
      
      <p class="text-gray-600 max-w-2xl mx-auto mb-6">
        Entdecke, wie sich das Engagement der Studierenden entwickelt. Die Visualisierung kommt ganz ohne externe Chart-Bibliotheken aus.
      </p>
      
      <div class="bg-white border rounded-lg px-4 py-3 inline-block">
        <span class="text-sm text-gray-600">Aktiver Zeitraum:</span>
        <span class="text-sm font-semibold text-gray-800 ml-2"><%= l(@start_date, format: :short) %> - <%= l(@end_date, format: :short) %></span>
      </div>
    </header>

    <section class="bg-white rounded-lg shadow-sm border p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Zeitraum anpassen</h2>
      <p class="text-gray-600 mb-6">
        Verfeinere deine Analyse durch die Auswahl eines spezifischen Zeitfensters.
      </p>
      
      <div class="text-sm text-gray-500 mb-6">
        Verfügbare Daten: <%= l(@available_start, format: :short) %> – <%= l(@available_end, format: :short) %>
      </div>

      <%= form_with url: analytics_path, method: :get, local: true, class: "grid gap-4 md:grid-cols-3" do |form| %>
        <div>
          <%= form.label :start_date, "Startdatum", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.date_field :start_date, value: @start_date, class: "w-full rounded-md border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <div>
          <%= form.label :end_date, "Enddatum", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.date_field :end_date, value: @end_date, class: "w-full rounded-md border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <div class="flex items-end">
          <%= form.submit "Aktualisieren", class: "w-full bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      <% end %>
    </section>

    <section class="grid gap-4 md:grid-cols-3 mb-8">
      <div class="bg-white rounded-lg border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600">Neue Registrierungen</p>
            <p class="text-xs text-gray-500">Studierende</p>
          </div>
          <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">
            <%= @range_days_count %> Tage
          </span>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@registration_total) %></p>
        <p class="text-sm text-gray-600 mt-2">Gesamtanzahl neuer Accounts</p>
      </div>

      <div class="bg-white rounded-lg border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600">Kontaktanfragen</p>
            <p class="text-xs text-gray-500">an Organisationen</p>
          </div>
          <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded">
            <%= @range_days_count %> Tage
          </span>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@contact_request_total) %></p>
        <p class="text-sm text-gray-600 mt-2">Summe aller Kontaktanfragen</p>
      </div>

      <div class="bg-white rounded-lg border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600">Aktive Studierende</p>
            <p class="text-xs text-gray-500">Engagement</p>
          </div>
          <span class="text-xs bg-orange-100 text-orange-800 px-2 py-1 rounded">
            <%= @range_days_count %> Tage
          </span>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@activity_total) %></p>
        <p class="text-sm text-gray-600 mt-2">Kumulierte Aktivitäten</p>
      </div>
    </section>

    <!-- Data Table Section -->
    <section class="bg-white rounded-lg shadow-sm border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Tägliche Metriken</h2>
      <p class="text-gray-600 mb-6">
        Eine detaillierte Aufschlüsselung der wichtigsten Kennzahlen für den ausgewählten Zeitraum.
      </p>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Datum
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Registrierungen
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Kontaktanfragen
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Aktivitäten
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @table_data.each do |row| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= row[:label] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= row[:registrations] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= row[:contact_requests] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= row[:activity] %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

  </div>
</div>
