<div class="min-h-screen bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-8 text-center">
      <div class="mb-4">
        <span class="text-sm font-semibold text-gray-600 bg-gray-200 px-4 py-2 rounded-full"><%= t("analytics.index.badge") %></span>
      </div>
      
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        <%= t("analytics.index.heading") %>
      </h1>
      
      <p class="text-gray-600 max-w-2xl mx-auto mb-6">
        <%= t("analytics.index.description") %>
      </p>
      
      <div class="bg-white border rounded-lg px-4 py-3 inline-block">
        <span class="text-sm text-gray-600"><%= t("analytics.index.period_label") %></span>
        <span class="text-sm font-semibold text-gray-800 ml-2"><%= l(@start_date, format: :short) %> - <%= l(@end_date, format: :short) %></span>
      </div>
    </header>

    <section class="bg-white rounded-lg shadow-sm border p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= t("analytics.index.filter.title") %></h2>
      <p class="text-gray-600 mb-6">
        <%= t("analytics.index.filter.description") %>
      </p>
      
      <div class="text-sm text-gray-500 mb-6">
        <%= t("analytics.index.filter.available_data", start: l(@available_start, format: :short), end: l(@available_end, format: :short)) %>
      </div>

      <%= form_with url: analytics_path, method: :get, local: true, class: "grid gap-4 md:grid-cols-3" do |form| %>
        <div>
          <%= form.label :start_date, t("analytics.index.filter.start_label"), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.date_field :start_date, value: @start_date, class: "w-full rounded-md border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <div>
          <%= form.label :end_date, t("analytics.index.filter.end_label"), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.date_field :end_date, value: @end_date, class: "w-full rounded-md border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <div class="flex items-end">
          <%= form.submit t("analytics.index.filter.submit"), class: "w-full bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      <% end %>
    </section>

    <section class="grid gap-4 md:grid-cols-3 mb-8">
      <div class="bg-white rounded-lg border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600"><%= t("analytics.index.cards.registrations.title") %></p>
            <p class="text-xs text-gray-500"><%= t("analytics.index.cards.registrations.subtitle") %></p>
          </div>
          <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">
            <%= t("analytics.index.cards.range_days", count: @range_days_count) %>
          </span>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@registration_total) %></p>
        <p class="text-sm text-gray-600 mt-2"><%= t("analytics.index.cards.registrations.description") %></p>
      </div>

      <div class="bg-white rounded-lg border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600"><%= t("analytics.index.cards.contact_requests.title") %></p>
            <p class="text-xs text-gray-500"><%= t("analytics.index.cards.contact_requests.subtitle") %></p>
          </div>
          <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded">
            <%= t("analytics.index.cards.range_days", count: @range_days_count) %>
          </span>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@contact_request_total) %></p>
        <p class="text-sm text-gray-600 mt-2"><%= t("analytics.index.cards.contact_requests.description") %></p>
      </div>

      <div class="bg-white rounded-lg border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600"><%= t("analytics.index.cards.activity.title") %></p>
            <p class="text-xs text-gray-500"><%= t("analytics.index.cards.activity.subtitle") %></p>
          </div>
          <span class="text-xs bg-orange-100 text-orange-800 px-2 py-1 rounded">
            <%= t("analytics.index.cards.range_days", count: @range_days_count) %>
          </span>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@activity_total) %></p>
        <p class="text-sm text-gray-600 mt-2"><%= t("analytics.index.cards.activity.description") %></p>
      </div>
    </section>

    <!-- Data Table Section -->
    <section class="bg-white rounded-lg shadow-sm border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= t("analytics.index.table.title") %></h2>
      <p class="text-gray-600 mb-6">
        <%= t("analytics.index.table.description") %>
      </p>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                <%= t("analytics.index.table.headers.date") %>
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                <%= t("analytics.index.table.headers.registrations") %>
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                <%= t("analytics.index.table.headers.contact_requests") %>
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                <%= t("analytics.index.table.headers.activity") %>
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @table_data.each do |row| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= row[:label] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= row[:registrations] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= row[:contact_requests] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= row[:activity] %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

  </div>
</div>
