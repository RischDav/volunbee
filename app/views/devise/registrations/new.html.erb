<div class="bg-[#F8F9FA]/80 min-h-screen py-12">
  <div class="max-w-lg mx-auto p-8 bg-white shadow-xl rounded-2xl border border-gray-100">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold mb-2">
        <span class="text-[#264653]">Join</span> 
        <span class="text-[#F2C94C]">Volunbee</span>
      </h1>
      <p class="text-[#264653]/70 text-lg">Start making a difference today</p>
    </div>

    <!-- Toggle zwischen Organisation und Student -->
    <div class="mb-8">
      <div class="flex justify-center space-x-2 bg-[#264653]/5 p-2 rounded-xl border border-[#264653]/10">
        <button type="button" id="org-toggle" class="toggle-btn active flex-1 px-6 py-3 text-sm font-semibold rounded-lg transition-all duration-300 transform hover:scale-105">
          <span class="flex items-center justify-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z"/>
            </svg>
            Organisation
          </span>
        </button>
        <button type="button" id="student-toggle" class="toggle-btn flex-1 px-6 py-3 text-sm font-semibold rounded-lg transition-all duration-300 transform hover:scale-105">
          <span class="flex items-center justify-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
            </svg>
            Student
          </span>
        </button>
      </div>
    </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- Verstecktes Feld für den Registrierungstyp -->
    <%= f.hidden_field :role, id: "user_role", value: "organization" %>

    <div class="space-y-6">
      <div class="field group">
        <%= f.label :email, t('devise.registrations.new.email_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
            </svg>
          </div>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", 
              class: "w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 
                     focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] 
                     hover:border-[#2A9D8F]/50 group-hover:shadow-md" %>
        </div>
      </div>

      <div class="field group">
        <%= f.label :password, t('devise.registrations.new.password_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-[#264653]/60 mb-2">
            (<%= t('devise.registrations.new.password_minimum_length', count: @minimum_password_length) %>)
          </p>
        <% end %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", 
              class: "w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 
                     focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] 
                     hover:border-[#2A9D8F]/50 group-hover:shadow-md" %>
        </div>
      </div>

      <!-- Passwort-Bestätigung nur für Organisationen -->
      <div class="field group" id="password-confirmation-field">
        <%= f.label :password_confirmation, t('devise.registrations.new.password_confirmation_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", 
              class: "w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 
                     focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] 
                     hover:border-[#2A9D8F]/50 group-hover:shadow-md" %>
        </div>
      </div>

      <!-- Organisation Name nur für Organisationen -->
      <div class="field group" id="organization-name-field">
        <%= f.label :organization_name, t('devise.registrations.new.organization_name_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <%= f.text_field :organization_name, 
              class: "w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 
                     focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] 
                     hover:border-[#2A9D8F]/50 group-hover:shadow-md" %>
        </div>
        <p class="text-xs text-[#264653]/60 mt-2 ml-1"><%= t('devise.registrations.new.organization_name_hint') %></p>
      </div>
    </div>

    <div class="actions mt-8">
      <%= f.submit t('devise.registrations.new.sign_up_button'), 
          class: "w-full py-4 px-6 bg-gradient-to-r from-[#E76F51] to-[#E76F51]/90 
                 text-white font-semibold text-lg rounded-xl shadow-lg 
                 hover:from-[#E76F51]/90 hover:to-[#E76F51] 
                 focus:outline-none focus:ring-4 focus:ring-[#E76F51]/30 
                 transform transition-all duration-300 hover:scale-105 hover:shadow-xl
                 active:scale-95" %>
    </div>
  <% end %>

  <div class="text-center mt-8 pt-6 border-t border-gray-100">
    <div class="space-y-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const orgToggle = document.getElementById('org-toggle');
  const studentToggle = document.getElementById('student-toggle');
  const passwordConfirmationField = document.getElementById('password-confirmation-field');
  const organizationNameField = document.getElementById('organization-name-field');
  const userRoleField = document.getElementById('user_role');

  function updateActiveToggle(activeBtn, inactiveBtn) {
    // Active button styling
    activeBtn.classList.add('active');
    activeBtn.classList.remove('text-[#264653]/70', 'hover:text-[#264653]', 'bg-transparent');
    activeBtn.classList.add('bg-gradient-to-r', 'from-[#2A9D8F]', 'to-[#2A9D8F]/90', 'text-white', 'shadow-lg');
    
    // Inactive button styling
    inactiveBtn.classList.remove('active');
    inactiveBtn.classList.remove('bg-gradient-to-r', 'from-[#2A9D8F]', 'to-[#2A9D8F]/90', 'text-white', 'shadow-lg');
    inactiveBtn.classList.add('text-[#264653]/70', 'hover:text-[#264653]', 'bg-transparent');
  }

  function showOrganizationForm() {
    passwordConfirmationField.style.display = 'block';
    organizationNameField.style.display = 'block';
    userRoleField.value = 'organization';
    updateActiveToggle(orgToggle, studentToggle);
    
    // Smooth transition
    passwordConfirmationField.style.opacity = '0';
    organizationNameField.style.opacity = '0';
    setTimeout(() => {
      passwordConfirmationField.style.opacity = '1';
      organizationNameField.style.opacity = '1';
    }, 150);
  }

  function showStudentForm() {
    passwordConfirmationField.style.display = 'none';
    organizationNameField.style.display = 'none';
    userRoleField.value = 'student';
    updateActiveToggle(studentToggle, orgToggle);
  }

  // Event Listeners
  orgToggle.addEventListener('click', showOrganizationForm);
  studentToggle.addEventListener('click', showStudentForm);

  // Initialer Zustand (Organisation)
  showOrganizationForm();
});
</script>

<style>
.toggle-btn {
  @apply text-[#264653]/70 hover:text-[#264653] bg-transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.toggle-btn.active {
  @apply bg-gradient-to-r from-[#2A9D8F] to-[#2A9D8F]/90 text-white shadow-lg;
}

.field {
  transition: all 0.3s ease;
}

/* Custom focus styles for better accessibility */
.field input:focus {
  transform: translateY(-1px);
}

/* Hover effects for the form */
.group:hover input {
  border-color: #2A9D8F80;
}

/* Loading animation for smooth transitions */
.field {
  opacity: 1;
  transition: opacity 0.3s ease;
}

/* Custom scrollbar if needed */
::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  background: #2A9D8F;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: #264653;
}
</style>
