<%# Variables for Tailwind CSS classes %>
<% box_style = "bg-transparent border border-[#2a2b2e] rounded-lg p-8" %>
<% input_style = "w-full bg-transparent border border-[#2a2b2e] rounded-md py-2 px-3 focus:outline-none focus:border-[#2A9D8F] transition-colors duration-300" %>
<% label_style = "block text-sm font-medium text-gray-400 mb-2" %>
<% button_style = "w-full bg-[#2A9D8F] text-white font-bold py-3 px-4 rounded-md hover:bg-[#258a7e] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#1a1919] focus:ring-[#2A9D8F] transition-all duration-300" %>
<% link_style = "font-medium text-[#2A9D8F] hover:text-[#38b8a5] transition-colors duration-300" %>

<div class=" text-gray-300 min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-lg w-full space-y-8">
    <article class="<%= box_style %>">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-100">
          <%= t('devise.registrations.new_student.join_as') %> <span class="text-[#F2C94C]"><%= t('devise.registrations.new_student.student') %></span>
        </h1>
        <p class="text-gray-400 mt-2"><%= t('devise.registrations.new_student.student_register') %></p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :role, value: "student" %>

        <div>
          <%= f.label :email, t('devise.registrations.new_student.email_label'), class: label_style %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_style, placeholder: "name@example.com" %>
        </div>

        <div>
          <%= f.label :password, t('devise.registrations.new_student.password_label'), class: label_style %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-500 mb-2">(<%= t('devise.registrations.new_student.password_minimum_length', count: @minimum_password_length) %>)</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: input_style, placeholder: "••••••••" %>
        </div>

        <div>
          <%= f.label :password_confirmation, t('devise.registrations.new_student.password_confirmation_label'), class: label_style %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: input_style, placeholder: "••••••••" %>
        </div>

        <div class="actions pt-4">
          <%= f.submit t('devise.registrations.new_student.sign_up_button'), class: button_style %>
        </div>
      <% end %>
    </article>

    <div class="text-center text-sm">
      <%= render "devise/shared/links" %>
      <div class="mt-4">
        <%= link_to t('devise.registrations.new_student.switch_to_organization_registration'), new_organization_registration_path, class: link_style %>
      </div>
    </div>
  </div>
</div>