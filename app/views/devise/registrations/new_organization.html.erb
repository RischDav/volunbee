<div class="bg-[#F8F9FA]/80 min-h-screen py-12">
  <div class="max-w-lg mx-auto p-8 bg-white shadow-xl rounded-2xl border border-gray-100">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold mb-2">
        <span class="text-[#264653]"><%= t('devise.registrations.new.join_as') %></span>
        <span class="text-[#F2C94C]"><%= t('devise.registrations.new.organization') %></span>
      </h1>
      <p class="text-[#264653]/70 text-lg"><%= t('devise.registrations.new.organization_register') %></p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :role, value: "organization" %>

      <div class="space-y-6">
        <div class="field group">
          <%= f.label :email, t('devise.registrations.new.email_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-2 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
              </svg>
            </div>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full mx-2 pl-12 pr-5 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] hover:border-[#2A9D8F]/50 group-hover:shadow-md group-hover:border-[#2A9D8F]/50 transform focus:-translate-y-0.5" %>
          </div>
        </div>

        <div class="field group">
          <%= f.label :password, t('devise.registrations.new.password_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-[#264653]/60 mb-2">(<%= t('devise.registrations.new.password_minimum_length', count: @minimum_password_length) %>)</p>
          <% end %>
          <div class="relative">
            <div class="absolute inset-y-0 left-2 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full mx-2 pl-12 pr-5 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] hover:border-[#2A9D8F]/50 group-hover:shadow-md group-hover:border-[#2A9D8F]/50 transform focus:-translate-y-0.5" %>
          </div>
        </div>

        <div class="field group" id="password-confirmation-field">
          <%= f.label :password_confirmation, t('devise.registrations.new.password_confirmation_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-2 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full mx-2 pl-12 pr-5 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] hover:border-[#2A9D8F]/50 group-hover:shadow-md group-hover:border-[#2A9D8F]/50 transform focus:-translate-y-0.5" %>
          </div>
        </div>

        <div class="field group" id="organization-name-field">
          <%= f.label :organization_name, t('devise.registrations.new.organization_name_label'), class: "block text-sm font-semibold text-[#264653] mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-2 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-[#2A9D8F]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <%= f.text_field :organization_name, class: "w-full mx-2 pl-12 pr-5 py-3 border-2 border-gray-200 rounded-xl shadow-sm transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/30 focus:border-[#2A9D8F] hover:border-[#2A9D8F]/50 group-hover:shadow-md group-hover:border-[#2A9D8F]/50 transform focus:-translate-y-0.5" %>
          </div>
          <p class="text-xs text-[#264653]/60 mt-2 ml-1"><%= t('devise.registrations.new.organization_name_hint') %></p>
        </div>
      </div>

      <div class="actions mt-8">
        <%= f.submit t('devise.registrations.new.sign_up_button'), class: "w-full py-4 px-6 bg-gradient-to-r from-orange-500 to-orange-600 text-slate-400 font-semibold text-lg rounded-xl shadow-lg hover:from-orange-600 hover:to-orange-700 focus:outline-none focus:ring-4 focus:ring-orange-300 transform transition-all duration-300 hover:scale-105 hover:shadow-xl active:scale-95 border-2 border-orange-700" %>
      </div>
    <% end %>

    <div class="text-center mt-8 pt-6 border-t border-gray-100">
      <%= render "devise/shared/links" %>
      <div class="mt-4">
        <%= link_to t('devise.registrations.new.switch_to_student_registration'), new_student_registration_path, class: "text-[#2A9D8F] hover:underline" %>
      </div>
    </div>
  </div>
</div>
