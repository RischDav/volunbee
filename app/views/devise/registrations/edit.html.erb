<div class="max-w-md mx-auto mt-10 p-6 bg-white shadow-md rounded-lg border border-slate-200">
  <h2 class="text-2xl font-bold text-center text-blue-600 mb-6">Profil bearbeiten</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <h3 class="text-lg font-medium text-gray-900 mb-2">Email-Adresse</h3>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="text-sm text-amber-600 bg-amber-50 p-2 rounded">
        Warte auf Bestätigung für: <%= resource.unconfirmed_email %>
      </div>
    <% end %>

    <div class="border-t border-gray-200 pt-4 mt-6">
      <h3 class="text-lg font-medium text-gray-900 mb-2">Passwort ändern</h3>
      
      <div class="field">
        <%= f.label :password, "Neues Passwort", class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-xs text-gray-500 mt-1">(leer lassen, wenn Sie es nicht ändern möchten)</p>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500">(<%= @minimum_password_length %> Zeichen mindestens)</p>
        <% end %>
      </div>

      <div class="field mt-4">
        <%= f.label :password_confirmation, "Neues Passwort bestätigen", class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>

    <div class="border-t border-gray-200 pt-4 mt-6">
      <div class="field">
        <%= f.label :current_password, "Aktuelles Passwort", class: "block text-sm font-medium text-gray-700 font-semibold" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-xs text-gray-500 mt-1">(wir benötigen Ihr aktuelles Passwort, um die Änderungen zu bestätigen)</p>
      </div>
    </div>

    <div class="actions mt-6">
      <%= f.submit "Aktualisieren", class: "w-full py-2 px-4 bg-blue-600 text-white font-medium text-sm rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    </div>
  <% end %>

  <div class="mt-8 pt-6 border-t border-gray-200">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Account löschen</h3>

    <div class="flex items-center justify-between">
      <span class="text-sm text-gray-600">Unzufrieden?</span>
      <%= button_to "Account löschen", registration_path(resource_name), 
                    data: { confirm: "Sind Sie sicher?", turbo_confirm: "Sind Sie sicher?" }, 
                    method: :delete, 
                    class: "py-2 px-4 bg-red-600 text-white text-sm rounded-md shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>
    </div>
  </div>

  <div class="text-center mt-6">
    <%= link_to "Zurück", :back, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
  </div>
</div>