<%- if controller_name != 'sessions' %>
  <%= link_to t('devise.shared.login'), new_session_path(resource_name), class: "inline-block px-4 py-2 mb-2 text-blue-600 hover:text-blue-800 hover:underline transition-colors" %><br />
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to t('devise.shared.register'), new_registration_path(resource_name), class: "inline-block px-4 py-2 mb-2 text-blue-600 hover:text-blue-800 hover:underline transition-colors" %><br />
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to t('devise.shared.forgot_password'), new_password_path(resource_name), class: "inline-block px-4 py-2 mb-2 text-blue-600 hover:text-blue-800 hover:underline transition-colors" %><br />
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <%= link_to t('devise.shared.no_confirmation'), new_confirmation_path(resource_name), class: "inline-block px-4 py-2 mb-2 text-blue-600 hover:text-blue-800 hover:underline transition-colors" %><br />
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <%= link_to t('devise.shared.no_unlock_instructions'), new_unlock_path(resource_name), class: "inline-block px-4 py-2 mb-2 text-blue-600 hover:text-blue-800 hover:underline transition-colors" %><br />
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <%= button_to t('devise.shared.login_with', provider: OmniAuth::Utils.camelize(provider)), omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "inline-block px-4 py-2 mb-2 text-blue-600 hover:text-blue-800 hover:underline transition-colors" %><br />
  <% end %>
<% end %>
