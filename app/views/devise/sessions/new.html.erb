<%# Variables for Tailwind CSS classes %>
<% box_style = "bg-transparent border border-[#6B7280] rounded-lg p-8" %>
<% input_style = "w-full bg-transparent border border-[#6B7280] rounded-md py-2 px-3 focus:outline-none focus:border-[#2A9D8F] transition-colors duration-300" %>
<% label_style = "block text-sm font-medium text-gray-400 mb-2" %>
<% button_style = "w-full bg-[#2A9D8F] text-white font-bold py-3 px-4 rounded-md hover:bg-[#258a7e] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#1a1919] focus:ring-[#2A9D8F] transition-all duration-300" %>
<% link_style = "font-medium text-[#2A9D8F] hover:text-[#38b8a5] transition-colors duration-300" %>
<% checkbox_style = "h-4 w-4 text-[#2A9D8F] bg-transparent border-[#6B7280] rounded focus:ring-[#2A9D8F] focus:ring-offset-[#1a1919]" %>


<div class="bg-[#1a1919] text-gray-300 min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-lg w-full space-y-8">
    <article class="<%= box_style %>">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-100">
          Welcome to <span class="text-[#2A9D8F]">Volunbee</span>
        </h1>
        <p class="text-gray-400 mt-2"><%= t('devise.sessions.login') %></p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, t('devise.sessions.email'), class: label_style %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_style, placeholder: "name@example.com" %>
        </div>

        <div>
          <%= f.label :password, t('devise.sessions.password'), class: label_style %>
          <%= f.password_field :password, autocomplete: "current-password", class: input_style, placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="field flex items-center">
            <%= f.check_box :remember_me, class: checkbox_style %>
            <%= f.label :remember_me, t('devise.sessions.remember_me'), class: "ml-2 block text-sm text-gray-400" %>
          </div>
        <% end %>

        <div class="actions pt-4">
          <%= f.submit t('devise.sessions.login_button'), class: button_style %>
        </div>
      <% end %>
    </article>

    <div class="text-center text-sm">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>