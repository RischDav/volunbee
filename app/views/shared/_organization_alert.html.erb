<% if current_user && !current_user.admin? && current_user.organization && !current_user.organization.complete_profile? %>
  <div class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 m-4 p-6 mb-4" role="alert">
    <p class="font-bold">Achtung</p>
    <p>
      Ihre Organisation verfügt noch nicht über alle erforderlichen Informationen.
      Weitere Funktionen werden verfügbar, sobald alle Pflichtfelder ausgefüllt und die Organisation gespeichert wurde.
      <br>
      <strong>Fehlende Informationen:</strong> <%= current_user.organization.incomplete_fields.join(", ") %>
    </p>
    <!-- <div class="mt-4">
      <%= link_to "Organisationsprofil bearbeiten", edit_organization_path(current_user.organization), class: "bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700" %>
    </div> -->
  </div>
<% end %>