<!-- filepath: app/views/shared/_public_footer.html.erb -->
<footer class="bg-[#264653] shadow">
  <div class="w-full max-w-screen-xl mx-auto p-4">
    <!-- Top section with project info and links -->
    <div class="flex justify-between items-center">
      <!-- Left side - Project credit -->
      <div>
        <span class="text-lg text-white/50">Project realized by David Rischow</span>
      </div>
      
      <!-- Right side - Links -->
      <div class="flex items-center space-x-6">
        <%= link_to "Impressum", impressum_path, class: "text-sm font-medium hover:underline transition-colors duration-200", style: "color: #F8F9FA;" %>
      </div>
    </div>
    
    <!-- Divider line -->
    <hr class="my-4 border-white/50" />
    
    <!-- Bottom section with copyright and additional links -->
    <div class="flex flex-col md:flex-row justify-between items-center space-y-2 md:space-y-0">
      <!-- Copyright text -->
      <span class="text-lg text-white/50">© 2026 Förderverein der Studierenden am TUM Campus Heilbronn e.V.</span>
      
      <!-- Additional footer links -->
      <div class="flex flex-wrap justify-center md:justify-end items-center space-x-4 text-sm">
        <a href="#" onclick="showCookieSettings(); return false;" class="text-white/70 hover:text-white transition-colors duration-200">
          🍪 Cookies
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
/* Hover effects */
footer a:hover {
  text-decoration: underline;
}

/* Responsive improvements */
@media (max-width: 768px) {
  footer .flex.justify-between {
    flex-direction: column;
    space-y: 4;
  }
  
  footer .flex.items-center.space-x-6 {
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
}
</style>