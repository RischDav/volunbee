<!-- JavaScript für Footer Cookie Funktionalität -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Zeige Cookie-Indikator nach erstem Consent
  function checkCookieIndicator() {
    const existingConsent = localStorage.getItem('volunbee_cookieconsent');
    const indicator = document.getElementById('footer-cookie-indicator');
    const floatingBtn = document.getElementById('footer-cookie-btn');
    
    if (existingConsent === 'dismissed') {
      if (indicator) {
        indicator.classList.remove('hidden');
      }
      // Verstecke den ursprünglichen floating button, da wir jetzt den Footer-Button haben
      if (floatingBtn) {
        floatingBtn.style.display = 'none';
      }
    }
  }
  
  // Initial check
  checkCookieIndicator();
  
  // Override die ursprüngliche saveCookieSettings Funktion um den Indikator zu zeigen
  const originalSaveCookieSettings = window.saveCookieSettings;
  if (typeof originalSaveCookieSettings === 'function') {
    window.saveCookieSettings = function(settings) {
      originalSaveCookieSettings(settings);
      checkCookieIndicator();
    };
  }
});
</script>

<style>
/* Footer Cookie Button Animation */
#footer-cookie-indicator button {
  animation: cookiePulse 2s infinite;
}

@keyframes cookiePulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4px 12px rgba(38, 70, 83, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(38, 70, 83, 0.4);
  }
}

/* Hover effects */
footer a:hover {
  text-decoration: underline;
}

/* Responsive improvements */
@media (max-width: 768px) {
  footer .flex.justify-between {
    flex-direction: column;
    space-y: 4;
  }
  
  footer .flex.items-center.space-x-6 {
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
}

/* Better mobile cookie button positioning */
@media (max-width: 640px) {
  #footer-cookie-indicator {
    bottom: 80px; /* Platz für mobile Navigation falls vorhanden */
    right: 16px;
  }
}
</style>