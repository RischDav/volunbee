<style>
/* Cookie Banner Custom Styling */
.cc-window {
  z-index: 99999 !important;
  border-radius: 16px !important;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15), 0 8px 24px rgba(0, 0, 0, 0.1) !important;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
  position: fixed !important;
  border: 1px solid #E5E7EB !important;
  backdrop-filter: blur(10px) !important;
  background: rgba(255, 255, 255, 0.98) !important;
}

/* Desktop: Größeres Fenster unten links */
@media (min-width: 768px) {
  .cc-window {
    bottom: 24px !important;
    left: 24px !important;
    right: auto !important;
    top: auto !important;
    margin: 0 !important;
    transform: none !important;
    max-width: 520px !important;
    width: 520px !important;
    padding: 32px !important;
  }
}

/* Mobile: Kompakteres Design */
@media (max-width: 767px) {
  .cc-window {
    bottom: 20px !important;
    left: 50% !important;
    right: auto !important;
    top: auto !important;
    transform: translateX(-50%) !important;
    margin: 0 !important;
    max-width: calc(100vw - 32px) !important;
    width: calc(100vw - 32px) !important;
    padding: 24px !important;
  }
}

/* Cookie Settings Modal */
.cookie-settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 999999;
  display: none;
  align-items: center;
  justify-content: center;
}

.cookie-settings-content {
  background: white;
  border-radius: 16px;
  padding: 32px;
  max-width: 600px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 25px 75px rgba(0, 0, 0, 0.2);
}

/* Cookie Category Styling */
.cookie-category {
  border: 1px solid #E5E7EB;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
}

.cookie-category-header {
  background: #F9FAFB;
  padding: 16px 20px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #E5E7EB;
}

.cookie-category-content {
  padding: 20px;
  display: none;
}

.cookie-category.active .cookie-category-content {
  display: block;
}

.cookie-toggle {
  position: relative;
  display: inline-block;
  width: 50px;
  height: 24px;
}

.cookie-toggle input {
  opacity: 0;
  width: 0;
  height: 0;
}

.cookie-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  transition: .4s;
  border-radius: 24px;
}

.cookie-slider:before {
  position: absolute;
  content: "";
  height: 18px;
  width: 18px;
  left: 3px;
  bottom: 3px;
  background-color: white;
  transition: .4s;
  border-radius: 50%;
}

input:checked + .cookie-slider {
  background-color: #10B981;
}

input:checked + .cookie-slider:before {
  transform: translateX(26px);
}

/* Disabled/grayed out toggle für notwendige Cookies */
.cookie-toggle.disabled .cookie-slider {
  background-color: #9CA3AF !important;
  cursor: not-allowed !important;
  opacity: 0.6 !important;
}

.cookie-toggle.disabled input:checked + .cookie-slider {
  background-color: #9CA3AF !important;
}

.cookie-toggle.disabled .cookie-slider:before {
  opacity: 0.8 !important;
}

/* Button Styling - ALLE BUTTONS GLEICH */
.cc-btn, .cookie-settings-btn, .cookie-save-btn {
  border-radius: 10px !important;
  font-weight: 600 !important;
  font-size: 14px !important;
  transition: all 0.2s ease !important;
  border: none !important;
  cursor: pointer !important;
  padding: 12px 24px !important;
  margin: 0 8px 8px 0 !important;
  display: inline-block !important;
}

/* Grüne Buttons (Akzeptieren/Speichern) */
.cc-btn.cc-dismiss, .cookie-save-btn {
  background: linear-gradient(135deg, #10B981, #059669) !important;
  color: #ffffff !important;
  box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3) !important;
}

/* Rote Buttons (Ablehnen) */
.cc-btn.cc-deny {
  background: linear-gradient(135deg, #EF4444, #DC2626) !important;
  color: #ffffff !important;
  box-shadow: 0 4px 14px rgba(239, 68, 68, 0.3) !important;
}

/* Graue Buttons (Einstellungen) */
.cookie-settings-btn {
  background: linear-gradient(135deg, #6B7280, #4B5563) !important;
  color: #ffffff !important;
  box-shadow: 0 4px 14px rgba(107, 114, 128, 0.3) !important;
}

.cc-btn:hover, .cookie-settings-btn:hover, .cookie-save-btn:hover {
  transform: translateY(-2px) !important;
}

/* Banner Button Container - NEBENEINANDER */
.cc-compliance {
  display: flex !important;
  gap: 12px !important;
  flex-wrap: wrap !important;
  align-items: center !important;
  justify-content: flex-start !important;
  margin-top: 16px !important;
}

/* Desktop: Buttons nebeneinander */
@media (min-width: 768px) {
  .cc-compliance {
    flex-wrap: nowrap !important;
    gap: 16px !important;
  }
  
  .cc-btn, .cookie-settings-btn {
    margin: 0 !important;
    flex-shrink: 0 !important;
  }
}

/* Mobile: Buttons untereinander */
@media (max-width: 767px) {
  .cc-compliance {
    flex-direction: column !important;
    gap: 12px !important;
  }
  
  .cc-btn, .cookie-settings-btn {
    width: 100% !important;
    margin: 0 !important;
    text-align: center !important;
  }
}

/* Modal Button Container */
.modal-button-container {
  margin-top: 32px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

@media (max-width: 767px) {
  .modal-button-container {
    flex-direction: column;
  }
  
  .modal-button-container .cc-btn,
  .modal-button-container .cookie-save-btn {
    width: 100% !important;
    margin: 0 0 12px 0 !important;
  }
}
</style>

<!-- Cookie Settings Modal -->
<div id="cookie-settings-modal" class="cookie-settings-modal">
  <div class="cookie-settings-content">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
      <h2 style="font-size: 24px; font-weight: 700; color: #111827;">Cookie-Einstellungen</h2>
      <button id="close-cookie-settings" onclick="hideCookieSettings(); return false;" style="background: none; border: none; font-size: 24px; cursor: pointer;">✕</button>
    </div>
    
    <p style="color: #6B7280; margin-bottom: 24px;">
      Wählen Sie aus, welche Cookies Sie zulassen möchten. Sie können diese Einstellungen jederzeit ändern.
    </p>

    <div id="cookie-categories">
      <!-- Notwendige Cookies -->
      <div class="cookie-category active">
        <div class="cookie-category-header" onclick="toggleCookieCategory(this)">
          <div>
            <h3 style="font-weight: 600; color: #111827;">Notwendige Cookies</h3>
            <p style="font-size: 14px; color: #6B7280; margin: 4px 0 0 0;">Für die Grundfunktionen der Website erforderlich</p>
          </div>
          <label class="cookie-toggle disabled">
            <input type="checkbox" checked disabled>
            <span class="cookie-slider"></span>
          </label>
        </div>
        <div class="cookie-category-content">
          <p style="color: #374151; font-size: 14px; line-height: 1.6;">
            Diese Cookies sind für das ordnungsgemäße Funktionieren der Website unerlässlich und können nicht deaktiviert werden. Sie werden normalerweise nur als Reaktion auf Ihre Aktionen gesetzt.
          </p>
          <ul style="color: #6B7280; font-size: 13px; margin-top: 12px; padding-left: 20px;">
            <li>Session-Management</li>
            <li>Sicherheitstoken</li>
            <li>Cookie-Einstellungen</li>
          </ul>
        </div>
      </div>

      <!-- Analytics Cookies -->
      <div class="cookie-category">
        <div class="cookie-category-header" onclick="toggleCookieCategory(this)">
          <div>
            <h3 style="font-weight: 600; color: #111827;">Analytics Cookies</h3>
            <p style="font-size: 14px; color: #6B7280; margin: 4px 0 0 0;">Helfen uns, die Website zu verbessern</p>
          </div>
          <label class="cookie-toggle">
            <input type="checkbox" id="analytics-cookies">
            <span class="cookie-slider"></span>
          </label>
        </div>
        <div class="cookie-category-content">
          <p style="color: #374151; font-size: 14px; line-height: 1.6;">
            Diese Cookies helfen uns zu verstehen, wie Besucher mit der Website interagieren, indem sie Informationen anonym sammeln und melden.
          </p>
          <ul style="color: #6B7280; font-size: 13px; margin-top: 12px; padding-left: 20px;">
            <li>Google Analytics</li>
            <li>Besucherstatistiken</li>
            <li>Performance-Monitoring</li>
          </ul>
        </div>
      </div>

      <!-- Marketing Cookies -->
      <div class="cookie-category">
        <div class="cookie-category-header" onclick="toggleCookieCategory(this)">
          <div>
            <h3 style="font-weight: 600; color: #111827;">Marketing Cookies</h3>
            <p style="font-size: 14px; color: #6B7280; margin: 4px 0 0 0;">Für personalisierte Inhalte und Werbung</p>
          </div>
          <label class="cookie-toggle">
            <input type="checkbox" id="marketing-cookies">
            <span class="cookie-slider"></span>
          </label>
        </div>
        <div class="cookie-category-content">
          <p style="color: #374151; font-size: 14px; line-height: 1.6;">
            Diese Cookies können von unseren Werbepartnern über unsere Website gesetzt werden, um ein Profil Ihrer Interessen zu erstellen.
          </p>
          <ul style="color: #6B7280; font-size: 13px; margin-top: 12px; padding-left: 20px;">
            <li>Werbe-Tracking</li>
            <li>Social Media Integration</li>
            <li>Personalisierte Inhalte</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="modal-button-container">
      <button id="accept-selected-cookies" class="cookie-save-btn">Auswahl speichern</button>
      <button id="accept-all-cookies" class="cc-btn cc-dismiss">Alle akzeptieren</button>
      <button id="reject-all-cookies" onclick="rejectAllCookies(); return false;" class="cc-btn cc-deny">Alle ablehnen</button>
    </div>
  </div>
</div>

<script>
// Cookie Management Functions
function toggleCookieCategory(header) {
  const category = header.parentElement;
  category.classList.toggle('active');
}

function showCookieSettings() {
  document.getElementById('cookie-settings-modal').style.display = 'flex';
  loadCurrentCookieSettings();
}

function hideCookieSettings() {
  console.log('hideCookieSettings called');
  const modal = document.getElementById('cookie-settings-modal');
  if (modal) {
    modal.style.display = 'none';
    console.log('Modal hidden successfully');
  } else {
    console.error('Modal not found when trying to hide');
  }
}

function loadCurrentCookieSettings() {
  const settings = getCookieSettings();
  document.getElementById('analytics-cookies').checked = settings.analytics;
  document.getElementById('marketing-cookies').checked = settings.marketing;
}

function getCookieSettings() {
  const consent = localStorage.getItem('volunbee_cookie_consent');
  if (consent) {
    return JSON.parse(consent);
  }
  return { necessary: true, analytics: false, marketing: false };
}

function saveCookieSettings(settings) {
  localStorage.setItem('volunbee_cookie_consent', JSON.stringify(settings));
  localStorage.setItem('volunbee_cookieconsent', 'dismissed');
  
  // Triggere Analytics/Marketing basierend auf Einstellungen
  if (settings.analytics) {
    enableAnalytics();
  } else {
    disableAnalytics();
  }
  
  if (settings.marketing) {
    enableMarketing();
  } else {
    disableMarketing();
  }
}

function enableAnalytics() {
  console.log('Analytics aktiviert');
}

function disableAnalytics() {
  console.log('Analytics deaktiviert');
}

function enableMarketing() {
  console.log('Marketing aktiviert');
}

function disableMarketing() {
  console.log('Marketing deaktiviert');
}

// Inline functions for backup
function rejectAllCookies() {
  console.log('Reject all (inline) clicked');
  const settings = { necessary: true, analytics: false, marketing: false };
  saveCookieSettings(settings);
  hideCookieSettings();
  
  const banner = document.querySelector('.cc-window');
  if (banner) {
    banner.style.display = 'none';
  }
}

// Event Listeners
document.addEventListener('DOMContentLoaded', function() {
  console.log('Cookie consent DOM loaded');
  
  // Modal Close Button
  const closeButton = document.getElementById('close-cookie-settings');
  if (closeButton) {
    closeButton.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('Close button clicked');
      hideCookieSettings();
    });
  } else {
    console.error('Close button not found');
  }
  
  // Modal Background Click
  const modal = document.getElementById('cookie-settings-modal');
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === this) {
        console.log('Modal background clicked');
        hideCookieSettings();
      }
    });
  }
  
  // Cookie Settings Buttons
  const acceptSelectedButton = document.getElementById('accept-selected-cookies');
  if (acceptSelectedButton) {
    acceptSelectedButton.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('Accept selected clicked');
      const settings = {
        necessary: true,
        analytics: document.getElementById('analytics-cookies').checked,
        marketing: document.getElementById('marketing-cookies').checked
      };
      saveCookieSettings(settings);
      hideCookieSettings();
      
      const banner = document.querySelector('.cc-window');
      if (banner) {
        banner.style.display = 'none';
      }
    });
  }
  
  const acceptAllButton = document.getElementById('accept-all-cookies');
  if (acceptAllButton) {
    acceptAllButton.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('Accept all clicked');
      const settings = { necessary: true, analytics: true, marketing: true };
      saveCookieSettings(settings);
      hideCookieSettings();
      
      const banner = document.querySelector('.cc-window');
      if (banner) {
        banner.style.display = 'none';
      }
    });
  }
  
  const rejectAllButton = document.getElementById('reject-all-cookies');
  if (rejectAllButton) {
    rejectAllButton.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('Reject all clicked');
      const settings = { necessary: true, analytics: false, marketing: false };
      saveCookieSettings(settings);
      hideCookieSettings();
      
      const banner = document.querySelector('.cc-window');
      if (banner) {
        banner.style.display = 'none';
      }
    });
  } else {
    console.error('Reject all button not found');
  }
});
</script>