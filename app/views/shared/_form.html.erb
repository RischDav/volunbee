<div id="contact-form-section" class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 mt-8">
  <div class="p-6 lg:p-8">
    <h3 class="text-xl sm:text-2xl font-bold text-slate-800 mb-6 flex items-center gap-3">
      <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      Interesse an dieser Position?
    </h3>

    <!-- Success/Error Messages -->
    <div id="form-messages" class="mb-6" style="display: none;">
      <!-- Messages will be inserted here via AJAX -->
    </div>

    <%= form_with(model: [@position, @message || Message.new], 
                  url: send_message_position_path(@position), 
                  method: :post,
                  local: false,
                  id: "contact-form",
                  class: "space-y-6") do |f| %>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Name Field -->
        <div>
          <%= f.label :sender_name, "Ihr Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.text_field :sender_name, 
                          placeholder: "Vollständiger Name", 
                          class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors",
                          required: true %>
        </div>

        <!-- Email Field -->
        <div>
          <%= f.label :sender_email, "E-Mail Adresse", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :sender_email, 
                            placeholder: "ihre.email@beispiel.de", 
                            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors",
                            required: true %>
        </div>
      </div>

      <!-- Phone Field -->
      <div>
        <%= f.label :sender_phone, "Telefonnummer (optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.telephone_field :sender_phone, 
                              placeholder: "+49 123 456789", 
                              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
      </div>

      <!-- Message Content -->
      <div>
        <%= f.label :content, "Ihre Nachricht", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :content, 
                        placeholder: "Beschreiben Sie Ihr Interesse an dieser Position und stellen Sie gerne Fragen...", 
                        rows: 5,
                        class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors resize-none",
                        required: true %>
        <p class="text-sm text-gray-500 mt-2">Mindestens 10 Zeichen erforderlich</p>
      </div>

      <!-- Submit Button -->
      <div class="flex justify-end">
        <%= f.submit "Nachricht senden", 
                     id: "submit-button",
                     class: "inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 cursor-pointer",
                     data: { disable_with: "Wird gesendet..." } %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('contact-form');
  const messagesDiv = document.getElementById('form-messages');
  
  if (form) {
    form.addEventListener('ajax:success', function(event) {
      // Show success message
      messagesDiv.innerHTML = `
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg flex items-center gap-3">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <strong>Nachricht gesendet!</strong> Vielen Dank für Ihr Interesse. Sie erhalten bald eine Antwort.
        </div>
      `;
      messagesDiv.style.display = 'block';
      
      // Clear form
      form.reset();
      
      // Scroll to message
      messagesDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Hide message after 5 seconds
      setTimeout(function() {
        messagesDiv.style.display = 'none';
      }, 5000);
    });
    
    form.addEventListener('ajax:error', function(event) {
      const errors = event.detail[0];
      let errorHTML = '';
      
      if (errors && errors.errors) {
        errorHTML = `
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg">
            <strong>Fehler beim Senden:</strong>
            <ul class="mt-2 list-disc list-inside">
        `;
        
        Object.keys(errors.errors).forEach(field => {
          errors.errors[field].forEach(error => {
            errorHTML += `<li>${error}</li>`;
          });
        });
        
        errorHTML += '</ul></div>';
      } else {
        errorHTML = `
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg flex items-center gap-3">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <strong>Fehler!</strong> Nachricht konnte nicht gesendet werden. Bitte versuchen Sie es erneut.
          </div>
        `;
      }
      
      messagesDiv.innerHTML = errorHTML;
      messagesDiv.style.display = 'block';
      messagesDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
});
</script>