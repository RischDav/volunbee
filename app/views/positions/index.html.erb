<h1 class="text-3xl font-bold mb-6">Offene Stellen</h1>
<% if !current_user.admin? %>
<% available_positions = 3 - @positions_count %>
<% if available_positions > 0 && !current_user.admin?%>
  <%= link_to "Neue Position erstellen (#{available_positions} positionen verfügbar)", new_position_path, class: "inline-block mb-8 px-4 py-2 rounded-md bg-green-500 text-black border border-slate-200 hover:bg-green-700", role: 'button' %>
<% else %>
  <span class="inline-block mb-8 px-4 py-2 rounded-md bg-gray-500 text-gray-300 border border-gray-400 cursor-not-allowed">Neue Position erstellen (0 positionen verfügbar)</span>
<% end %>
<% end %>
<% if @positions.present? %>
  <div>
    <% @positions.each do |position| %>
      <div class="bg-white shadow-md rounded-lg p-6 my-6 border border-gray-200">
        <h2 class="text-2xl font-semibold mb-2"><%= position.title %></h2>
        <p class="text-gray-700 mb-4"><%= position.description %></p>
        <div class="flex space-x-4">
          <%= link_to 'Bearbeiten', '#', class: 'inline-block bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-700' %>
          <%= button_to 'Löschen', position, method: :delete, class: 'inline-block bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-700' %>
        </div>
      </div>
      <%= position.pictures.each do |picture| %>
        <%= link_to image_tag(picture) %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-700">Keine offenen Stellen gefunden.</p>
<% end %>