<!-- DEBUG: List all positions passed to the view -->
<% if @positions.present? %>
  <% @positions.each do |p| %>
    <div style="background: #fffbe6; border: 1px solid #ffe58f; padding: 6px; margin-bottom: 4px; font-size: 0.95em;">
      <b>ID:</b> <%= p.id %> |
      <b>Title:</b> <%= p.title %> |
      <b>Org:</b> <%= p.organization_id %> |
      <b>Uni:</b> <%= p.university_id %> |
      <b>Visibility:</b> <%= p.visibility %> |
      <b>Visible Uni:</b> <%= p.visible_university_id %> |
      <b>Released:</b> <%= p.released %> |
      <b>Online:</b> <%= p.online %>
    </div>
  <% end %>
<% end %>
<div class="mx-auto my-4 p-8 bg-blue-50 rounded-lg shadow-md">
  <h1 class="text-3xl font-semibold text-gray-800 mb-6"><%= t('positions.index.title') %></h1>

  <!-- Button für neue Position: Nur für University Staff -->
  <%= render partial: 'new_position_button' if current_user.university_staff? %>

  <!-- Admin-Bereich für nicht freigegebene Positionen -->
  <%= render partial: 'admin_unreleased_positions', locals: { positions: @positions.where(released: false) } if current_user.admin? && @positions.where(released: false).exists? %>

  <!-- Liste der Positionen -->
  <% if @positions.present? %>
    <div class="space-y-6">
      <% if current_user.admin? %>
        <% @positions.where(released: true).each do |position| %>
          <%= render partial: 'position_card', locals: { position: position } %>
        <% end %>
      <% else %>
        <% @positions.each do |position| %>
          <%= render partial: 'position_card', locals: { position: position } %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-600 text-center mt-8"><%= t('positions.index.no_positions_available') %></p>
  <% end %>
</div>
