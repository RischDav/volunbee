<div class="min-h-screen bg-gray-50">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-8">
    <div class="mb-6 sm:mb-8">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-2"><%= t('positions.index.title') %></h1>
    </div>

  <!-- Button für neue Position -->
  <%= render partial: 'positions/shared/new_position_button' if (!current_user.admin? && !current_user.student?) %>

  <!-- Admin Alert for Unreleased Positions -->
  <%= render partial: 'positions/shared/admin_unreleased_positions', locals: { positions: @positions.where(released: false) } if current_user.admin? && @positions.where(released: false).exists? %>

  <!-- Positionen meiner Uni (nur für Studierende & Personal Uni) -->
  <% if current_user.university.present? %>
    <% university_positions = @positions.where(university_id: current_user.university.id) %>
    <% if university_positions.any? %>
      <div class="mb-8 sm:mb-12">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-4 sm:mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span class="text-base sm:text-xl lg:text-2xl">Positionen von <%= current_user.university.name %></span>
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
          <% university_positions.each do |position| %>
            <%= render partial: 'positions/shared/position_card', locals: { position: position } %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

   <!-- Positionen der Organization -->
  <% if current_user.organization.present? %>
    <% organization_positions = @positions.where(organization_id: current_user.organization.id) %>
    <% if organization_positions.any? %>
      <div class="mb-8 sm:mb-12">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-4 sm:mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span class="text-base sm:text-xl lg:text-2xl">Positionen von Ihnen</span>
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
          <% organization_positions.each do |position| %>
            <%= render partial: 'positions/shared/position_card', locals: { position: position } %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <% if @positions.present? && (current_user.admin? || current_user.student? || current_user.university_staff? || current_user.organization?) %>
    <% 
      volunteering_positions = current_user.admin? ? @positions.by_type('volunteering').released : @positions.by_type('volunteering')
      freetime_positions = current_user.admin? ? @positions.by_type('freetime').released : @positions.by_type('freetime')
    %>

    <!-- Ehrenamtliche Aktivitäten -->
    <% if volunteering_positions.any? %>
      <div class="mb-8 sm:mb-12">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-4 sm:mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          Ehrenamtliche Aktivitäten
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
          <% volunteering_positions.each do |position| %>
            <%= render partial: 'positions/shared/position_card', locals: { position: position } %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Freizeitaktivitäten -->
    <% if freetime_positions.any? %>
      <div class="mb-8 sm:mb-12">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-4 sm:mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h.01M12 5v.01M8 21l4-7 4 7M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
          </svg>
          Freizeitaktivitäten
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
          <% freetime_positions.each do |position| %>
            <%= render partial: 'positions/shared/position_card', locals: { position: position } %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>