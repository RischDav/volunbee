<h1 class="text-3xl">Offene Stellen</h1>

<% if !current_user.admin? %>
  <% available_positions = 3 - @positions_count %>
  <% if available_positions > 0 %>
    <%= link_to "Neue Position erstellen (#{available_positions} positionen verfügbar)", new_position_path, class: "inline-block mb-8 px-4 py-2 rounded-md bg-green-500 text-black border border-slate-200 hover:bg-green-700", role: 'button' %>
  <% else %>
    <span class="inline-block mb-8 px-4 py-2 rounded-md bg-gray-500 text-gray-300 border border-gray-400 cursor-not-allowed">Neue Position erstellen (0 positionen verfügbar)</span>
  <% end %>
<% end %>


<% if current_user.admin? && @positions.where(released: false).exists? %>
  <div class="bg-yellow-600 p-4 rounded-md">
    <div class="text-xl">Es gibt einige noch nicht freigegebene Positionen!</div>
    <% @positions.where(released: false).each do |position| %>
      <div class="bg-white shadow-md rounded-lg p-6 my-6 border border-gray-200">
        <h2 class="text-2xl font-semibold mb-2"><%= position.title %></h2>
        <p class="text-gray-700 mb-4"><%= position.description %></p>
        <div class="flex space-x-4">
          <% if position.mainPicture.attached? %>
            <%= link_to image_tag(position.mainPicture, style: "max-width: 200px;", class: "rounded"), url_for(position.mainPicture) %>
          <% end %>
          <% if position.picture1.attached? %>
            <%= link_to image_tag(position.picture1, style: "max-width: 200px;", class: "rounded"), url_for(position.picture1) %>
          <% end %>
          <% if position.picture2.attached? %>
            <%= link_to image_tag(position.picture2, style: "max-width: 200px;", class: "rounded"), url_for(position.picture2) %>
          <% end %>
          <% if position.picture3.attached? %>
            <%= link_to image_tag(position.picture3, style: "max-width: 200px;", class: "rounded"), url_for(position.picture3) %>
          <% end %>
        </div>
        <div class="flex space-x-4 mt-5">
          <%= link_to 'Ansehen', position_path(position), class: 'inline-block bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-700' %>
          <%= button_to 'Freigeben', release_position_path(position), method: :patch, class: 'inline-block bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-700' %>
        </div>
      </div>
      </div>
    <% end %>

<% end %>

<% if @positions.present? %>
  <div>
    <% @positions.each do |position| %>
      <div class="bg-white shadow-md rounded-lg p-6 my-6 border border-gray-200">
        <% if position.released == false %>
      <span style="color: orange;">Die Position wurde von uns noch nicht freigegeben und wird dem Endnutzer dementsprechend nicht angezeigt.</span>
    <% end %>
        <h2 class="text-2xl font-semibold mb-2"><%= position.title %></h2>
        <p class="text-gray-700 mb-4"><%= position.description %></p>
        <div class="flex space-x-4">
          <% if position.mainPicture.attached? %>
            <%= link_to image_tag(position.mainPicture, style: "max-width: 200px;", class: "rounded"), url_for(position.mainPicture) %>
          <% end %>
          <% if position.picture1.attached? %>
            <%= link_to image_tag(position.picture1, style: "max-width: 200px;", class: "rounded"), url_for(position.picture1) %>
          <% end %>
          <% if position.picture2.attached? %>
            <%= link_to image_tag(position.picture2, style: "max-width: 200px;", class: "rounded"), url_for(position.picture2) %>
          <% end %>
          <% if position.picture3.attached? %>
            <%= link_to image_tag(position.picture3, style: "max-width: 200px;", class: "rounded"), url_for(position.picture3) %>
          <% end %>
        </div>
        <div class="flex space-x-4 mt-5">
          <%= link_to 'Ansehen', position_path(position), class: 'inline-block bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-700' %>
            <% if !current_user.admin? %>
            <%= button_to "Löschen", position_path(position), method: :delete, class: "inline-block bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-700" %>
            <%= link_to 'Bearbeiten', edit_position_path(position), class: 'inline-block bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-700' %>
          <% else %>
            <% if position.online %>
            <%= button_to 'Offline nehmen', offline_position_path(position), method: :patch, class: 'inline-block bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-700' %>
            <% else %>
            <%= button_to 'Online nehmen', online_position_path(position), method: :patch, class: 'inline-block bg-green-500 text-white px-4 py-2 rounded-md hover:bg-green-700' %>
            <% end %>
            <%= button_to 'Sperren', lock_position_path(position), method: :patch, class: 'inline-block bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-700' %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-700">Keine offenen Stellen gefunden.</p>
<% end %>