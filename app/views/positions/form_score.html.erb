<h2 class="text-2xl font-bold">Score</h2>
<div class="bg-slate-100 rounded-lg p-6">
  <p class="text-sm text-gray-700">Verteilen Sie 15 Punkte auf die folgenden Eigenschaften...</p>
  <div id="remaining-points" class="my-4 text-lg font-medium text-gray-700">Verbleibende Punkte: 15</div>
  <div class="gap-4">
    <% { creative_skills: "Kreativität", technical_skills: "Technische Skills", social_skills: "Soziale Skills", language_skills: "Sprachliche Skills", flexibility: "Flexibilität" }.each do |skill, label| %>
      <div class="field">
        <%= f.label skill, label, class: "block text-sm font-medium text-gray-700" %>
        <div>
          <% (1..5).each do |i| %>
            <label>
              <%= f.radio_button skill, i, class: "rating-input" %> <%= i %>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>