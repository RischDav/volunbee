<%#
	Partial: positions/fields/_type		<button type="button"
					data-action="click->position-type#confirm"
					class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
			<%= t('positions.type_selector.confirm') %>
	</button>ector
	Usage: <%= render 'positions/fields/type_selector', f: f %>
	Expects: local variable `f` (form builder)
%>

<% selected_type_key = if f.object.respond_to?(:type)
  f.object.type.presence
else
  nil
end %>

<div class="w-full">
		<div class="mb-2">
			<label for="position_type" class="block text-sm font-medium text-gray-900">
				<%= t('positions.type_selector.label') %>
			</label>
			<p class="mt-1 text-sm text-gray-500">
				<%= t('positions.type_selector.help') %>
			</p>
		</div>

	<div class="flex flex-col sm:flex-row sm:items-center gap-3">
		<div class="sm:flex-1">
							<%= f.select :type,
								options_for_select([
									[t('positions.type_selector.options.volunteering'), 'volunteering'],
									[t('positions.type_selector.options.freetime'), 'freetime'],
									[t('positions.type_selector.options.university_position'), 'university_position']
								], selected_type_key),
						{ prompt: t('positions.type_selector.prompt') },
				class: "block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 sm:text-sm",
				required: true
			%>
		</div>

			<button type="button"
						class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
				<%= t('positions.type_selector.confirm') %>
		</button>
	</div>
</div>

