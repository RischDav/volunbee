<!-- University Position-specific fields -->
<div class="space-y-10">
  <!-- Basic Information -->
  <%= render 'positions/shared/form_general_information', f: f %>
  
  <!-- University-specific section -->
  <div class="space-y-10 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm lg:p-10">
    <h2 class="text-2xl font-bold text-purple-600">Universitätsposition Details</h2>
    
    <!-- Position Type -->
    <div class="field space-y-3">
      <%= f.label :university_position_type, "Art der Position", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :university_position_type, 
          options_for_select([
            ['Forschungsassistenz', 'research'],
            ['Tutorium', 'tutorial'],
            ['Hilfskraft', 'assistant'],
            ['Projektmitarbeit', 'project'],
            ['Praktikum', 'internship'],
            ['Studentische Vertretung', 'representation']
          ]),
          { prompt: 'Wähle eine Kategorie' },
          { class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500" } %>
      <p class="text-sm text-gray-500">Welche Art von Universitätsposition ist das?</p>
    </div>

    <!-- Department -->
    <div class="field space-y-3">
      <%= f.label :department, "Fachbereich/Institut", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :department, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "z.B. Informatik, BWL, Maschinenbau..." %>
      <p class="text-sm text-gray-500">Zu welchem Fachbereich gehört die Position?</p>
    </div>

    <!-- Required qualifications -->
    <div class="field space-y-3">
      <%= f.label :qualifications, "Voraussetzungen", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :qualifications, rows: 4, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "z.B. Semester, Vorkenntnisse, Noten..." %>
      <p class="text-sm text-gray-500">Welche Voraussetzungen müssen Studierende erfüllen?</p>
    </div>

    <!-- Compensation -->
    <div class="field space-y-3">
      <%= f.label :compensation, "Vergütung", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :compensation, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "z.B. 12€/Stunde, Credit Points, unbezahlt..." %>
      <p class="text-sm text-gray-500">Wie wird die Position vergütet?</p>
    </div>

    <!-- Duration -->
    <div class="field space-y-3">
      <%= f.label :duration, "Dauer", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :duration, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "z.B. Ein Semester, 6 Monate, 20 Stunden..." %>
      <p class="text-sm text-gray-500">Wie lange dauert die Position?</p>
    </div>
  </div>

  <!-- Images -->
  <%= render 'positions/shared/form_images', f: f %>

  <!-- Skills (Required but simplified for university positions) -->
  <div class="hidden">
    <%= f.hidden_field :creative_skills, value: 3 %>
    <%= f.hidden_field :technical_skills, value: 3 %>
    <%= f.hidden_field :social_skills, value: 3 %>
    <%= f.hidden_field :language_skills, value: 3 %>
    <%= f.hidden_field :flexibility, value: 3 %>
  </div>

  <!-- University confirmation -->
  <div class="bg-purple-50 rounded-xl p-8 space-y-6">
    <h2 class="text-2xl font-bold">Universitätsbestätigung</h2>
    <div class="space-y-6">
      <div class="field space-y-3">
        <div class="flex items-start">
          <%= f.check_box :university_approved, id: "university-checkbox", class: "mt-1 h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded" %>
          <%= f.label :university_approved, "Diese Position ist von der Universität genehmigt", class: "ml-3 text-sm font-medium text-gray-700" %>
        </div>
        <p class="ml-7 text-sm text-gray-500">Bestätige, dass diese Position offiziell von deiner Universität genehmigt wurde.</p>
      </div>

      <div class="field space-y-3">
        <div class="flex items-start">
          <%= f.check_box :terms_accepted, id: "terms-checkbox-university", class: "mt-1 h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded" %>
          <%= f.label :terms_accepted, "Ich bestätige die Richtigkeit der Angaben", class: "ml-3 text-sm font-medium text-gray-700" %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initUniversityFields() {
    // Validation for university fields
    const universityCheckbox = document.getElementById("university-checkbox");
    const termsCheckbox = document.getElementById("terms-checkbox-university");
    const submitButton = document.getElementById("submit-button");

    function updateSubmitButtonState() {
      if (universityCheckbox && termsCheckbox && submitButton) {
        if (universityCheckbox.checked && termsCheckbox.checked) {
          submitButton.disabled = false;
          submitButton.classList.remove("bg-gray-400", "cursor-not-allowed");
          submitButton.classList.add("bg-purple-600", "hover:bg-purple-700");
        } else {
          submitButton.disabled = true;
          submitButton.classList.remove("bg-purple-600", "hover:bg-purple-700");
          submitButton.classList.add("bg-gray-400", "cursor-not-allowed");
        }
      }
    }

    if (universityCheckbox && termsCheckbox && submitButton) {
      updateSubmitButtonState();
      universityCheckbox.addEventListener("change", updateSubmitButtonState);
      termsCheckbox.addEventListener("change", updateSubmitButtonState);
    }
  }

  setTimeout(initUniversityFields, 100);
</script>