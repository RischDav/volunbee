<div class="bg-white rounded-lg shadow-sm border p-4 sm:p-6">
  <header class="mb-6 sm:mb-8 text-center">
    <div class="mb-3 sm:mb-4">
      <span class="text-xs sm:text-sm font-semibold text-gray-600 bg-gray-200 px-3 sm:px-4 py-1.5 sm:py-2 rounded-full"><%= t('applications.forms.badges.application') %></span>
    </div>
    
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-3 sm:mb-4">
      <%= t('applications.forms.titles.volunteer') %>
    </h2>
    
    <p class="text-sm sm:text-base text-gray-600 max-w-2xl mx-auto mb-4 sm:mb-6 px-2">
      <%= t('applications.forms.descriptions.volunteer') %>
    </p>
  </header>

    <% # If form is passed from parent view, use it. Otherwise don't create one (will fail) %>
  <% if defined?(form) && form %>
    <!-- Form is handled by parent view -->
    
    <!-- Personal Information -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6">
      <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4 sm:mb-6"><%= t('applications.forms.sections.personal_information') %></h3>
      
      <div class="grid gap-4 sm:gap-6 md:grid-cols-2">
        <div>
          <%= form.label :first_name, t('applications.forms.fields.first_name'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.text_field :first_name, required: true, class: "w-full rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", placeholder: t('applications.forms.placeholders.first_name') %>
        </div>

        <div>
          <%= form.label :last_name, t('applications.forms.fields.last_name'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.text_field :last_name, required: true, class: "w-full rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", placeholder: t('applications.forms.placeholders.last_name') %>
        </div>
      </div>

      <div class="mt-4 sm:mt-6">
  <%= form.label :email, t('applications.forms.fields.email_address'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
  
  <% if user_signed_in? %>
    <%# Eingeloggter User: Feld ist ausgefüllt und gesperrt %>
    <%= form.email_field :email, 
        value: current_user.email, 
        readonly: true, 
        class: "w-full rounded-md border border-gray-300 bg-gray-100 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base text-gray-500 cursor-not-allowed focus:outline-none", 
        placeholder: t('applications.forms.placeholders.email') %>
    <p class="mt-1 text-xs text-gray-400">Verknüpft mit deinem Account-E-Mail.</p>
  <% else %>
    <%# Gast: Feld ist leer und bearbeitbar %>
    <%= form.email_field :email, 
        required: true, 
        class: "w-full rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", 
        placeholder: t('applications.forms.placeholders.email') %>
  <% end %>
</div>

<div class="mt-4 sm:mt-6">
  <%= form.label :preferred_language, "Preferred Language / Bevorzugte Sprache", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5" %>
  <%= form.select :preferred_language, 
      options_for_select([
        ['Deutsch', 'german'],
        ['English', 'english']
      ], @application_object.preferred_language),
      { prompt: 'Please select / Bitte wählen' }, 
      { 
        class: "w-full rounded-md border border-gray-400 px-3 py-2 text-sm sm:text-base focus:ring-2 focus:ring-green-500",
        required: true 
      } %>
</div>

      <div class="grid gap-4 sm:gap-6 md:grid-cols-2 mt-4 sm:mt-6">
        <div>
          <%= form.label :gender, t('applications.forms.fields.gender'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.select :gender, 
              options_for_select([
      [t('applications.forms.options.please_select'), ''],
      [t('applications.forms.options.gender.male'), 'male'],
      [t('applications.forms.options.gender.female'), 'female'],
      [t('applications.forms.options.gender.non_binary'), 'non-binary'],
      [t('applications.forms.options.gender.prefer_not_to_say'), 'prefer_not_to_say']
    ], ''),
              { prompt: false }, 
              { 
                class: "w-full rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500",
                required: true
              } %>
        </div>

      <div>
          <%= form.label :age, t('applications.forms.fields.age'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.number_field :age, required: true, class: "w-full rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500" %>
        </div>
    </section>

    <!-- Volunteer Experience -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6">
      <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4 sm:mb-6"><%= t('applications.forms.sections.volunteer_experience') %></h3>
      
      <div class="mb-4 sm:mb-6">
        <%= form.label :has_volunteer_experience, t('applications.forms.fields.has_volunteer_experience'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
        <%= form.select :has_volunteer_experience, 
            options_for_select([
              [t('applications.forms.options.please_select'), ''],
              [t('applications.forms.options.experience.yes'), 'yes'],
              [t('applications.forms.options.experience.no'), 'no']
            ], ''), 
            { prompt: false }, 
            { 
              class: "w-full md:w-1/2 rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500",
              onchange: "toggleVolunteerExperienceDetails(this.value)",
              required: true
            } %>
      </div>

      <div id="volunteer-experience-details" class="hidden">
        <%= form.label :volunteer_experience_description, t('applications.forms.fields.volunteer_experience_description'), class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
        <p class="text-xs sm:text-sm text-gray-500 mb-3"><%= t('applications.forms.help_texts.experience_details') %></p>
        <%= form.text_area :volunteer_experience_description, rows: 4, class: "w-full rounded-md border border-gray-400 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500 resize-none", placeholder: t('applications.forms.placeholders.volunteer_experience_description') %>
        <div class="flex justify-between items-center mt-2">
          <p class="text-xs text-gray-500"><%= t('applications.forms.character_limits.experience_max') %></p>
          <span id="volunteer-experience-counter" class="text-xs text-gray-500">0 / 800</span>
        </div>
      </div>
    </section>


  <% else %>
    <!-- This partial should only be called with a form object passed from parent -->
    <div class="p-4 bg-red-100 border border-red-400 text-red-700 rounded">
      <p><%= t('applications.forms.errors.form_error') %></p>
    </div>
  <% end %>
</div>

<script>
  // Character counter for "About yourself" field
  document.addEventListener('DOMContentLoaded', function() {
    const aboutField = document.querySelector('[name*="about_yourself"]');
    const aboutCounter = document.getElementById('about-counter');
  

    // Character counter for volunteer experience description
    const volunteerExperienceField = document.querySelector('[name*="volunteer_experience_description"]');
    const volunteerExperienceCounter = document.getElementById('volunteer-experience-counter');
    
    if (volunteerExperienceField && volunteerExperienceCounter) {
      volunteerExperienceField.addEventListener('input', function() {
        const length = this.value.length;
        volunteerExperienceCounter.textContent = length + ' / 100';
        
        if (length > 100) {
          volunteerExperienceCounter.classList.add('text-red-500');
          volunteerExperienceCounter.classList.remove('text-gray-500');
        } else {
          volunteerExperienceCounter.classList.add('text-gray-500');
          volunteerExperienceCounter.classList.remove('text-red-500');
        }
      });
    }
  });

  // Toggle volunteer experience details
  function toggleVolunteerExperienceDetails(value) {
    const detailsDiv = document.getElementById('volunteer-experience-details');
    const experienceField = document.querySelector('[name*="volunteer_experience_description"]');
    
    if (value === 'yes') {
      detailsDiv.classList.remove('hidden');
      experienceField.required = true;
    } else {
      detailsDiv.classList.add('hidden');
      experienceField.required = false;
      experienceField.value = '';
    }
  }
</script>