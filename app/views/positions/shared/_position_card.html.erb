<%#
  Unified Position Card with "Ghost" Design
  - Adapts content based on user role (student, organization, etc.).
  - Uses consistent styling variables for a cohesive look.
%>

<%# Design System Variables %>
<%
  card_base_class = "rounded-2xl border border-[#6B7280] overflow-hidden flex flex-col h-full"
  content_padding = "p-5 sm:p-6"
  text_color = "text-[#292b2e]"
  title_color = "text-gray-600"
  accent_color = "text-[#F2C94C]"
  title_sub_class = "text-lg font-semibold leading-tight sm:text-xl #{title_color}"
  text_main_class = "text-sm leading-relaxed sm:text-base #{text_color}"
  tag_class = "inline-block bg-[#2c333e] text-[#a0aec0] text-xs font-medium px-2.5 py-1 rounded-full"
%>

<article class="<%= card_base_class %>">
  <%# --- IMAGE SECTION --- %>
  <%# Students/Staff see a large image, Organizations see a smaller one or none. %>
  <% if current_user.student? || current_user.university_staff? %>
    <div class="relative h-56 w-full border-b border-[#6B7280]">
      <% begin %>
        <% if position.main_picture.attached? %>
          <%= image_tag position.main_picture.variant(resize_to_fill: [600, 400]).processed, class: "w-full h-full object-cover", alt: position.title %>
        <% else %>
          <%# Fallback placeholder %>
          <div class="w-full h-full bg-[#2a3039] flex items-center justify-center text-center p-4">
            <div>
              <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z"></path></svg>
              <p class="font-medium <%= title_color %>">Position Image</p>
            </div>
          </div>
        <% end %>
      <% rescue %>
        <%# Rescue block for processing errors %>
      <% end %>

      <%# "Not Released" Badge %>
      <% if !position.released? %>
        <div class="absolute top-3 left-3">
          <span class="bg-orange-500/80 text-white px-3 py-1 rounded-full text-xs font-bold shadow-lg backdrop-blur-sm">
            <%= t('positions.position_card.not_released') %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# --- CONTENT SECTION --- %>
  <div class="<%= content_padding %> flex flex-col flex-grow">
    <%# Compact Header for Organization view %>
    <% if current_user.organization? %>
      <div class="flex items-start justify-between mb-4">
        <h2 class="<%= title_sub_class %> flex-1"><%= position.title %></h2>
        <% if !position.released? %>
          <span class="ml-4 flex-shrink-0 bg-orange-500/20 text-orange-400 text-xs font-medium px-2.5 py-1 rounded-full">
            <%= t('positions.position_card.not_released') %>
          </span>
        <% end %>
      </div>
    <% else %>
      <%# Standard Header for Student/Admin view %>
      <div class="flex items-center mb-4 space-x-3">
        <% scope = position.organization || position.university %>
        <% if scope&.logo&.attached? %>
          <div class="bg-[#2a3039] rounded-lg p-1.5 border border-[#6B7280] w-12 h-12 flex items-center justify-center flex-shrink-0">
            <%= image_tag scope.logo.variant(resize_to_limit: [48, 48]).processed, class: "object-contain w-full h-full", alt: scope.name %>
          </div>
        <% end %>
        <div>
          <p class="font-semibold text-sm <%= title_color %>"><%= scope&.name %></p>
          <% if position.weekly_time_commitment.to_i > 0 %>
            <p class="text-xs <%= text_color %> mt-0.5">
              <%= pluralize(position.weekly_time_commitment, "hour") %>/week
            </p>
          <% end %>
        </div>
      </div>
      <h2 class="<%= title_sub_class %> mb-3"><%= position.title %></h2>
    <% end %>

    <%# Description %>
    <p class="<%= text_main_class %> mb-5"><%= truncate(position.description, length: 140) %></p>

    <%# Skills Tags %>
    <div class="flex flex-wrap gap-2 mb-6">
      <% if position.creative_skills > 3 %><span class="<%= tag_class %>">🎨 Creative</span><% end %>
      <% if position.technical_skills > 3 %><span class="<%= tag_class %>">⚡ Technical</span><% end %>
      <% if position.social_skills > 3 %><span class="<%= tag_class %>">👥 Social</span><% end %>
      <% if position.position_temporary %><span class="<%= tag_class %>">📅 Temporary</span><% end %>
    </div>

    <%# Action Buttons (Rendered from a shared partial) %>
    <div class="mt-auto">
      <%= render partial: 'positions/shared/position_actions', locals: { position: position } %>
    </div>
  </div>
</article>