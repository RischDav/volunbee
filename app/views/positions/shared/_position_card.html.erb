<% if current_user.student? %>
  <!-- Student Design: Ausführlich und visuell ansprechend -->
  <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
    <!-- Hero Image Section -->
    <div class="relative h-64 w-full">
      <% begin %>
        <% if position.main_picture.attached? %>
          <%= image_tag position.main_picture.variant(resize_to_limit: [1200, 600]).processed, class: "w-full h-full object-cover", alt: position.title %>
        <% elsif position.picture1.attached? %>
          <%= image_tag position.picture1.variant(resize_to_limit: [1200, 600]).processed, class: "w-full h-full object-cover", alt: position.title %>
        <% else %>
          <% raise "no_image" %>
        <% end %>
      <% rescue ActiveStorage::FileNotFoundError, StandardError %>
        <div class="w-full h-full bg-gradient-to-br from-blue-500 via-purple-500 to-pink-500 flex items-center justify-center">
          <div class="text-white text-center">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-80" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z" clip-rule="evenodd"></path>
              <path d="M2 13.692V16a2 2 0 002 2h12a2 2 0 002-2v-2.308A24.974 24.974 0 0110 15c-2.796 0-5.487-.46-8-1.308z"></path>
            </svg>
            <p class="text-lg font-medium">Spannende Stelle wartet auf dich!</p>
          </div>
        </div>
      <% end %>
    
      
      <!-- Status Badge -->
      <% if position.released == false %>
        <div class="absolute top-4 left-4">
          <span class="bg-orange-500 text-white px-3 py-1 rounded-full text-sm font-medium shadow-lg">
            <%= t('positions.position_card.not_released') %>
          </span>
        </div>
      <% end %>
    </div>
    
    <!-- Content Section -->
    <div class="p-8">
      <!-- Organization/University Info mit Logo -->
      <div class="flex items-center mb-6 space-x-4">
        <% begin %>
          <% if position.organization&.logo&.attached? %>
            <div class="bg-gray-50 rounded-xl p-2 shadow border border-gray-200 w-14 h-14 flex items-center justify-center">
              <%= image_tag position.organization.logo.variant(resize_to_limit: [56, 56]).processed,
                    class: "object-contain w-full h-full",
                    alt: position.organization.name %>
            </div>
          <% elsif position.university&.logo&.attached? %>
            <div class="bg-gray-50 rounded-xl p-2 shadow border border-gray-200 w-14 h-14 flex items-center justify-center">
              <%= image_tag position.university.logo.variant(resize_to_limit: [56, 56]).processed,
                    class: "object-contain w-full h-full",
                    alt: position.university.name %>
            </div>
          <% end %>
        <% rescue ActiveStorage::FileNotFoundError, StandardError %>
          <!-- Fallback: No logo displayed -->
        <% end %>

        <div>
          <p class="text-sm text-gray-600 font-medium">
            <%= position.organization&.name || position.university&.name %>
          </p>
          <% if position.weekly_time_commitment && position.weekly_time_commitment > 0 %>
            <p class="text-xs text-blue-600 font-medium mt-1">
              ⏱ <%= pluralize(position.weekly_time_commitment, "Stunde") %> pro Woche
            </p>
          <% end %>
        </div>
      </div>

      <!-- Title -->
      <h2 class="text-2xl font-bold text-gray-900 mb-4 leading-tight">
        <%= position.title %>
      </h2>
      
      <!-- Description -->
      <p class="text-gray-700 mb-6 leading-relaxed">
        <%= position.description %>
      </p>

      <!-- Skills Tags -->
      <div class="flex flex-wrap gap-2 mb-6">
        <% if position.creative_skills > 3 %>
          <span class="bg-purple-100 text-purple-800 text-xs font-medium px-2.5 py-0.5 rounded-full">🎨 <%= t('positions.position_card.skills.creative') %></span>
        <% end %>
        <% if position.technical_skills > 3 %>
          <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">⚡ <%= t('positions.position_card.skills.technical') %></span>
        <% end %>
        <% if position.social_skills > 3 %>
          <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded-full">👥 <%= t('positions.position_card.skills.social') %></span>
        <% end %>
        <% if position.language_skills > 3 %>
          <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded-full">🌍 <%= t('positions.position_card.skills.language') %></span>
        <% end %>
        <% if position.position_temporary %>
          <span class="bg-orange-100 text-orange-800 text-xs font-medium px-2.5 py-0.5 rounded-full">📅 <%= t('positions.position_card.temporary') %></span>
        <% end %>
      </div>
      
      <!-- Action Button -->
  <%= render partial: 'positions/shared/position_actions', locals: { position: position } %>
    </div>
  </div>

<% elsif current_user.organization? || current_user.university? %>
  <!-- Organization/University Staff Design: Kompakt und funktional -->
  <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200 border border-gray-200">
    <div class="p-6">
      <div class="flex items-start justify-between mb-4">
        <div class="flex-1">
          <% if position.released == false %>
            <span class="inline-block bg-orange-100 text-orange-800 text-xs font-medium px-2 py-1 rounded mb-2">
              <%= t('positions.position_card.not_released') %>
            </span>
          <% end %>
          <h2 class="text-xl font-semibold text-gray-900 mb-2"><%= position.title %></h2>
          <p class="text-gray-600 text-sm mb-4"><%= truncate(position.description, length: 150) %></p>
        </div>
        
        <!-- Thumbnail Image -->
        <div class="ml-4 flex-shrink-0">
          <% begin %>
            <% if position.main_picture.attached? %>
              <%= image_tag position.main_picture.variant(resize_to_limit: [80, 80]).processed, class: "w-20 h-20 object-cover rounded-lg", alt: position.title %>
            <% elsif position.picture1.attached? %>
              <%= image_tag position.picture1.variant(resize_to_limit: [80, 80]).processed, class: "w-20 h-20 object-cover rounded-lg", alt: position.title %>
            <% else %>
              <% raise "no_image" %>
            <% end %>
          <% rescue ActiveStorage::FileNotFoundError, StandardError %>
            <div class="w-20 h-20 bg-gray-100 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- Stats -->
      <div class="flex items-center text-sm text-gray-500 mb-4 space-x-4">
        <% if position.weekly_time_commitment && position.weekly_time_commitment > 0 %>
          <span>⏱ <%= position.weekly_time_commitment %>h/Woche</span>
        <% end %>
        <span>📅 <%= position.created_at.strftime("%d.%m.%Y") %></span>
        <% if position.position_temporary %>
          <span class="text-orange-600">🔄 <%= t('positions.position_card.temporary') %></span>
        <% end %>
      </div>
      
  <%= render partial: 'positions/shared/position_actions', locals: { position: position } %>
    </div>
  </div>

<% else %>
  <!-- Fallback Design: Standard -->
  <div class="bg-white shadow-md rounded-lg p-6 border border-gray-200">
    <% if position.released == false %>
      <span style="color: orange;"><%= t('positions.position_card.not_released') %></span>
    <% end %>
    <h2 class="text-2xl font-semibold mb-2"><%= position.title %></h2>
    <p class="text-gray-700 mb-4 break-words whitespace-normal"><%= position.description %></p>
  <%= render partial: 'positions/shared/position_images', locals: { position: position } %>
  <%= render partial: 'positions/shared/position_actions', locals: { position: position } %>
  </div>
<% end %>
