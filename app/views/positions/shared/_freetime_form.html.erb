<div class="bg-white rounded-lg shadow-sm border p-4 sm:p-6">
  <header class="mb-6 sm:mb-8 text-center">
    <div class="mb-3 sm:mb-4">
      <span class="text-xs sm:text-sm font-semibold text-gray-600 bg-gray-200 px-3 sm:px-4 py-1.5 sm:py-2 rounded-full">Interest</span>
    </div>
    
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-3 sm:mb-4">
      Interest in Freetime Activity
    </h2>
    
    <p class="text-sm sm:text-base text-gray-600 max-w-2xl mx-auto mb-4 sm:mb-6 px-2">
      Please fill out the following form to express your interest in this freetime activity. All information will be treated confidentially.
    </p>
  </header>

  <% # If form is passed from parent view, use it. Otherwise don't create one (will fail) %>
  <% if defined?(form) && form %>
    <!-- Form is handled by parent view -->
    
    <!-- Personal Information -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6">
      <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4 sm:mb-6">Personal Information</h3>
      
      <div class="grid gap-4 sm:gap-6 md:grid-cols-2">
        <div>
          <%= form.label :first_name, "First Name", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.text_field :first_name, required: true, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", placeholder: "Your first name" %>
        </div>

        <div>
          <%= form.label :last_name, "Last Name", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.text_field :last_name, required: true, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", placeholder: "Your last name" %>
        </div>
      </div>

      <div class="mt-4 sm:mt-6">
        <%= form.label :email, "Email Address", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
        <%= form.email_field :email, required: true, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", placeholder: "your.email@example.com" %>
      </div>

      <div class="grid gap-4 sm:gap-6 md:grid-cols-2 mt-4 sm:mt-6">
        <div>
          <%= form.label :phone_number, "Phone Number", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.telephone_field :phone_number, required: true, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500", placeholder: "+49 123 456 789" %>
          <p class="text-xs sm:text-sm text-gray-500 mt-2">
            We may need to contact you by phone for important updates.
          </p>
        </div>

        <div>
          <%= form.label :birth_date, "Date of Birth", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
          <%= form.date_field :birth_date, required: true, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-xs sm:text-sm text-gray-500 mt-2">
            Age is required to verify legal adulthood.
          </p>
        </div>
      </div>

      <div class="mt-4 sm:mt-6">
        <%= form.label :gender, "Gender", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
        <%= form.select :gender, 
            options_for_select([
              ['Please select...', ''],
              ['Male', 'male'],
              ['Female', 'female'],
              ['Non-binary', 'non-binary'],
              ['Prefer not to say', 'prefer_not_to_say']
            ]), 
            { prompt: false }, 
            { class: "w-full md:w-1/2 rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500" } %>
        <p class="text-xs sm:text-sm text-gray-500 mt-2">
          Optional - This information helps us ensure inclusive practices.
        </p>
      </div>
    </section>

    <!-- Motivation -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6">
      <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4 sm:mb-6">Motivation</h3>
      
      <div>
        <%= form.label :motivation, "Why are you interested in this activity?", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
        <p class="text-xs sm:text-sm text-gray-500 mb-3">Optional - Tell us what draws you to this freetime activity.</p>
        <%= form.text_area :motivation, rows: 4, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500 resize-none", placeholder: "Describe what interests you about this activity..." %>
        <div class="flex justify-between items-center mt-2">
          <p class="text-xs text-gray-500">Maximum 500 characters</p>
          <span id="motivation-counter" class="text-xs text-gray-500">0 / 500</span>
        </div>
      </div>
    </section>

    <!-- About Yourself -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6">
      <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-4 sm:mb-6">About You</h3>
      
      <div>
        <%= form.label :about_yourself, "Tell us about yourself", class: "block text-xs sm:text-sm font-medium text-gray-700 mb-1.5 sm:mb-2" %>
        <p class="text-xs sm:text-sm text-gray-500 mb-3">Optional - Share something about yourself, your interests, or what you hope to gain from this activity.</p>
        <%= form.text_area :about_yourself, rows: 5, class: "w-full rounded-md border-gray-300 px-2.5 sm:px-3 py-1.5 sm:py-2 text-sm sm:text-base focus:border-blue-500 focus:ring-blue-500 resize-none", placeholder: "Tell us about yourself, your interests, hobbies, or what you're looking forward to in this activity..." %>
        <div class="flex justify-between items-center mt-2">
          <p class="text-xs text-gray-500">Maximum 800 characters</p>
          <span id="about-counter" class="text-xs text-gray-500">0 / 800</span>
        </div>
      </div>
    </section>

  <% else %>
    <!-- This partial should only be called with a form object passed from parent -->
    <div class="p-4 bg-red-100 border border-red-400 text-red-700 rounded">
      <p>Error: This form requires a form object to be passed from the parent view.</p>
    </div>
  <% end %>
</div>

<script>
  // Character counters
  document.addEventListener('DOMContentLoaded', function() {
    const motivationField = document.querySelector('[name*="motivation"]');
    const motivationCounter = document.getElementById('motivation-counter');
    
    const aboutField = document.querySelector('[name*="about_yourself"]');
    const aboutCounter = document.getElementById('about-counter');
    
    if (motivationField && motivationCounter) {
      motivationField.addEventListener('input', function() {
        const length = this.value.length;
        motivationCounter.textContent = length + ' / 500';
        
        if (length > 500) {
          motivationCounter.classList.add('text-red-500');
          motivationCounter.classList.remove('text-gray-500');
        } else {
          motivationCounter.classList.add('text-gray-500');
          motivationCounter.classList.remove('text-red-500');
        }
      });
    }
    
    if (aboutField && aboutCounter) {
      aboutField.addEventListener('input', function() {
        const length = this.value.length;
        aboutCounter.textContent = length + ' / 800';
        
        if (length > 800) {
          aboutCounter.classList.add('text-red-500');
          aboutCounter.classList.remove('text-gray-500');
        } else {
          aboutCounter.classList.add('text-gray-500');
          aboutCounter.classList.remove('text-red-500');
        }
      });
    }
  });
</script>
