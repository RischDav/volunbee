<!-- FAQ Section -->
<div class="space-y-4 mt-8">
  <h2 class="text-2xl font-bold"><%= t('shared.faq.title') %></h2>
  <p class="text-sm text-gray-700"><%= t('shared.faq.description') %></p>

  <div id="faqs" class="space-y-4">
    <%= f.fields_for :faqs do |faq_fields| %>
      <div class="field bg-gray-50 p-4 rounded-lg">
        <div class="space-y-4">
          <%= faq_fields.label :question, t('shared.faq.question_label'), class: "block text-sm font-medium text-gray-700" %>
          <%= faq_fields.text_field :question, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('shared.faq.question_placeholder') %>
          
          <%= faq_fields.label :answer, t('shared.faq.answer_label'), class: "block text-sm font-medium text-gray-700 mt-4" %>
          <%= faq_fields.text_area :answer, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('shared.faq.answer_placeholder') %>
          
          <button type="button" class="remove-faq mt-2 inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
            <%= t('shared.faq.remove_button') %>
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <button type="button" id="add_faq" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
    <%= t('shared.faq.add_button') %>
  </button>
</div>
