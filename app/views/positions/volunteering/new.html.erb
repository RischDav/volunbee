<div class="min-h-screen bg-gradient-to-br from-green-50 via-white to-emerald-50 py-4 sm:py-8 flex flex-col justify-center lg:py-14">
  <div class="relative py-2 sm:py-4 sm:max-w-xl md:max-w-2xl lg:max-w-4xl xl:max-w-6xl mx-auto w-full">
    <div class="relative mx-2 sm:mx-4 rounded-2xl sm:rounded-3xl bg-white px-4 py-8 sm:px-6 sm:py-12 lg:px-12 lg:py-14 xl:px-16 shadow-xl border border-gray-100">
      
      <!-- Header -->
      <div class="text-center mb-6 sm:mb-8 lg:mb-12">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-green-800 mb-2 sm:mb-4">🤝 Ehrenamtliche Position erstellen</h1>
        <p class="text-sm sm:text-base lg:text-lg text-green-600 px-2">Erstelle eine Position für Freiwilligenarbeit und gesellschaftliches Engagement</p>
      </div>

      <%= form_with model: @position, url: positions_path, local: true, class: "space-y-12", multipart: true do |f| %>
      <!-- Flash Alerts for custom error messages -->
<% if flash[:alert] %>
  <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
    <div class="flex items-start">
      <svg class="w-5 h-5 text-red-500 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <div>
        <h3 class="font-bold mb-2">Fehler beim Erstellen der Position:</h3>
        <div class="text-sm">
          <%= flash[:alert].html_safe %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<!-- Standard Rails Errors for fallback -->
<% if @position.errors.any? %>
  <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
    <div class="flex items-start">
      <svg class="w-5 h-5 text-red-500 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <div>
        <h3 class="font-bold mb-2">Fehler beim Speichern (<%= pluralize(@position.errors.count, "Fehler") %>):</h3>
        <ul class="list-disc pl-5 text-sm space-y-1">
          <% @position.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>
        <!-- Set the type to volunteering -->
        <%= f.hidden_field :type, value: 'volunteering' %>

        <div class="space-y-10">
          <h2 class="text-2xl font-bold text-red-600"><%= t('positions.new.subtitle') %></h2>

          <%= render 'positions/shared/form_general_information', f: f %>
          <%= render 'positions/shared/form_images', f: f %>
          <%= render 'positions/shared/form_score', f: f %>
          
          <!-- FAQ Section -->
          <div class="mt-12 space-y-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm lg:p-8">
            <h2 class="text-2xl font-bold"><%= t('positions.faqs.form.header') %></h2>
            <p class="text-sm text-gray-700"><%= t('positions.faqs.form.description') %></p>
            <div id="faqs" class="space-y-5">
              <!-- Existing FAQ blocks -->
              <% @position.frequently_asked_questions.each_with_index do |faq, index| %>
                <div class="faq-item field bg-gray-50 p-4 rounded-lg">
                  <%= f.fields_for :frequently_asked_questions, faq do |faq_form| %>
                    <div class="space-y-4">
                      <label class="block text-sm font-medium text-gray-700"><%= t('positions.faqs.form.question_label') %></label>
                      <%= faq_form.text_field :question, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>

                      <label class="block text-sm font-medium text-gray-700"><%= t('positions.faqs.form.answer_label') %></label>
                      <%= faq_form.text_area :answer, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>

                      <%= faq_form.hidden_field :_destroy, value: false, class: "destroy-field" %>
                      <button type="button" class="remove-faq mt-2 inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                        Entfernen
                      </button>
                    </div>
                  <% end %>
                </div>
              <% end %>
              <!-- FAQ blocks will be added here dynamically -->
            </div>
            <button type="button" id="add_faq" class="mt-6 inline-flex items-center rounded-md border border-transparent px-5 py-3 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              FAQ hinzufügen
            </button>
          </div>

          <!-- Checkbox-Bereich -->
          <h2 class="text-2xl font-bold"><%= t('positions.new.confirmation.title') %></h2>
          <div class="bg-slate-100 rounded-xl p-8 space-y-6">
            <div class="space-y-6">
              <!-- Checkbox: Textbeschreibungen in englischer Sprache -->
              <div class="field space-y-3">
                <div class="border-2 border-gray-300 p-4 rounded-md">
                  <label class="inline-flex items-center">
                    <input type="checkbox" id="english-checkbox" class="form-checkbox h-5 w-5 text-blue-600">
                    <span class="ml-2 text-sm text-gray-700">
                      <%= t('positions.new.confirmation.text') %>
                    </span>
                  </label>
                </div>
              </div>

              <!-- Checkbox: Zustimmung zu AGB und Datenschutz -->
              <div class="field space-y-3">
                <div class="border-2 border-gray-300 p-4 rounded-md">
                  <label class="inline-flex items-center">
                    <input type="checkbox" id="terms-checkbox" class="form-checkbox h-5 w-5 text-blue-600">
                    <span class="ml-2 text-sm text-gray-700">
                      <%= raw t('positions.new.confirmation.terms') %>
                    </span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="mt-8 sm:mt-12 flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-6">
            <%= f.submit t('positions.new.button.create'), 
                id: "submit-button", 
                class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 bg-gray-400 text-white font-semibold text-base sm:text-lg rounded-xl shadow-lg cursor-not-allowed transform transition-all duration-200", 
                disabled: true %>
            
            <%= link_to t('common.cancel'), 
                positions_path, 
                class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 bg-gray-200 text-gray-800 font-semibold text-base sm:text-lg rounded-xl shadow-lg hover:bg-gray-300 transform transition-all duration-200 hover:scale-105 text-center" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
<script>
  function initPositionNewForm () {
    // Temporäre Position: Hinweistext anzeigen/verbergen
    const temporarySelect = document.getElementById("position_temporary_select");
    const infoText = document.getElementById("temporary-info-text");

    if (temporarySelect && infoText) {
      const toggleTemporaryInfo = () => {
        if (temporarySelect.value === "true") {
          infoText.classList.remove("hidden");
        } else {
          infoText.classList.add("hidden");
        }
      };

      temporarySelect.addEventListener("change", toggleTemporaryInfo);
      toggleTemporaryInfo();
    }

    // Character count validation
    function updateCharCount(fieldId, countId, minLength, maxLength, fieldName) {
      const field = document.querySelector(`[name="position[${fieldId}]"]`);
      const counter = document.getElementById(countId);
      
      if (!field || !counter) return;
      
      function update() {
        const length = field.value.length;
        const remaining = minLength - length;
        
        if (length === 0) {
          counter.innerHTML = `<span class="text-gray-500">Mindestens ${minLength} Zeichen erforderlich</span>`;
          counter.className = 'text-sm text-gray-500';
        } else if (length < minLength) {
          counter.innerHTML = `<span class="text-red-600">⚠️ Noch ${remaining} Zeichen benötigt (${length}/${minLength})</span>`;
          counter.className = 'text-sm text-red-600 font-medium';
        } else if (length > maxLength) {
          const excess = length - maxLength;
          counter.innerHTML = `<span class="text-red-600">⚠️ ${excess} Zeichen zu viel (${length}/${maxLength})</span>`;
          counter.className = 'text-sm text-red-600 font-medium';
        } else {
          counter.innerHTML = `<span class="text-green-600">✓ ${length} Zeichen (${minLength}-${maxLength})</span>`;
          counter.className = 'text-sm text-green-600 font-medium';
        }
      }
      
      field.addEventListener('input', update);
      update();
    }
    
    // Initialize character counters
    updateCharCount('title', 'word-count-title', 15, 75, 'Titel');
    updateCharCount('description', 'word-count-description', 100, 1000, 'Beschreibung');
    updateCharCount('benefits', 'word-count-benefits', 100, 1000, 'Vorteile');

    // Rating points logic
    const maxPoints = 15;
    const ratingInputs = document.querySelectorAll('.rating-input');
    const remainingPointsDisplay = document.getElementById('remaining-points');

    function updateRemainingPoints() {
      let totalPoints = 0;
      ratingInputs.forEach(input => {
        if (input.checked) {
          totalPoints += parseInt(input.value);
        }
      });

      const remainingPoints = maxPoints - totalPoints;
      // Richtiger Weg für Ruby-Übersetzungen in JavaScript
      remainingPointsDisplay.textContent = '<%= t("positions.new.remaining_points") %>'.replace('%{remaining_points}', remainingPoints);
      remainingPointsDisplay.style.color = remainingPoints < 0 ? 'red' : 'black';
    }

    if (ratingInputs.length > 0 && remainingPointsDisplay) {
      ratingInputs.forEach(input => {
        input.addEventListener('change', updateRemainingPoints);
      });

      updateRemainingPoints();
    }

    // Upload feedback logic
    function handleFileUpload(inputId, feedbackId) {
      const input = document.getElementById(inputId);
      const feedback = document.getElementById(feedbackId);

      if (input && feedback) {
        input.addEventListener("change", function () {
          if (input.files && input.files.length > 0) {
            // Richtiger Weg für Übersetzungen mit Variablen
            feedback.textContent = '<%= t("positions.new.upload_feedback.success") %>'.replace('%{file_name}', input.files[0].name);
            feedback.classList.remove("text-gray-500");
            feedback.classList.add("text-green-600");
          } else {
            feedback.textContent = '<%= t("positions.new.upload_feedback.default") %>';
            feedback.classList.remove("text-green-600");
            feedback.classList.add("text-gray-500");
          }
        });
      }
    }

    handleFileUpload("position_main_picture", "main_picture-feedback");
    handleFileUpload("position_picture1", "picture1-feedback");
    handleFileUpload("position_picture2", "picture2-feedback");
    handleFileUpload("position_picture3", "picture3-feedback");

    // FAQ Management - Robust approach
    const addFaqButton = document.getElementById("add_faq");
    const faqsContainer = document.getElementById("faqs");

    if (addFaqButton && faqsContainer) {
      if (faqsContainer.dataset.initialized === 'true') return;
      faqsContainer.dataset.initialized = 'true';
      let faqCounter = Date.now(); // Use timestamp to avoid conflicts

      function addFaqFields() {
        const newId = faqCounter++;
        const faqHtml = `
          <div class="faq-item field bg-gray-50 p-4 rounded-lg">
            <div class="space-y-4">
              <label class="block text-sm font-medium text-gray-700">Frage</label>
              <input type="text" name="position[frequently_asked_questions_attributes][${newId}][question]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">

              <label class="block text-sm font-medium text-gray-700">Antwort</label>
              <textarea name="position[frequently_asked_questions_attributes][${newId}][answer]" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"></textarea>

              <button type="button" class="remove-faq mt-2 inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                Entfernen
              </button>
            </div>
          </div>
        `;
        faqsContainer.insertAdjacentHTML('beforeend', faqHtml);
      }

      // Add new FAQ
      addFaqButton.addEventListener("click", function(e) {
        e.preventDefault();
        addFaqFields();
      });

      // Remove FAQ using event delegation
      faqsContainer.addEventListener("click", function(e) {
        const btn = e.target.closest('.remove-faq');
        if (!btn) return;
        e.preventDefault();
        const faqItem = btn.closest('.faq-item');
        if (faqItem) {
          const destroyField = faqItem.querySelector('.destroy-field');
          if (destroyField) {
            // Existing FAQ - mark for destruction
            destroyField.value = "1";
            faqItem.style.display = "none";
          } else {
            // New FAQ - remove completely
            faqItem.remove();
          }
        }
      });
    }

    // Checkbox logic for enabling the submit button
    const englishCheckbox = document.getElementById("english-checkbox");
    const termsCheckbox = document.getElementById("terms-checkbox");
    const submitButton = document.getElementById("submit-button");

    function updateSubmitButtonState() {
      if (englishCheckbox.checked && termsCheckbox.checked) {
        submitButton.disabled = false;
        submitButton.classList.remove("bg-gray-400", "cursor-not-allowed");
        submitButton.classList.add("bg-blue-600", "hover:bg-blue-700");
      } else {
        submitButton.disabled = true;
        submitButton.classList.remove("bg-blue-600", "hover:bg-blue-700");
        submitButton.classList.add("bg-gray-400", "cursor-not-allowed");
      }
    }

    if (englishCheckbox && termsCheckbox && submitButton) {
      // Initial update
      updateSubmitButtonState();
      
      // Add event listeners
      englishCheckbox.addEventListener("change", updateSubmitButtonState);
      termsCheckbox.addEventListener("change", updateSubmitButtonState);
    }
  }
  document.addEventListener('DOMContentLoaded', initPositionNewForm);
  document.addEventListener('turbolinks:load', initPositionNewForm);
  document.addEventListener('turbo:load', initPositionNewForm);
</script>