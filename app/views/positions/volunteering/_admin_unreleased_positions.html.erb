<div class="bg-yellow-600 p-4 rounded-md">
  <div class="text-xl"><%= t('positions.admin_unreleased_positions.header') %></div>
  <% @positions.where(released: false).each do |position| %>
    <div class="bg-white shadow-md rounded-lg p-6 my-6 border border-gray-200">
      <h2 class="text-2xl font-semibold mb-2"><%= position.title %></h2>
      <p class="text-gray-700 mb-4"><%= position.description %></p>
  <%= render partial: 'positions/volunteering/position_images', locals: { position: position } %>
      <div class="flex space-x-4 mt-5">
        <%= link_to t('positions.admin_unreleased_positions.view'), position_path(position), class: 'inline-block bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-700' %>
        <%= button_to t('positions.admin_unreleased_positions.release'), release_position_path(position), method: :patch, class: 'inline-block bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-700' %>
      </div>
    </div>
  <% end %>
</div>
