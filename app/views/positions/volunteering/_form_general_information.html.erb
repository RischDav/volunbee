<!-- General Information Section -->
<div class="space-y-10 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm lg:p-10">
  <h2 class="text-2xl font-bold"><%= t('positions.general_information.form.header') %></h2>
  
  <!-- Position Title -->
  <div class="field space-y-3">
    <%= f.label :title, t('positions.general_information.form.title_label'), class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('positions.general_information.form.title_description') %>
    <div id="word-count-title" class="text-sm text-gray-500"></div>
    <p class="text-sm text-gray-500 leading-relaxed"><%= t('positions.general_information.form.title_description') %></p>
  </div>

  <!-- Position Description -->
  <div class="field space-y-3 border-t border-gray-100 pt-6">
    <%= f.label :description, t('positions.general_information.form.description_label'), class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :description, rows: 5, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('positions.general_information.form.description_description') %>
    <div id="word-count-description" class="text-sm text-gray-500"></div>
    <p class="text-sm text-gray-500 leading-relaxed"><%= t('positions.general_information.form.description_description') %></p>
  </div>

  <!-- Benefits -->
  <div class="field space-y-3 border-t border-gray-100 pt-6">
    <%= f.label :benefits, t('positions.general_information.form.benefits_label'), class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :benefits, rows: 3, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t('positions.general_information.form.benefits_description') %>
    <div id="word-count-benefits" class="text-sm text-gray-500"></div>
    <p class="text-sm text-gray-500 leading-relaxed"><%= t('positions.general_information.form.benefits_description') %></p>
  </div>

  <!-- Weekly Time Commitment -->
  <div class="field space-y-3 border-t border-gray-100 pt-6">
    <%= f.label :weekly_time_commitment, t('positions.general_information.form.weekly_time_commitment_label'), class: "block text-sm font-medium text-gray-700" %>
    <%= f.number_field :weekly_time_commitment, class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", min: 1 %>
    <p class="text-sm text-gray-500 leading-relaxed"><%= t('positions.general_information.form.weekly_time_commitment_description') %></p>
  </div>

  <!-- Temporary Position -->
  <div class="field space-y-3 border-t border-gray-100 pt-6">
    <%= f.label :position_temporary, t('positions.general_information.form.position_temporary_label'), class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :position_temporary, [["Yes", true], ["No", false]], {}, { class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", id: "position_temporary_select" } %>
    <% temporary_visible = ActiveModel::Type::Boolean.new.cast(f.object&.position_temporary) %>
    <p id="temporary-info-text" class="text-sm text-red-400 leading-relaxed <%= 'hidden' unless temporary_visible %>"><%= t('positions.general_information.form.temporary_description') %></p>
  </div>

  <% if current_user&.university_staff? %>
  <div class="field space-y-3 border-t border-gray-100 pt-6">
      <%= f.label :visibility, t('positions.general_information.form.visibility_label', default: 'Position Visibility'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :visibility, [[t('positions.general_information.form.visibility_all', default: 'All students'), 'all'], [t('positions.general_information.form.visibility_university', default: 'Only students from my university'), 'university']], {}, { class: "mt-2 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", id: "position_visibility_select" } %>
      <p class="text-sm text-gray-500 leading-relaxed"><%= t('positions.general_information.form.visibility_description', default: 'Choose who can see this position.') %></p>
    </div>
  <% end %>
</div>
