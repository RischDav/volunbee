<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-indigo-50 py-6">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">
        <%= t('positions.show.title') %>
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-full"></div>
    </div>

    <!-- Main Content Card -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
      
      <!-- Hero Section -->
      <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-8 py-12 text-white">
        <div class="max-w-4xl">
          <!-- Position Type Badge -->
          <div class="mb-4">
            <% 
              type_config = case @position.type
              when 'volunteering'
                { label: '🤝 Ehrenamtliche Position', color: 'bg-green-500' }
              when 'freetime'
                { label: '🎯 Freizeitaktivität', color: 'bg-blue-500' }
              when 'university_position'
                { label: '🎓 Universitätsposition', color: 'bg-purple-500' }
              else
                { label: '📋 Position', color: 'bg-gray-500' }
              end
            %>
            <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold <%= type_config[:color] %> text-white shadow-lg">
              <%= type_config[:label] %>
            </span>
          </div>
          
          <h2 class="text-3xl sm:text-4xl font-bold mb-4 leading-tight">
            <%= @position.title.present? ? @position.title : t('positions.show.no_title') %>
          </h2>
          <% if @position.organization&.name || @position.university&.name %>
            <div class="flex items-center gap-2 text-blue-100">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2v8h12V6H4z" clip-rule="evenodd" />
              </svg>
              <span class="font-medium"><%= @position.organization&.name || @position.university&.name %></span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Content Sections -->
      <div class="p-8 space-y-12">
        
        <!-- General Information -->
        <div>
          <h3 class="text-2xl font-bold text-slate-800 mb-8 flex items-center gap-3">
            <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <%= t('positions.show.general_info') %>
          </h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Description -->
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-6 rounded-xl border border-blue-100">
              <div class="flex items-start gap-3 mb-4">
                <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h4 class="font-semibold text-slate-800"><%= t('positions.show.description') %></h4>
              </div>
              <p class="text-slate-600 leading-relaxed">
                <%= @position.description.present? ? simple_format(@position.description) : t('positions.show.not_available') %>
              </p>
            </div>

            <!-- Benefits -->
            <div class="bg-gradient-to-br from-emerald-50 to-green-50 p-6 rounded-xl border border-emerald-100">
              <div class="flex items-start gap-3 mb-4">
                <svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v6m0 6v6m11-7h-6m-6 0H1" />
                </svg>
                <h4 class="font-semibold text-slate-800"><%= t('positions.show.benefits') %></h4>
              </div>
              <p class="text-slate-600 leading-relaxed">
                <%= @position.benefits.present? ? simple_format(@position.benefits) : t('positions.show.not_available') %>
              </p>
            </div>

            <!-- Time Commitment - Hide for students if 0 hours -->
            <% unless current_user&.student? && @position.weekly_time_commitment == 0 %>
              <div class="bg-gradient-to-br from-purple-50 to-violet-50 p-6 rounded-xl border border-purple-100">
                <div class="flex items-center gap-3 mb-3">
                  <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                  </svg>
                  <h4 class="font-semibold text-slate-800"><%= t('positions.show.weekly_commitment') %></h4>
                </div>
                <p class="text-2xl font-bold text-purple-700">
                  <%= @position.weekly_time_commitment.present? ? "#{@position.weekly_time_commitment} Stunden" : t('positions.show.not_available') %>
                </p>
              </div>
            <% end %>

            <!-- Status Badges - Hide online and released for students -->
            <div class="space-y-4">
              <div class="flex flex-wrap gap-3">
                <div class="flex items-center gap-2 px-4 py-2 rounded-full <%= @position.position_temporary ? 'bg-orange-100 text-orange-800' : 'bg-slate-100 text-slate-600' %>">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                  </svg>
                  <span class="font-medium text-sm">
                    <%= t('positions.show.temporary') %>: <%= @position.position_temporary ? t('positions.show.yes') : t('positions.show.no') %>
                  </span>
                </div>

                <% unless current_user&.student? %>
                  <div class="flex items-center gap-2 px-4 py-2 rounded-full <%= @position.online ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                    </svg>
                    <span class="font-medium text-sm">
                      <%= t('positions.show.online') %>: <%= @position.online ? t('positions.show.yes') : t('positions.show.no') %>
                    </span>
                  </div>

                  <div class="flex items-center gap-2 px-4 py-2 rounded-full <%= @position.released ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd" />
                    </svg>
                    <span class="font-medium text-sm">
                      <%= t('positions.show.status') %>: <%= @position.released ? t('positions.show.released') : t('positions.show.not_released') %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Images Section - Only show if there are images -->
        <% has_images = @position.main_picture.attached? || @position.picture1.attached? || @position.picture2.attached? || @position.picture3.attached? %>
        <% if has_images %>
          <div>
            <h3 class="text-2xl font-bold text-slate-800 mb-8 flex items-center gap-3">
              <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                </svg>
              </div>
              <%= t('positions.show.images') %>
            </h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
              <% if @position.main_picture.attached? %>
                <div class="group">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-3 rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300">
                    <p class="text-slate-700 font-semibold mb-2 flex items-center gap-2">
                      <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 4a1 1 0 011-1h12a1 1 0 011 1v8a1 1 0 01-1 1H4a1 1 0 01-1-1V8z" clip-rule="evenodd" />
                      </svg>
                      <%= t('positions.show.main_picture') %>
                    </p>
                    <% begin %>
                      <%= image_tag @position.main_picture.variant(resize_to_limit: [300, 200]).processed, 
                            class: "rounded-lg shadow-md w-full max-h-32 object-contain group-hover:scale-105 transition-transform duration-300" %>
                    <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                      <div class="w-full h-24 bg-slate-200 rounded-lg flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
              
              <% if @position.picture1.attached? %>
                <div class="group">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-3 rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300">
                    <p class="text-slate-700 font-semibold mb-2 flex items-center gap-2">
                      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                      </svg>
                      <%= t('positions.show.picture_1') %>
                    </p>
                    <% begin %>
                      <%= image_tag @position.picture1.variant(resize_to_limit: [300, 200]).processed, 
                            class: "rounded-lg shadow-md w-full max-h-32 object-contain group-hover:scale-105 transition-transform duration-300" %>
                    <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                      <div class="w-full h-24 bg-slate-200 rounded-lg flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
              
              <% if @position.picture2.attached? %>
                <div class="group">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-3 rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300">
                    <p class="text-slate-700 font-semibold mb-2 flex items-center gap-2">
                      <svg class="w-4 h-4 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                      </svg>
                      <%= t('positions.show.picture_2') %>
                    </p>
                    <% begin %>
                      <%= image_tag @position.picture2.variant(resize_to_limit: [300, 200]).processed, 
                            class: "rounded-lg shadow-md w-full max-h-32 object-contain group-hover:scale-105 transition-transform duration-300" %>
                    <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                      <div class="w-full h-24 bg-slate-200 rounded-lg flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
              
              <% if @position.picture3.attached? %>
                <div class="group">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-3 rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300">
                    <p class="text-slate-700 font-semibold mb-2 flex items-center gap-2">
                      <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                      </svg>
                      <%= t('positions.show.picture_3') %>
                    </p>
                    <% begin %>
                      <%= image_tag @position.picture3.variant(resize_to_limit: [300, 200]).processed, 
                            class: "rounded-lg shadow-md w-full max-h-32 object-contain group-hover:scale-105 transition-transform duration-300" %>
                    <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                      <div class="w-full h-24 bg-slate-200 rounded-lg flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

        <!-- Skills Section -->
        <div>
          <h3 class="text-2xl font-bold text-slate-800 my-8 flex items-center gap-3">
            <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <%= t('positions.show.skills') %>
          </h3>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
            <!-- Creative Skills -->
            <div class="bg-gradient-to-br from-purple-50 to-pink-50 p-4 rounded-xl border border-purple-100 text-center">
              <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4 4 4 0 004-4V5z" />
                </svg>
              </div>
              <h4 class="font-semibold text-slate-800 text-sm mb-1"><%= t('positions.show.creative_skills') %></h4>
              <div class="text-2xl font-bold text-purple-600">
                <%= @position.creative_skills.present? ? @position.creative_skills : '—' %>
                <% if @position.creative_skills.present? %>
                  <span class="text-sm text-purple-400">/5</span>
                <% end %>
              </div>
            </div>

            <!-- Technical Skills -->
            <div class="bg-gradient-to-br from-blue-50 to-cyan-50 p-4 rounded-xl border border-blue-100 text-center">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                </svg>
              </div>
              <h4 class="font-semibold text-slate-800 text-sm mb-1"><%= t('positions.show.technical_skills') %></h4>
              <div class="text-2xl font-bold text-blue-600">
                <%= @position.technical_skills.present? ? @position.technical_skills : '—' %>
                <% if @position.technical_skills.present? %>
                  <span class="text-sm text-blue-400">/5</span>
                <% end %>
              </div>
            </div>

            <!-- Social Skills -->
            <div class="bg-gradient-to-br from-green-50 to-emerald-50 p-4 rounded-xl border border-green-100 text-center">
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
                </svg>
              </div>
              <h4 class="font-semibold text-slate-800 text-sm mb-1"><%= t('positions.show.social_skills') %></h4>
              <div class="text-2xl font-bold text-green-600">
                <%= @position.social_skills.present? ? @position.social_skills : '—' %>
                <% if @position.social_skills.present? %>
                  <span class="text-sm text-green-400">/5</span>
                <% end %>
              </div>
            </div>

            <!-- Language Skills -->
            <div class="bg-gradient-to-br from-yellow-50 to-orange-50 p-4 rounded-xl border border-yellow-100 text-center">
              <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                </svg>
              </div>
              <h4 class="font-semibold text-slate-800 text-sm mb-1"><%= t('positions.show.language_skills') %></h4>
              <div class="text-2xl font-bold text-yellow-600">
                <%= @position.language_skills.present? ? @position.language_skills : '—' %>
                <% if @position.language_skills.present? %>
                  <span class="text-sm text-yellow-400">/5</span>
                <% end %>
              </div>
            </div>

            <!-- Flexibility -->
            <div class="bg-gradient-to-br from-pink-50 to-rose-50 p-4 rounded-xl border border-pink-100 text-center">
              <div class="w-12 h-12 bg-pink-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </div>
              <h4 class="font-semibold text-slate-800 text-sm mb-1"><%= t('positions.show.flexibility') %></h4>
              <div class="text-2xl font-bold text-pink-600">
                <%= @position.flexibility.present? ? @position.flexibility : '—' %>
                <% if @position.flexibility.present? %>
                  <span class="text-sm text-pink-400">/5</span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

    <!-- Contact Information Section - Only show for organization positions -->
<% if @position.organization.present? %>
  <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 mt-8">
    <div class="p-8">
      <h3 class="text-2xl font-bold text-slate-800 mb-8 flex items-center gap-3">
        <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        Kontaktinformationen - <%= @position.organization.name %>
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Contact Person -->
        <% if @position.organization.contact_person.present? %>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-6 rounded-xl border border-blue-100">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <h4 class="font-semibold text-slate-800">Ansprechperson</h4>
            </div>
            <p class="text-slate-600 text-lg font-medium"><%= @position.organization.contact_person %></p>
          </div>
        <% end %>

        <!-- Email -->
        <% if @position.organization.email.present? %>
          <div class="bg-gradient-to-br from-emerald-50 to-green-50 p-6 rounded-xl border border-emerald-100">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <h4 class="font-semibold text-slate-800">E-Mail</h4>
            </div>
            <a href="mailto:<%= @position.organization.email %>" class="text-emerald-600 hover:text-emerald-800 font-medium">
              <%= @position.organization.email %>
            </a>
          </div>
        <% end %>

        <!-- Phone -->
        <% if @position.organization.contact_number.present? %>
          <div class="bg-gradient-to-br from-purple-50 to-violet-50 p-6 rounded-xl border border-purple-100">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.135a11.249 11.249 0 005.409 5.409l1.135-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <h4 class="font-semibold text-slate-800">Telefon</h4>
            </div>
            <a href="tel:<%= @position.organization.contact_number %>" class="text-purple-600 hover:text-purple-800 font-medium">
              <%= @position.organization.contact_number %>
            </a>
          </div>
        <% end %>

        <!-- Address -->
        <% if [@position.organization.street, @position.organization.housenumber, @position.organization.city, @position.organization.zip].any?(&:present?) %>
          <div class="bg-gradient-to-br from-orange-50 to-amber-50 p-6 rounded-xl border border-orange-100">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <h4 class="font-semibold text-slate-800">Adresse</h4>
            </div>
            <div class="text-slate-600 space-y-1">
              <% if @position.organization.street.present? && @position.organization.housenumber.present? %>
                <p><%= @position.organization.street %> <%= @position.organization.housenumber %></p>
              <% end %>
              <% if @position.organization.zip.present? && @position.organization.city.present? %>
                <p><%= @position.organization.zip %> <%= @position.organization.city %></p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Website -->
        <% if @position.organization.website.present? %>
          <div class="bg-gradient-to-br from-cyan-50 to-blue-50 p-6 rounded-xl border border-cyan-100">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9m0 9a9 9 0 01-9-9m9 9c0-2.5-4-5-9-5s-9 2.5-9 5m9 4a9 9 0 009-9m-9 9c2.5 0 5-4 5-9s-2.5-9-5-9" />
              </svg>
              <h4 class="font-semibold text-slate-800">Website</h4>
            </div>
            <a href="<%= @position.organization.website %>" target="_blank" class="text-cyan-600 hover:text-cyan-800 font-medium inline-flex items-center gap-1">
              <%= @position.organization.website %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        <% end %>

        <!-- Social Media -->
        <% if [@position.organization.instagram_url, @position.organization.linkedin_url, @position.organization.facebook_link].any?(&:present?) %>
          <div class="bg-gradient-to-br from-pink-50 to-rose-50 p-6 rounded-xl border border-pink-100 md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 4V2C7 1.44772 7.44772 1 8 1H16C16.5523 1 17 1.44772 17 2V4M7 4H4C2.89543 4 2 4.89543 2 6V18C2 19.1046 2.89543 20 4 20H20C21.1046 20 22 19.1046 22 18V6C22 4.89543 21.1046 4 20 4H17M7 4H17" />
              </svg>
              <h4 class="font-semibold text-slate-800">Social Media</h4>
            </div>
            <div class="flex flex-wrap gap-3">
              <% if @position.organization.instagram_url.present? %>
                <a href="<%= @position.organization.instagram_url %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-lg hover:from-purple-600 hover:to-pink-600 transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                  Instagram
                </a>
              <% end %>
              <% if @position.organization.linkedin_url.present? %>
                <a href="<%= @position.organization.linkedin_url %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              <% end %>
              <% if @position.organization.facebook_link.present? %>
                <a href="<%= @position.organization.facebook_link %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-800 text-white rounded-lg hover:bg-blue-900 transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                  Facebook
                </a>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>       

        <!-- FAQ Section -->
        <% if @position.frequently_asked_questions.any? %>
          <div>
            <h3 class="text-2xl font-bold text-slate-800 my-8 flex items-center gap-3">
              <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              Häufig gestellte Fragen
            </h3>
            
            <div class="space-y-6">
              <% @position.frequently_asked_questions.each_with_index do |faq, index| %>
                <div class="bg-gradient-to-br from-purple-50 to-violet-50 p-6 rounded-xl border border-purple-100">
                  <div class="flex items-start gap-3 mb-4">
                    <span class="bg-purple-100 text-purple-600 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">
                      <%= index + 1 %>
                    </span>
                    <h4 class="font-semibold text-slate-800 text-lg"><%= faq.question %></h4>
                  </div>
                  <div class="ml-11 text-slate-600 leading-relaxed"><%= simple_format(faq.answer) %></div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

    <!-- Back Button -->
    <div class="mt-8 flex justify-center">
      <%= link_to positions_path, class: "inline-flex items-center gap-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <%= t('positions.show.back') %>
      <% end %>
    </div>
    
  </div>
</div>
