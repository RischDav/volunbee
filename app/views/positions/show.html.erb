<h1 class="text-3xl my-4">Position Details</h1>
<div class="mt-8 p-6 bg-white rounded-lg shadow-md border border-slate-200">
    <h2 class="text-2xl font-semibold mb-4 text-center"><%= @position.title.present? ? @position.title : 'Titel nicht vorhanden' %></h2>
    
    <!-- General Information -->
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2">Allgemeine Informationen</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700 whitespace-normal"><strong>Beschreibung:</strong> <%= @position.description.present? ? @position.description : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700 whitespace-normal"><strong>Vorteile:</strong> <%= @position.benefits.present? ? @position.benefits : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Wöchentlicher Zeitaufwand:</strong> <%= @position.weekly_time_commitment.present? ? "#{@position.weekly_time_commitment} Stunden" : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Temporär:</strong> <%= @position.position_temporary ? 'Ja' : 'Nein' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Online:</strong> <%= @position.online ? 'Ja' : 'Nein' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Status:</strong> 
                    <span class="<%= @position.released ? 'text-green-500' : 'text-red-500' %>">
                        <%= @position.released ? 'Position ist freigegeben und sichtbar.' : 'Die Position wird demnächst freigegeben. Bis dahin ist sie nicht sichtbar.' %>
                    </span>
                </p>
            </div>
        </div>
    </div>

    <!-- Skills Section -->
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2">Erforderliche Fähigkeiten</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Kreative Fähigkeiten:</strong> <%= @position.creative_skills.present? ? @position.creative_skills : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Technische Fähigkeiten:</strong> <%= @position.technical_skills.present? ? @position.technical_skills : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Soziale Fähigkeiten:</strong> <%= @position.social_skills.present? ? @position.social_skills : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Sprachkenntnisse:</strong> <%= @position.language_skills.present? ? @position.language_skills : 'Nicht vorhanden' %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong>Flexibilität:</strong> <%= @position.flexibility.present? ? @position.flexibility : 'Nicht vorhanden' %></p>
            </div>
        </div>
    </div>

    <!-- Images Section -->
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2">Bilder</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% if @position.mainPicture.attached? %>
                <div class="bg-gray-100 p-4 rounded max-w-48">
                    <p class="text-gray-700 font-semibold">Titelbild:</p>
                    <%= image_tag @position.mainPicture, class: "rounded w-24" %>
                </div>
            <% end %>
            <% if @position.picture1.attached? %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold">Bild 1:</p>
                    <%= image_tag @position.picture1, class: "rounded shadow-md w-24" %>
                </div>
            <% end %>
            <% if @position.picture2.attached? %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold">Bild 2:</p>
                    <%= image_tag @position.picture2, class: "rounded shadow-md w-24" %>
                </div>
            <% end %>
            <% if @position.picture3.attached? %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold">Bild 3:</p>
                    <%= image_tag @position.picture3, class: "rounded shadow-md w-24" %>
                </div>
            <% end %>
        </div>
    </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-6 flex justify-end">
        <%= link_to 'Zurück', positions_path, class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
    </div>
</div>
