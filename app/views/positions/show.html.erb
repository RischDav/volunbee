<h1 class="text-3xl my-4"><%= t('positions.show.title') %></h1>
<div class="mt-8 p-6 bg-white rounded-lg shadow-md border border-slate-200">
    <h2 class="text-2xl font-semibold mb-4 text-center"><%= @position.title.present? ? @position.title : t('positions.show.no_title') %></h2>
    
    <!-- General Information -->
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2"><%= t('positions.show.general_info') %></h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700 whitespace-normal"><strong><%= t('positions.show.description') %>:</strong> <%= @position.description.present? ? @position.description : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700 whitespace-normal"><strong><%= t('positions.show.benefits') %>:</strong> <%= @position.benefits.present? ? @position.benefits : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.weekly_commitment') %>:</strong> <%= @position.weekly_time_commitment.present? ? "#{@position.weekly_time_commitment} Stunden" : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.temporary') %>:</strong> <%= @position.position_temporary ? t('positions.show.yes') : t('positions.show.no') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.online') %>:</strong> <%= @position.online ? t('positions.show.yes') : t('positions.show.no') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.status') %>:</strong> 
                    <span class="<%= @position.released ? 'text-green-500' : 'text-red-500' %>">
                        <%= @position.released ? t('positions.show.released') : t('positions.show.not_released') %>
                    </span>
                </p>
            </div>
        </div>
    </div>

    <!-- Skills Section -->
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2"><%= t('positions.show.skills') %></h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.creative_skills') %>:</strong> <%= @position.creative_skills.present? ? @position.creative_skills : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.technical_skills') %>:</strong> <%= @position.technical_skills.present? ? @position.technical_skills : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.social_skills') %>:</strong> <%= @position.social_skills.present? ? @position.social_skills : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.language_skills') %>:</strong> <%= @position.language_skills.present? ? @position.language_skills : t('positions.show.not_available') %></p>
            </div>
            <div class="bg-gray-100 p-4 rounded">
                <p class="text-gray-700"><strong><%= t('positions.show.flexibility') %>:</strong> <%= @position.flexibility.present? ? @position.flexibility : t('positions.show.not_available') %></p>
            </div>
        </div>
    </div>

    <!-- Images Section -->
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2"><%= t('positions.show.images') %></h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% if @position.mainPicture.attached? %>
                <div class="bg-gray-100 p-4 rounded max-w-48">
                    <p class="text-gray-700 font-semibold"><%= t('positions.show.main_picture') %>:</p>
                    <%= image_tag @position.mainPicture, class: "rounded w-24" %>
                </div>
            <% end %>
            <% if @position.picture1.attached? %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold"><%= t('positions.show.picture_1') %>:</p>
                    <%= image_tag @position.picture1, class: "rounded shadow-md w-24" %>
                </div>
            <% end %>
            <% if @position.picture2.attached? %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold"><%= t('positions.show.picture_2') %>:</p>
                    <%= image_tag @position.picture2, class: "rounded shadow-md w-24" %>
                </div>
            <% end %>
            <% if @position.picture3.attached? %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold"><%= t('positions.show.picture_3') %>:</p>
                    <%= image_tag @position.picture3, class: "rounded shadow-md w-24" %>
                </div>
            <% end %>
        </div>
    </div>

    <!-- FAQ Section -->
    <% if @position.faqs.any? %>
    <div class="mb-6">
        <h3 class="text-xl font-bold mb-2"><%= t('positions.show.faqs') %></h3>
        <div class="space-y-4">
            <% @position.faqs.each do |faq| %>
                <div class="bg-gray-100 p-4 rounded">
                    <p class="text-gray-700 font-semibold"><%= faq.question %></p>
                    <p class="text-gray-700 mt-2"><%= faq.answer %></p>
                </div>
            <% end %>
        </div>
    </div>
    <% end %>
</div>

<!-- Back Button -->
<div class="mt-6 flex justify-end">
    <%= link_to t('positions.show.back'), positions_path, class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
</div>
