<div class="bg-white shadow-md rounded-lg p-6 my-6 border border-gray-200">
  <% if position.released == false %>
    <span style="color: orange;"><%= t('position_card.not_released') %></span>
  <% end %>
  <h2 class="text-2xl font-semibold mb-2"><%= position.title %></h2>
  <p class="text-gray-700 mb-4 break-words whitespace-normal"><%= position.description %></p>
  <%= render partial: 'position_images', locals: { position: position } %>
  <%= render partial: 'position_actions', locals: { position: position } %>
</div>