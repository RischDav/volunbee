<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-indigo-50 py-8 flex flex-col justify-center sm:py-14">
  <div class="relative py-4 sm:max-w-xl md:max-w-2xl lg:max-w-4xl xl:max-w-6xl mx-auto">
    <div class="relative mx-4 rounded-3xl bg-white px-6 py-12 shadow-xl sm:mx-0 sm:px-12 sm:py-14 lg:px-16 border border-gray-100">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Neue Position erstellen</h1>
        <p class="text-lg text-gray-600 mb-8">Wähle zuerst den Typ deiner Position aus</p>
      </div>

      <!-- Type Selector -->
      <%= form_with url: new_position_path, method: :get, local: true, class: "text-center" do |f| %>
        <div class="max-w-2xl mx-auto bg-gradient-to-r from-indigo-50 to-blue-50 rounded-2xl p-8 border border-indigo-200">
          
          <!-- Type Selection -->
          <div class="mb-6">
            <label for="type" class="block text-xl font-semibold text-gray-900 mb-4">
              <%= t('positions.type_selector.label') %>
            </label>
            <p class="text-gray-600 mb-6">
              <%= t('positions.type_selector.help') %>
            </p>
            
            <%= f.select :type,
                options_for_select([
                  [t('positions.type_selector.options.volunteering'), 'volunteering'],
                  [t('positions.type_selector.options.freetime'), 'freetime'],
                  [t('positions.type_selector.options.university_position'), 'university_position']
                ], params[:type]),
                { prompt: t('positions.type_selector.prompt') },
                { 
                  class: "mx-auto block w-full max-w-md rounded-xl border border-gray-300 bg-white px-4 py-3 text-lg text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500",
                  required: true,
                  onchange: "this.form.submit();"
                } %>
          </div>
          
          <p class="text-sm text-gray-500 mt-4">
            Wähle einen Typ aus und du wirst automatisch zum entsprechenden Formular weitergeleitet.
          </p>
        </div>
      <% end %>


    </div>
  </div>
</div>

<style>
  .bg-gradient-to-br {
    background-image: linear-gradient(to bottom right, var(--tw-gradient-stops));
  }
  
  .bg-gradient-to-r {
    background-image: linear-gradient(to right, var(--tw-gradient-stops));
  }
  
  .transform {
    transform: var(--tw-transform);
  }
  
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .duration-200 {
    transition-duration: 200ms;
  }
  
  .hover\:scale-105:hover {
    --tw-scale-x: 1.05;
    --tw-scale-y: 1.05;
    transform: scale(var(--tw-scale-x), var(--tw-scale-y));
  }
</style>
