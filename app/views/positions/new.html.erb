<h1 class="text-3xl font-bold mb-6">Neue Position erstellen</h1>

<%= form_for @position, url: positions_path, html: { class: "space-y-4" } do |f| %>
  <div class="field">
    <%= f.label :title, "Titel", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="field">
    <%= f.label :description, "Beschreibung", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :description, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="field">
    <%= f.label :is_active, "Aktiv", class: "block text-sm font-medium text-gray-700" %>
    <%= f.check_box :is_active %>
  </div>

  <div class="field">
    <%= f.label :pictures, "Bilder", class: "block text-sm font-medium text-gray-700" %>
    <div id="drop-area" class="border-2 border-dashed border-gray-300 p-4 rounded-md">
      <p>Drag & Drop your files here or click to select files</p>
      <%= f.file_field :pictures, multiple: true, data: { direct_upload_url: rails_direct_uploads_url } %>
    </div>
  </div>

  <div class="actions">
    <%= f.submit "Erstellen", class: "w-full py-2 px-4 bg-blue-600 text-white font-medium text-sm rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
  </div>
<% end %>