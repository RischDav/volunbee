<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-indigo-50 py-8 flex flex-col justify-center sm:py-14">
  <div class="relative py-4 sm:max-w-xl md:max-w-2xl lg:max-w-4xl xl:max-w-6xl mx-auto">
    <div class="relative mx-4 rounded-3xl bg-white px-6 py-12 shadow-xl sm:mx-0 sm:px-12 sm:py-14 lg:px-16 border border-gray-100">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Neue Position erstellen</h1>
        <p class="text-lg text-gray-600 mb-8">Wähle zuerst den Typ deiner Position aus</p>
      </div>

      <!-- Type Selector -->
      <%= form_with url: new_position_path, method: :get, local: true, class: "text-center" do |f| %>
        <div class="max-w-2xl mx-auto bg-gradient-to-r from-indigo-50 to-blue-50 rounded-2xl p-8 border border-indigo-200">
          
          <!-- Type Selection -->
          <div class="mb-6">
            <label for="type" class="block text-xl font-semibold text-gray-900 mb-4">
              <%= t('positions.type_selector.label') %>
            </label>
            <p class="text-gray-600 mb-6">
              <%= t('positions.type_selector.help') %>
            </p>
            
            <%= f.select :type,
                options_for_select([
                  [t('positions.type_selector.options.volunteering'), 'volunteering'],
                  [t('positions.type_selector.options.freetime'), 'freetime'],
                  [t('positions.type_selector.options.university_position'), 'university_position']
                ], params[:type]),
                { prompt: t('positions.type_selector.prompt') },
                { 
                  class: "mx-auto block w-full max-w-md rounded-xl border border-gray-300 bg-white px-4 py-3 text-lg text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500",
                  required: true,
                  onchange: "this.form.submit();"
                } %>
          </div>
          
          <p class="text-sm text-gray-500 mt-4">
            Wähle einen Typ aus und du wirst automatisch zum entsprechenden Formular weitergeleitet.
          </p>
        </div>
      <% end %>

      <!-- Type-specific action cards (shown after selection) -->
      <% if params[:type].present? %>
        <div class="mt-12 max-w-4xl mx-auto">
          <% case params[:type] %>
          <% when 'volunteering' %>
            <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-8 border border-green-200 text-center">
              <div class="mb-6">
                <h2 class="text-3xl font-bold text-green-800 mb-4">🤝 Ehrenamtliche Position</h2>
                <p class="text-lg text-green-700 mb-8">Erstelle eine Position für Freiwilligenarbeit und gesellschaftliches Engagement</p>
              </div>
              <%= link_to "Ehrenamtliche Position erstellen", 
                  new_volunteering_position_path, 
                  class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-green-600 to-emerald-600 px-8 py-4 text-lg font-semibold text-white shadow-lg hover:from-green-700 hover:to-emerald-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transform transition-all duration-200 hover:scale-105" %>
            </div>
          
          <% when 'freetime' %>
            <div class="bg-gradient-to-r from-blue-50 to-sky-50 rounded-2xl p-8 border border-blue-200 text-center">
              <div class="mb-6">
                <h2 class="text-3xl font-bold text-blue-800 mb-4">🎯 Freizeitaktivität</h2>
                <p class="text-lg text-blue-700 mb-8">Organisiere spannende Freizeitaktivitäten für die Community</p>
              </div>
              <%= link_to "Freizeitaktivität erstellen", 
                  new_freetime_position_path, 
                  class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-blue-600 to-sky-600 px-8 py-4 text-lg font-semibold text-white shadow-lg hover:from-blue-700 hover:to-sky-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transform transition-all duration-200 hover:scale-105" %>
            </div>
          
          <% when 'university_position' %>
            <div class="bg-gradient-to-r from-purple-50 to-violet-50 rounded-2xl p-8 border border-purple-200 text-center">
              <div class="mb-6">
                <h2 class="text-3xl font-bold text-purple-800 mb-4">🎓 Universitätsposition</h2>
                <p class="text-lg text-purple-700 mb-8">Biete studentische Stellen und Universitätspositionen an</p>
              </div>
              <%= link_to "Universitätsposition erstellen", 
                  new_university_position_position_path, 
                  class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-purple-600 to-violet-600 px-8 py-4 text-lg font-semibold text-white shadow-lg hover:from-purple-700 hover:to-violet-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 transform transition-all duration-200 hover:scale-105" %>
            </div>
          <% end %>
          
          <!-- Back button -->
          <div class="text-center mt-8">
            <%= link_to "Anderer Typ wählen", 
                new_position_path, 
                class: "inline-flex items-center text-gray-600 hover:text-gray-800" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .bg-gradient-to-br {
    background-image: linear-gradient(to bottom right, var(--tw-gradient-stops));
  }
  
  .bg-gradient-to-r {
    background-image: linear-gradient(to right, var(--tw-gradient-stops));
  }
  
  .transform {
    transform: var(--tw-transform);
  }
  
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .duration-200 {
    transition-duration: 200ms;
  }
  
  .hover\:scale-105:hover {
    --tw-scale-x: 1.05;
    --tw-scale-y: 1.05;
    transform: scale(var(--tw-scale-x), var(--tw-scale-y));
  }
</style>
