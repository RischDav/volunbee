<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-sky-50 py-8 flex flex-col justify-center sm:py-14">
  <div class="relative py-4 sm:max-w-xl md:max-w-2xl lg:max-w-4xl xl:max-w-6xl mx-auto">
    <div class="relative mx-4 rounded-3xl bg-white px-6 py-12 shadow-xl sm:mx-0 sm:px-12 sm:py-14 lg:px-16 border border-gray-100">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-blue-800 mb-4">🎯 Freizeitaktivität erstellen</h1>
        <p class="text-lg text-blue-600">Organisiere spannende Freizeitaktivitäten für die Community</p>
      </div>

      <%= form_with(model: @position, url: positions_path, local: true, class: "space-y-12", multipart: true) do |f| %>
        
        <!-- Flash Alerts -->
        <% if flash[:alert] %>
          <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-red-500 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              <div>
                <h3 class="font-bold mb-2">Fehler beim Erstellen der Position:</h3>
                <div class="text-sm"><%= flash[:alert].html_safe %></div>
              </div>
            </div>
          </div>
        <% end %>

        <% if @position.errors.any? %>
          <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-red-500 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              <div>
                <h3 class="font-bold mb-2">Fehler beim Speichern (<%= pluralize(@position.errors.count, "Fehler") %>):</h3>
                <ul class="list-disc pl-5 text-sm space-y-1">
                  <% @position.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Set the type to freetime -->
        <%= f.hidden_field :type, value: 'freetime' %>

        <!-- Freetime Fields -->
        <%= render 'positions/fields/freetime_fields', f: f %>

        <!-- Submit Button -->
        <div class="mt-12 flex items-center justify-center gap-6">
          <%= f.submit "Freizeitaktivität erstellen", 
              id: "submit-button", 
              class: "px-8 py-4 bg-gray-400 text-white font-semibold text-lg rounded-xl shadow-lg cursor-not-allowed transform transition-all duration-200", 
              disabled: true %>
          
          <%= link_to "Abbrechen", 
              positions_path, 
              class: "px-8 py-4 bg-gray-200 text-gray-800 font-semibold text-lg rounded-xl shadow-lg hover:bg-gray-300 transform transition-all duration-200 hover:scale-105" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Character count validation
  function updateCharCount(fieldId, countId, minLength, fieldName) {
    const field = document.querySelector(`[name="position[${fieldId}]"]`);
    const counter = document.getElementById(countId);
    
    if (!field || !counter) return;
    
    function update() {
      const length = field.value.length;
      const remaining = minLength - length;
      
      if (length === 0) {
        counter.innerHTML = `<span class="text-gray-500">Mindestens ${minLength} Zeichen erforderlich</span>`;
        counter.className = 'text-sm text-gray-500';
      } else if (length < minLength) {
        counter.innerHTML = `<span class="text-red-600">⚠️ Noch ${remaining} Zeichen benötigt (${length}/${minLength})</span>`;
        counter.className = 'text-sm text-red-600 font-medium';
      } else {
        counter.innerHTML = `<span class="text-green-600">✓ ${length} Zeichen (${minLength} minimum)</span>`;
        counter.className = 'text-sm text-green-600 font-medium';
      }
    }
    
    field.addEventListener('input', update);
    update();
  }
  
  // Initialize character counters
  updateCharCount('title', 'word-count-title', 15, 'Titel');
  updateCharCount('description', 'word-count-description', 100, 'Beschreibung');
  updateCharCount('benefits', 'word-count-benefits', 100, 'Vorteile');
  
  // Submit button validation
  const termsCheckbox = document.getElementById('terms-checkbox-freetime');
  const submitButton = document.getElementById('submit-button');
  
  if (termsCheckbox && submitButton) {
    termsCheckbox.addEventListener('change', function() {
      if (this.checked) {
        submitButton.disabled = false;
        submitButton.classList.remove('bg-gray-400', 'cursor-not-allowed');
        submitButton.classList.add('bg-blue-600', 'hover:bg-blue-700', 'hover:scale-105');
      } else {
        submitButton.disabled = true;
        submitButton.classList.remove('bg-blue-600', 'hover:bg-blue-700', 'hover:scale-105');
        submitButton.classList.add('bg-gray-400', 'cursor-not-allowed');
      }
    });
  }
});
</script>