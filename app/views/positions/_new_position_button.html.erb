<% available_positions = 5 - @positions_count %>
<div class="text-center mb-16">
  <% if available_positions > 0 %>
    <%= link_to t('positions.new_position.create_button', available: available_positions), 
                new_position_path, 
                class: "inline-block rounded-full bg-green-500 px-12 py-5 text-white text-lg font-semibold shadow-lg transition duration-200 ease-in-out hover:bg-green-600 focus:outline-none focus:ring-4 focus:ring-green-300 sm:px-14", 
                role: 'button' %>
  <% else %>
    <span class="inline-block rounded-full bg-gray-300 px-12 py-5 text-gray-500 text-lg font-semibold shadow-lg sm:px-14">
      <%= t('positions.new_position.create_button_disabled') %>
    </span>
  <% end %>
</div>
