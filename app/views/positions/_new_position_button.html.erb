<% available_positions = 3 - @positions_count %>
<div class="text-center mb-12">
  <% if available_positions > 0 %>
    <%= link_to t('positions.new_position.create_button', available: available_positions), 
                new_position_path, 
                class: "inline-block rounded-full bg-green-500 px-8 py-3.5 text-white font-medium shadow-md transition duration-200 ease-in-out hover:bg-green-600", 
                role: 'button' %>
  <% else %>
    <span class="inline-block rounded-full bg-gray-300 px-8 py-3.5 text-gray-500 font-medium shadow-md">
      <%= t('positions.new_position.create_button_disabled') %>
    </span>
  <% end %>
</div>
