<!-- Images Section -->
<div class="space-y-4 mt-8">
  <h2 class="text-2xl font-bold"><%= t('positions.shared.images.title') %></h2>
  
  <!-- Main Picture -->
  <div class="field">
    <%= f.label :mainPicture, t('positions.shared.images.main_picture_label'), class: "block text-sm font-medium text-gray-700" %>
    <%= f.file_field :mainPicture, class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100", accept: 'image/*', id: "position_mainPicture" %>
    <p id="mainPicture-feedback" class="mt-2 text-sm text-gray-500"><%= t('positions.shared.images.upload_hint') %></p>
  </div>

  <!-- Additional Pictures -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="field">
      <%= f.label :picture1, t('positions.shared.images.additional_picture_label', number: 1), class: "block text-sm font-medium text-gray-700" %>
      <%= f.file_field :picture1, class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100", accept: 'image/*', id: "position_picture1" %>
      <p id="picture1-feedback" class="mt-2 text-sm text-gray-500"><%= t('positions.shared.images.upload_hint') %></p>
    </div>

    <div class="field">
      <%= f.label :picture2, t('positions.shared.images.additional_picture_label', number: 2), class: "block text-sm font-medium text-gray-700" %>
      <%= f.file_field :picture2, class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100", accept: 'image/*', id: "position_picture2" %>
      <p id="picture2-feedback" class="mt-2 text-sm text-gray-500"><%= t('positions.shared.images.upload_hint') %></p>
    </div>

    <div class="field">
      <%= f.label :picture3, t('positions.shared.images.additional_picture_label', number: 3), class: "block text-sm font-medium text-gray-700" %>
      <%= f.file_field :picture3, class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100", accept: 'image/*', id: "position_picture3" %>
      <p id="picture3-feedback" class="mt-2 text-sm text-gray-500"><%= t('positions.shared.images.upload_hint') %></p>
    </div>
  </div>
</div>
