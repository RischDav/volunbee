<h1 class="text-2xl font-bold mb-4">All Users</h1>

<table class="min-w-full bg-white border border-gray-200">
    <thead>
        <tr class="w-full bg-gray-100 border-b">
            <th class="py-2 px-4 text-left">Email</th>
            <th class="py-2 px-4 text-left">Role</th>
            <th class="py-2 px-4 text-left">Organization ID</th>
            <th class="py-2 px-4 text-left">Organization</th>
            <th class="py-2 px-4 text-left">Created At</th>
        </tr>
    </thead>
    <tbody>
        <% @users.each do |user| %>
            <tr class="border-b hover:bg-gray-50">
                <td class="py-2 px-4"><%= user.email %></td>
                <td class="py-2 px-4"><%= user.role %></td>
                <td class="py-2 px-4"><%= user.organization_id %></td>
                <td class="py-2 px-4"><%= user.organization ? user.organization.name : 'ADMIN' %></td>
                <td class="py-2 px-4"><%= user.created_at %></td>
            </tr>
        <% end %>
    </tbody>
</table>