<h1 class="text-2xl font-bold mb-4">Alle Benutzer</h1>

<% if current_user.admin? %>
    <% if @users.where(released: false).exists? %>
  <div class="bg-yellow-600 p-4 rounded-md">
      <div class="text-xl">Es gibt einige noch nicht freigegebene Benutzer!</div>
      <% @users.where(released: false).each do |user| %>
        <div class="mt-8 p-6 bg-white rounded-lg shadow-md border border-gray-200">
          <h2 class="text-2xl font-semibold mb-4"><%= user.email %></h2>
          <p class="text-gray-700 mb-2"><strong>Rolle:</strong> <%= user.role %></p>
          <p class="text-gray-700 mb-2"><strong>Organisation:</strong> <%= user.organization ? user.organization.name : 'ADMIN' %></p>
          <%= link_to 'Freigeben', release_user_admin_path(user), method: :patch, class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<table class="min-w-full bg-white border border-gray-200 mt-8">
  <thead>
    <tr class="w-full bg-gray-100 border-b">
      <th class="py-2 px-4 text-left">Email</th>
      <th class="py-2 px-4 text-left">Rolle</th>
      <th class="py-2 px-4 text-left">Organisation</th>
      <th class="py-2 px-4 text-left">Erstellt am</th>
      <th class="py-2 px-4 text-left">Aktionen</th>
    </tr>
  </thead>
  <tbody>
    <% @users.where(released: true).each do |user| %>
      <tr class="border-b hover:bg-gray-50">
        <td class="py-2 px-4"><%= user.email %></td>
        <td class="py-2 px-4"><%= user.role %></td>
        <td class="py-2 px-4"><%= user.organization ? user.organization.name : 'ADMIN' %></td>
        <td class="py-2 px-4"><%= user.created_at %></td>
        <td class="py-2 px-4">
        <% if !user.admin? %>
          <% if user.released%>
            <%= link_to 'Sperren', lock_user_admin_path(user), method: :patch, class: "px-4 py-2 bg-red-500 text-white rounded hover:bg-red-700" %>
          <% else %>
            <%= link_to 'Freigeben', release_user_admin_path(user), method: :patch, class: "px-4 py-2 bg-green-500 text-white rounded hover:bg-green-700" %>
          <% end %>
        <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>