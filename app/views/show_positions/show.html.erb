<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-emerald-50 py-4 sm:py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Card -->
    <div class="bg-white rounded-xl sm:rounded-2xl shadow-lg overflow-hidden mb-6">
      <!-- Hero Section -->
      <div class="relative">
        <% if @position.main_picture.attached? %>
          <% begin %>
            <div class="h-48 sm:h-64 lg:h-80 w-full overflow-hidden">
              <%= image_tag @position.main_picture.variant(resize_to_fill: [1200, 400]), 
                            class: "w-full h-full object-cover", 
                            alt: "Position main image" %>
            </div>
          <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
            <div class="h-48 sm:h-64 lg:h-80 w-full bg-gradient-to-r from-indigo-500 to-emerald-500 flex items-center justify-center">
              <div class="text-white text-center">
                <svg class="w-16 h-16 mx-auto mb-4 opacity-80" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                </svg>
                <p class="text-lg font-medium">Position Image</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="h-48 sm:h-64 lg:h-80 w-full bg-gradient-to-r from-indigo-500 to-emerald-500 flex items-center justify-center">
            <div class="text-white text-center">
              <svg class="w-16 h-16 mx-auto mb-4 opacity-80" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
              </svg>
              <p class="text-lg font-medium">Position Image</p>
            </div>
          </div>
        <% end %>
        
        <!-- Overlay with badges -->
        <div class="absolute top-4 left-4 flex flex-wrap gap-2">
          <% if @position.position_temporary %>
            <span class="bg-pink-500 text-white px-3 py-1 rounded-full text-xs font-semibold flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              Temporary
            </span>
          <% end %>
          <% if @position.weekly_time_commitment.present? %>
            <span class="bg-indigo-500 text-white px-3 py-1 rounded-full text-xs font-semibold flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              <%= pluralize(@position.weekly_time_commitment, "hr") %>/week
            </span>
          <% end %>
        </div>
      </div>

      <!-- Title and Organization -->
      <div class="p-6 sm:p-8">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
          <div class="flex-1">
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-3 leading-tight">
              <%= @position.title %>
            </h1>
            <% if @position.organization&.name || @position.university&.name %>
              <div class="flex items-center gap-2 text-gray-600 mb-4">
                <svg class="w-5 h-5 text-indigo-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2v8h12V6H4z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium"><%= @position.organization&.name || @position.university&.name %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <!-- Image Gallery -->
    <% images = [:main_picture, :picture1, :picture2, :picture3].map { |pic| @position.send(pic) if @position.send(pic).attached? }.compact %>
    <% if images.length > 1 %>
      <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
        <div class="p-4 sm:p-6 border-b border-gray-100">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
            </svg>
            Gallery
          </h2>
        </div>
        <div class="overflow-x-auto">
          <div class="flex gap-4 p-4 sm:p-6 min-w-max">
            <% images.each_with_index do |image, idx| %>
              <div class="flex-shrink-0 w-64 sm:w-80 h-40 sm:h-48 rounded-lg overflow-hidden shadow-md bg-white">
                <% begin %>
                  <%= image_tag(
                        rails_representation_url(image.variant(resize_to_fill: [400, 240]), only_path: true),
                        class: "object-cover w-full h-full hover:scale-105 transition-transform duration-300",
                        alt: "#{@position.title} image #{idx + 1}"
                      ) %>
                <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                  <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-400">
                    <div class="text-center">
                      <svg class="w-8 h-8 mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                      </svg>
                      <span class="text-sm">Image unavailable</span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main Content (Left Column) -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Description -->
        <% if @position.description.present? %>
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Description
            </h2>
            <div class="text-gray-700 leading-relaxed"><%= simple_format(@position.description) %></div>
          </div>
        <% end %>

        <!-- Benefits -->
        <% if @position.benefits.present? %>
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v6m0 6v6m11-7h-6m-6 0H1" />
              </svg>
              What You'll Gain
            </h2>
            <div class="text-gray-700 leading-relaxed"><%= simple_format(@position.benefits) %></div>
          </div>
        <% end %>

        <!-- Skills Required -->
        <% if @position.creative_skills.present? || @position.technical_skills.present? || @position.social_skills.present? || @position.language_skills.present? || @position.flexibility.present? %>
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
              Skills Required
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              <% if @position.creative_skills.present? %>
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-3 text-center">
                  <div class="text-purple-600 font-medium text-sm">Creative</div>
                  <div class="text-2xl font-bold text-purple-700"><%= @position.creative_skills %><span class="text-sm text-purple-500">/5</span></div>
                </div>
              <% end %>
              <% if @position.technical_skills.present? %>
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-center">
                  <div class="text-blue-600 font-medium text-sm">Technical</div>
                  <div class="text-2xl font-bold text-blue-700"><%= @position.technical_skills %><span class="text-sm text-blue-500">/5</span></div>
                </div>
              <% end %>
              <% if @position.social_skills.present? %>
                <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-center">
                  <div class="text-green-600 font-medium text-sm">Social</div>
                  <div class="text-2xl font-bold text-green-700"><%= @position.social_skills %><span class="text-sm text-green-500">/5</span></div>
                </div>
              <% end %>
              <% if @position.language_skills.present? %>
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3 text-center">
                  <div class="text-yellow-600 font-medium text-sm">Language</div>
                  <div class="text-2xl font-bold text-yellow-700"><%= @position.language_skills %><span class="text-sm text-yellow-500">/5</span></div>
                </div>
              <% end %>
              <% if @position.flexibility.present? %>
                <div class="bg-pink-50 border border-pink-200 rounded-lg p-3 text-center">
                  <div class="text-pink-600 font-medium text-sm">Flexibility</div>
                  <div class="text-2xl font-bold text-pink-700"><%= @position.flexibility %><span class="text-sm text-pink-500">/5</span></div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- FAQ -->
        <% if @position.frequently_asked_questions.any? %>
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Frequently Asked Questions
            </h2>
            <div class="space-y-4">
              <% @position.frequently_asked_questions.each_with_index do |faq, index| %>
                <div class="border border-gray-200 rounded-lg">
                  <div class="p-4">
                    <h3 class="font-semibold text-gray-900 flex items-start gap-2">
                      <span class="bg-indigo-100 text-indigo-600 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">
                        <%= index + 1 %>
                      </span>
                      <%= faq.question %>
                    </h3>
                    <div class="mt-2 ml-8 text-gray-700 leading-relaxed"><%= simple_format(faq.answer) %></div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <!-- Sidebar (Right Column) -->
      <div class="space-y-6">
        <!-- Organization Info -->
        <% if @position.organization.present? %>
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              Organization
            </h2>
            
            <!-- Organization Logo -->
            <% if @position.organization.logo&.attached? %>
              <div class="mb-4 flex justify-center">
                <% begin %>
                  <div class="w-16 h-16 rounded-lg overflow-hidden shadow border border-gray-200">
                    <%= image_tag @position.organization.logo.variant(resize_to_limit: [64, 64]).processed,
                          class: "w-full h-full object-contain",
                          alt: @position.organization.name %>
                  </div>
                <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                  <div class="w-16 h-16 rounded-lg bg-gray-100 flex items-center justify-center border border-gray-200">
                    <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2v8h12V6H4z" clip-rule="evenodd" />
                    </svg>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="text-center mb-4">
              <h3 class="text-lg font-semibold text-gray-900"><%= @position.organization.name %></h3>
              <% if @position.organization.description.present? %>
                <p class="text-gray-600 text-sm mt-2 leading-relaxed"><%= truncate(@position.organization.description, length: 120) %></p>
              <% end %>
            </div>

            <div class="space-y-3">
              <% if @position.organization.contact_person.present? %>
                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                  <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <div>
                    <div class="text-xs text-gray-500 uppercase tracking-wide">Contact Person</div>
                    <div class="text-sm font-medium text-gray-900"><%= @position.organization.contact_person %></div>
                  </div>
                </div>
              <% end %>
              
              <% if @position.organization.email.present? %>
                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                  <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <div>
                    <div class="text-xs text-gray-500 uppercase tracking-wide">Email</div>
                    <a href="mailto:<%= @position.organization.email %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 break-all">
                      <%= @position.organization.email %>
                    </a>
                  </div>
                </div>
              <% end %>
              
              <% if @position.organization.contact_number.present? %>
                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                  <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.135a11.249 11.249 0 005.409 5.409l1.135-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <div>
                    <div class="text-xs text-gray-500 uppercase tracking-wide">Phone</div>
                    <a href="tel:<%= @position.organization.contact_number %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">
                      <%= @position.organization.contact_number %>
                    </a>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- University Info (if applicable) -->
        <% if @position.university.present? %>
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              University
            </h2>
            
            <div class="text-center mb-4">
              <h3 class="text-lg font-semibold text-gray-900"><%= @position.university.name %></h3>
              <% if @position.university.description.present? %>
                <p class="text-gray-600 text-sm mt-2 leading-relaxed"><%= truncate(@position.university.description, length: 120) %></p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Quick Actions -->
        <div class="bg-white rounded-xl shadow-lg p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Quick Actions
          </h2>
          <div class="space-y-3">
            <% if @position.organization&.email.present? %>
              <a href="mailto:<%= @position.organization.email %>?subject=Interest in <%= @position.title %>" 
                 class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 px-4 rounded-lg transition-colors duration-200 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Apply Now
              </a>
            <% end %>
            
            <button onclick="window.print()" 
                    class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-3 px-4 rounded-lg transition-colors duration-200 flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
              </svg>
              Print Details
            </button>

            <button onclick="navigator.share ? navigator.share({title: '<%= @position.title %>', url: window.location.href}) : navigator.clipboard.writeText(window.location.href)" 
                    class="w-full bg-emerald-100 hover:bg-emerald-200 text-emerald-700 font-medium py-3 px-4 rounded-lg transition-colors duration-200 flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z" />
              </svg>
              Share Position
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Back Button -->
    <div class="mt-8 text-center">
      <%= link_to show_positions_path, class: "inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 font-medium py-3 px-6 rounded-lg shadow-lg transition-colors duration-200" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to all positions
      <% end %>
    </div>
  </div>
</div>
