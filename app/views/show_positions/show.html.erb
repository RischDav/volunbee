<div class="min-h-screen bg-gradient-to-br from-indigo-100 via-white to-emerald-100 py-10">
  <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden">
    <!-- Header: Organization & Project -->
    <div class="flex flex-col md:flex-row items-center md:items-start gap-8 p-8 border-b">
      <!-- Logo -->
      <div class="flex-shrink-0 flex flex-col items-center md:items-start">
        <% if @position.main_picture.attached? %>
          <% begin %>
            <% variant = @position.main_picture.variant(resize_to_fill: [112, 112]) %>
            <% if variant.processed? %>
              <%= image_tag rails_representation_url(variant, only_path: true), 
                          class: "w-28 h-28 object-contain rounded-xl shadow mb-2 bg-white", 
                          alt: "#{@position.organization&.name || 'Organization'} logo" %>
            <% else %>
              <%= image_tag rails_representation_url(@position.main_picture, only_path: true), 
                          class: "w-28 h-28 object-contain rounded-xl shadow mb-2 bg-white", 
                          alt: "#{@position.organization&.name || 'Organization'} logo" %>
            <% end %>
          <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
            <%= image_tag "pb-placeholder.png", 
                        class: "w-28 h-28 object-contain rounded-xl shadow mb-2 bg-white", 
                        alt: "Logo not available" %>
          <% end %>
        <% end %>
        <div class="text-sm text-gray-500 mt-2"><%= @position.organization&.name || @position.organization_name %></div>
      </div>
      <!-- Main Info -->
      <div class="flex-1">
        <div class="flex flex-wrap gap-2 mb-2">
          <% if @position.position_code.present? %>
            <span class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-xs font-semibold"><%= @position.position_code.to_s.humanize %></span>
          <% end %>
          <% if @position.position_temporary %>
            <span class="bg-pink-100 text-pink-800 px-3 py-1 rounded-full text-xs font-semibold">Temporary</span>
          <% end %>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-indigo-700 mb-2"><%= @position.title %></h1>
        <div class="text-gray-700 text-base mb-2"><%= @position.description %></div>
        <% if @position.weekly_time_commitment.present? %>
          <div class="text-xs text-gray-500 mb-1">⏱ <%= pluralize(@position.weekly_time_commitment, "hour") %>/week</div>
        <% end %>
      </div>
    </div>
    <!-- Images Gallery -->
    <div class="w-full overflow-x-auto bg-gray-50 border-b">
      <div class="flex gap-4 py-4 px-8">
        <% images = [:main_picture, :picture1, :picture2, :picture3].map { |pic| @position.send(pic) if @position.send(pic).attached? }.compact %>
        <% if images.any? %>
          <% images.each_with_index do |image, idx| %>
            <div class="flex-shrink-0 w-72 h-44 rounded-xl overflow-hidden shadow relative bg-white">
              <% begin %>
                <% variant = image.variant(resize_to_fill: [600, 250]) %>
                <% if variant.processed? %>
                  <%= image_tag rails_representation_url(variant, only_path: true), 
                              class: "object-cover w-full h-full", 
                              alt: "#{@position.title} image #{idx + 1}" %>
                <% else %>
                  <%= image_tag rails_representation_url(image, only_path: true), 
                              class: "object-cover w-full h-full", 
                              alt: "#{@position.title} image #{idx + 1}" %>
                <% end %>
              <% rescue ActiveStorage::IntegrityError, ActiveStorage::FileNotFoundError => e %>
                <%= image_tag "pb-placeholder.png", 
                            class: "object-cover w-full h-full", 
                            alt: "Image not available" %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="flex-shrink-0 w-72 h-44 rounded-xl overflow-hidden shadow bg-gray-200 flex items-center justify-center text-gray-400">
            <span>No images</span>
          </div>
        <% end %>
      </div>
    </div>
    <!-- Details Section -->
    <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Left: Tasks, Benefits, FAQ, Ratings, Tags -->
      <div class="space-y-6">
        <% if @position.description.present? %>
          <div>
            <div class="font-semibold text-indigo-700 mb-1 flex items-center gap-2">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-6h13v6M9 17H5a2 2 0 01-2-2V7a2 2 0 012-2h4m0 0V5a2 2 0 012-2h2a2 2 0 012 2v2"></path></svg>
              Tasks
            </div>
            <div class="text-gray-700 text-sm"><%= @position.description %></div>
          </div>
        <% end %>
        <% if @position.benefits.present? %>
          <div>
            <div class="font-semibold text-emerald-700 mb-1 flex items-center gap-2">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.343-3 3 0 1.657 1.343 3 3 3s3-1.343 3-3c0-1.657-1.343-3-3-3zm0 0V4m0 7v7"></path></svg>
              Benefits
            </div>
            <div class="text-emerald-700 text-sm"><%= @position.benefits %></div>
          </div>
        <% end %>
        <% if @position.frequently_asked_questions.any? %>
          <div>
            <div class="font-semibold text-indigo-700 mb-1 flex items-center gap-2">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 16v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2"></path></svg>
              FAQ
            </div>
            <ul class="text-gray-700 text-sm list-disc pl-5 space-y-2">
              <% @position.frequently_asked_questions.each do |faq| %>
                <li>
                  <span class="font-semibold"><%= faq.question %></span><br>
                  <span><%= faq.answer %></span>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <% if @position.creative_skills.present? || @position.technical_skills.present? || @position.social_skills.present? || @position.language_skills.present? || @position.flexibility.present? %>
          <div>
            <div class="font-semibold text-indigo-700 mb-1 flex items-center gap-2">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 15l4-4 4 4"/></svg>
              Skills Required
            </div>
            <div class="flex flex-wrap gap-2">
              <% if @position.creative_skills.present? %>
                <span class="bg-gray-100 text-gray-800 text-xs px-3 py-1 rounded-full shadow">Creative: <%= @position.creative_skills %>/5</span>
              <% end %>
              <% if @position.technical_skills.present? %>
                <span class="bg-gray-100 text-gray-800 text-xs px-3 py-1 rounded-full shadow">Technical: <%= @position.technical_skills %>/5</span>
              <% end %>
              <% if @position.social_skills.present? %>
                <span class="bg-gray-100 text-gray-800 text-xs px-3 py-1 rounded-full shadow">Social: <%= @position.social_skills %>/5</span>
              <% end %>
              <% if @position.language_skills.present? %>
                <span class="bg-gray-100 text-gray-800 text-xs px-3 py-1 rounded-full shadow">Language: <%= @position.language_skills %>/5</span>
              <% end %>
              <% if @position.flexibility.present? %>
                <span class="bg-gray-100 text-gray-800 text-xs px-3 py-1 rounded-full shadow">Flexibility: <%= @position.flexibility %>/5</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <!-- Right: Organization Info -->
      <div class="space-y-6">
        <% if @position.organization.present? %>
          <div>
            <div class="font-semibold text-indigo-700 mb-1 flex items-center gap-2">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              Organization
            </div>
            <div class="text-gray-700 text-sm">
              <h3 class="font-semibold"><%= @position.organization.name %></h3>
              <% if @position.organization.description.present? %>
                <p class="mt-1"><%= @position.organization.description %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    <div class="px-8 pb-8 flex justify-between items-center">
      <%= link_to "← Back to all positions", show_positions_path, class: "text-indigo-600 hover:underline font-semibold" %>
      <span class="text-xs text-gray-400">Volunbee</span>
    </div>
  </div>
</div>
