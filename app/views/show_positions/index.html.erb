<% cache [@positions.maximum(:updated_at)] do %>
  <div class="max-w-full mx-auto px-2 sm:px-4 lg:px-8 py-12">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 grid-cols-1">
      <% @positions.each_with_index do |position, pos_idx| %>
        <% cache [position, 'card'] do %>
          <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden w-full">
            <div class="relative h-64 w-full">
              <% images = [:main_picture, :picture1, :picture2, :picture3].map { |pic| position.send(pic) if position.send(pic).attached? }.compact %>
              <% if images.any? %>
                <div id="slider-<%= pos_idx %>" class="position-slider relative w-full h-full overflow-hidden">
                  <div class="slider-track flex w-full h-full transition-transform duration-700 ease-in-out" style="will-change: transform;">
                    <% images.each_with_index do |img, img_idx| %>
                      <div class="w-full h-full flex-shrink-0">
                        <%= image_tag(
                              rails_representation_url(img.variant(resize_to_fill: [600, 250]).processed, only_path: true),
                              class: "object-cover w-full h-full",
                              alt: "#{position.title} image #{img_idx + 1}"
                            ) %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <%= image_tag "placeholder.png", class: "object-cover w-full h-full", alt: "No image" %>
              <% end %>
            </div>
            <div class="p-8 space-y-3">
              <h2 class="text-xl font-semibold text-indigo-700"><%= position.title %></h2>
              <p class="text-gray-600 text-sm line-clamp-3"><%= truncate(position.description, length: 140) %></p>
              <% if position.benefits.present? %>
                <div class="text-sm text-emerald-600 font-medium">
                  🎁 <%= position.benefits %>
                </div>
              <% end %>
              <div class="mt-4 flex justify-between items-center">
                <span class="inline-flex items-center bg-indigo-100 text-indigo-800 text-xs font-semibold px-2.5 py-0.5 rounded">
                  <%= position.position_code.humanize %>
                </span>
                <% if position.weekly_time_commitment && position.weekly_time_commitment > 0 %>
                  <span class="text-xs text-gray-500">
                    ⏱ <%= pluralize(position.weekly_time_commitment, "hour") %>/week
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll('.position-slider').forEach(function(slider, sliderIdx) {
        const track = slider.querySelector('.slider-track');
        const slides = track.querySelectorAll('div.w-full.h-full.flex-shrink-0');
        if (slides.length < 2) return;
        let idx = 0;
        function slideTo(newIdx) {
          track.style.transform = `translateX(-${newIdx * 100}%)`;
        }
        function nextSlide() {
          idx = (idx + 1) % slides.length;
          slideTo(idx);
          setTimeout(nextSlide, 3000 + Math.random() * 2000); // 3-5 seconds
        }
        setTimeout(nextSlide, 3000 + Math.random() * 2000);
      });
    });
  </script>
  <style>
    .slider-track {
      width: 100%;
      height: 100%;
      display: flex;
      transition: transform 0.7s cubic-bezier(0.4,0,0.2,1);
    }
    .position-slider {
      overflow: hidden;
    }
    .position-slider .w-full.h-full.flex-shrink-0 {
      width: 100%;
      height: 100%;
      flex-shrink: 0;
    }
  </style>
<% end %>
