<% page_container = "mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" %>
<% box = "rounded-3xl border border-[#2a2b2e] p-5 sm:p-6 md:p-7" %>
<% inner_box = "rounded-2xl border border-[#2a2b2e] p-4 sm:p-5" %>
<% btn = "inline-flex w-full items-center justify-center rounded-full border border-[#2a2b2e] px-4 py-2.5 text-sm font-medium transition duration-300 hover:border-[#2A9D8F] hover:text-[#2A9D8F] sm:w-auto sm:px-5 sm:text-base" %>
<% text_main = "text-sm leading-relaxed sm:text-base" %>
<% title_main = "text-2xl font-semibold leading-tight sm:text-3xl" %>
<% title_sub = "text-lg font-semibold leading-tight sm:text-xl" %>

<div class="min-h-screen text-[#2a2b2e]">
  <!-- Consistent spacing between all sections -->
  <div class="space-y-4 sm:space-y-5 md:space-y-6 py-4 sm:py-5 md:py-6">

    <!-- SECTION 1: HERO -->
    <section>
      <div class="<%= page_container %>">
        <div class="grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 md:auto-rows-fr md:gap-6">
          <!-- Hero Text Group -->
          <article class="<%= box %> flex h-full flex-col justify-between">
            <div>
              <h1 class="<%= title_main %> mb-4">
                Together we are <span class="text-[#F2C94C]">Volunbee</span>.
              </h1>

              <p class="<%= text_main %> mb-5">
                With your help, we can achieve great things and make a real difference in people’s lives.
                Volunteering is not just about time — it is about creating positive change.
                Explore opportunities aligned with your interests and become part of a meaningful community.
              </p>
            </div>

            <div class="space-y-4 py-5 sm:py-6 md:py-7">
              <%= link_to "Volunteer Match in under 1 Minute", matching_path, class: btn %>

              <div class="flex flex-col gap-3 sm:flex-row">
                <%= link_to "Login for students", positions_path, class: btn %>
                <%= link_to "Signup", new_student_registration_path, class: btn %>
              </div>

              <div >
                <h2 class="<%= title_sub %> mb-3 text-[#F2C94C]">Our Project Partners</h2>

                <div class="flex flex-wrap justify-center gap-3 sm:gap-4">
                  <div class="h-15 sm:h-12">
                  <%= image_tag "fire_department_logo.jpg", class: "h-full w-auto object-contain", alt: "Fire department" %>
                  </div>
                  <div class="h-15 sm:h-12">
                  <%= image_tag "skjr_logo.png", class: "h-full w-auto object-contain", alt: "SKJR" %>
                  </div>
                  <div class="h-15 sm:h-12">
                  <%= image_tag "special_olympics_logo.png", class: "h-full w-auto object-contain", alt: "Special Olympics" %>
                  </div>
                  <div class="h-15 sm:h-12">
                  <%= image_tag "tedx_logo.png", class: "h-full w-auto object-contain", alt: "TEDx" %>
                  </div>
                  <div class="h-15 sm:h-12">
                  <%= image_tag "unicef_hg_logo.jpg", class: "h-full w-auto object-contain", alt: "UNICEF" %>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <!-- Hero Image Group -->
          <article class="overflow-hidden rounded-3xl border border-[#2a2b2e] h-72 sm:h-80 md:h-[36rem]">
            <%= image_tag "students_sitting_for_dinner.jpg",
              class: "block h-full w-full object-cover",
              alt: "Students volunteering together" %>
          </article>
        </div>
      </div>
    </section>

    <!-- SECTION 2: POSITIONS -->
    <section>
      <div class="<%= page_container %>">
        <div class="<%= box %>">
          <header class="mb-5 flex flex-col gap-3 sm:mb-6 md:flex-row md:items-end md:justify-between">
            <h2 class="<%= title_main %>">
              Latest <span class="text-[#F2C94C]">added</span>.
            </h2>

            <%= link_to "All positions", positions_path,
              class: "inline-flex w-fit items-center justify-center rounded-full border border-[#2a2b2e] px-4 py-2 text-sm font-medium transition duration-300 hover:border-[#2A9D8F] hover:text-[#2A9D8F] sm:text-base" %>
          </header>

          <div class="grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2 md:gap-5 lg:grid-cols-3">
            <% @positions.each do |position| %>
              <article class="<%= inner_box %> flex h-full flex-col justify-between">
                <div>
                  <h3 class="<%= title_sub %> mb-2"><%= position.title %></h3>
                  <p class="<%= text_main %> mb-4"><%= truncate(position.description, length: 120) %></p>
                </div>

                <div class="mt-auto">
                  <%= link_to "View details", positions_path,
                    class: "inline-flex w-fit items-center justify-center rounded-full border border-[#2a2b2e] px-4 py-2 text-sm font-medium transition duration-300 hover:border-[#2A9D8F] hover:text-[#2A9D8F] sm:text-base" %>
                </div>
              </article>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: ABOUT -->
    <section>
      <div class="<%= page_container %>">
        <div class="grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 md:auto-rows-fr md:gap-6">
          <!-- About Text Group -->
          <article class="<%= box %> flex h-full flex-col justify-between">
            <div>
              <h2 class="<%= title_main %> mb-4">
                About <span class="text-[#F2C94C]">Volunbee</span>.
              </h2>

              <p class="<%= text_main %> mb-5">
                We at TUM Campus Heilbronn are an international institution that brings students
                from all over the world to Heilbronn. We created this service to connect volunteer
                organizations with students, so they can share skills, support local initiatives,
                and become part of the community beyond the Bildungscampus.
              </p>
            </div>

            <%= link_to "https://chn.tum.de/campus/campus-heilbronn",
                class: "inline-flex w-fit items-center gap-1 rounded-full border border-[#2a2b2e] px-4 py-2 text-sm font-medium transition duration-300 hover:border-[#2A9D8F] hover:text-[#2A9D8F] sm:text-base",
                target: "_blank",
                rel: "noopener" do %>
              Learn more about TUM Campus Heilbronn
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#F2C94C] sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            <% end %>
          </article>

          <!-- About Image Group -->
          <article class="overflow-hidden rounded-3xl border border-[#2a2b2e] h-72 sm:h-80 md:h-[30rem]">
            <%= image_tag "campus_heilbronn.png",
              alt: "TUM Campus Heilbronn",
              class: "block h-full w-full object-cover" %>
          </article>
        </div>
      </div>
    </section>

  </div>
</div>