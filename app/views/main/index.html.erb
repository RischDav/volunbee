<div class="bg-[#F8F9FA]/80">
  <!-- First Section -->
  <div class="flex flex-col md:flex-row min-h-screen py-24">
    <!-- Left side content section -->
    <div class="flex-1 p-8 md:p-12 flex flex-col justify-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
      <span class="inline-block border-b-4 pb-1 text-[#264653]" style="border-color: #F2C94C;">Together.</span>
      </h1>
      
      <p class="text-base md:text-lg mb-8 max-w-xl leading-relaxed text-[#264653]">
        With your help, we can achieve great things and make a real difference in people's
        lives. Volunteering isn't just about time—it's about creating positive change. By
        joining our platform, you can explore a variety of volunteer opportunities tailored to
        your interests and skills. Whether you want to support local communities, assist
        those in need, or develop new skills, there's a place for you here.
      </p>
      
      <div class="mb-8 space-y-4">
        <!-- Wrap first two buttons in a flex container -->
        <div class="flex space-x-4">
          <%= link_to "Volunteer Match in under 1 Minute", matching_path, 
            class: "text-white py-3 px-6 rounded-full text-lg font-medium inline-block transition-colors cursor-pointer border 
                      bg-[#E76F51] text-white hover:bg-white border-[#E76F51] hover:text-[#E76F51]" %>

          <%= button_to "Find opportunities", positions_path, 
              method: :get,
              class: "py-3 px-6 rounded-full inline-block transition-colors cursor-pointer border 
                      border-[#E76F51] text-[#E76F51] hover:bg-[#E76F51] hover:text-white" %>  
        </div>
        
        <div class="mb-8 space-x-4">
          <div class="flex space-x-4">
            <%= button_to "For organisations", new_organization_registration_path, 
                method: :get,
                class: "py-3 px-6 rounded-full inline-block transition-colors cursor-pointer border 
                        bg-[#2A9D8F] text-white hover:bg-white hover:text-[#2A9D8F]" %>
            <%= button_to "For Students", new_student_registration_path, 
                method: :get,
                class: "py-3 px-6 rounded-full inline-block transition-colors cursor-pointer border 
                        border-[#2A9D8F] text-[#2A9D8F] hover:bg-white hover:[#2A9D8F]" %>
          </div>
        </div>
      </div>
      
      <div class="mt-8">
        <h2 class="text-xl font-bold mb-6 text-[#264653]">Our Project-partners:</h2>
        <div class="flex flex-wrap gap-6 items-center justify-start">
          <%= image_tag "fire_department_logo.jpg", class: "h-16 w-auto object-contain hover:opacity-80 transition-opacity duration-300", alt: "Partner 1" %>
          <%= image_tag "skjr_logo.png", class: "h-16 w-auto object-contain hover:opacity-80 transition-opacity duration-300", alt: "Partner 2" %>
          <%= image_tag "special_olympics_logo.png", class: "h-16 w-auto object-contain hover:opacity-80 transition-opacity duration-300", alt: "Partner 3" %>
          <%= image_tag "tedx_logo.png", class: "h-16 w-auto object-contain hover:opacity-80 transition-opacity duration-300", alt: "Partner 4" %>
          <%= image_tag "unicef_hg_logo.jpg", class: "h-16 w-auto object-contain hover:opacity-80 transition-opacity duration-300", alt: "Partner 5" %>
        </div>
      </div>
    </div>

    <!-- Right side image section -->
    <div class="flex-1 bg-cover rounded bg-center h-80 md:h-auto" style="background-image: url('<%= asset_path("students_sitting_for_dinner.jpg") %>');"></div>
  </div>
  <!-- Positions Section -->
  <div class="bg-[#2A9D8F]">
    <div class="container mx-auto px-4 py-24">
      <div class="flex flex-col md:flex-row md:items-center md:space-x-12">
        <div class="md:w-1/2 mb-8 md:mb-0">
          <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">
            Latest <span class="text-[#F2C94C]">Added</span>.
          </h1>
        </div>
        <div class="container mx-auto px-4 py-8">
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% @positions.each do |position| %>
              <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-shadow">
                <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= position.title %></h3>
                <p class="text-gray-700 mb-4"><%= truncate(position.description, length: 120) %></p>
                <%= link_to "View Details", positions_path, 
                  class: "inline-block bg-[#E76F51] text-white px-4 py-2 rounded-full text-sm hover:opacity-90 transition" %>
              </div>
            <% end %>
          </div>
        </div>  
      </div>        
    </div>
  </div>
  <!-- About This Project Section -->
  <div class="container mx-auto px-4 py-24">
    <div class="flex flex-col md:flex-row md:items-center md:space-x-12">
      <!-- About this project section -->
      <div class="md:w-1/2 mb-8 md:mb-0">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-[#264653]" style="text-decoration: none !important; border: none;">
          About <span style="color: #F2C94C !important; text-decoration: none !important;">Volunbee</span>.
        </h1>
        
        <p class="text-gray-700 text-lg mb-8 text-[#264653]">
          We at TUM Campus Heilbronn are an international institution
          that brings students from all over the world to Heilbronn. That's
          why we created a service that connects volunteer organizations
          with students. This allows students to share their skills,
          knowledge, and perspectives from different countries, while
          also giving them the chance to become part of the community
          and get to know the region and its people beyond the
          Bildungscampus.
        </p>
        
        <%= link_to "https://chn.tum.de/campus/campus-heilbronn", 
            style: "color: #F2C94C !important; text-decoration: none !important; display: inline-flex; align-items: center; font-weight: 500; transition: color 0.3s ease;", 
            target: "_blank", 
            rel: "noopener",
            onmouseover: "this.style.color='#ea580c'",
            onmouseout: "this.style.color='#f0b442'" do %>
          Learn more about the TUM Campus Heilbronn
          <svg xmlns="http://www.w3.org/2000/svg" style="height: 1.25rem; width: 1.25rem; margin-left: 0.25rem;" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        <% end %>
      </div>
      
      <!-- Campus image -->
      <div class="md:w-1/2 flex justify-center items-center">
        <img src="<%= asset_path('campus_heilbronn.png') %>" alt="TUM Campus Heilbronn" class="rounded-lg shadow-lg w-full md:w-[110%]">
      </div>    
    </div>
  </div>
</div>