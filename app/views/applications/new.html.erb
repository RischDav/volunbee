<% 
  # Set up variables based on position type
  case @position.type
  when 'volunteering'
    page_title = t('applications.volunteer.title', default: 'Apply as Volunteer')
    icon = '🤝'
    heading = t('applications.volunteer.heading', default: 'Volunteer Application')
    subheading = t('applications.volunteer.subheading', default: 'Join us and make a difference')
    submit_text = t('applications.volunteer.submit', default: 'Submit Application')
  when 'freetime'
    page_title = t('applications.freetime.title', default: 'Register for Activity')
    icon = '🎯'
    heading = t('applications.freetime.heading', default: 'Activity Registration')
    subheading = t('applications.freetime.subheading', default: 'Register and have fun with others')
    submit_text = t('applications.freetime.submit', default: 'Submit Registration')
  when 'university_position'
    page_title = t('applications.assistant.title', default: 'Apply as Assistant')
    icon = '🎓'
    heading = t('applications.assistant.heading', default: 'Assistant Application')
    subheading = t('applications.assistant.subheading', default: 'Start your career as a university assistant')
    submit_text = t('applications.assistant.submit', default: 'Submit Application')
  end
%>

<% content_for :title do %>
  <%= page_title %> - <%= @position.title %>
<% end %>

<div class="min-h-screen bg-gray-50 py-8">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Back Button -->
    <div class="mb-6">
      <%= link_to position_path(@position), 
          class: "inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        <%= t('common.back_to_position') %>
      <% end %>
    </div>

    <!-- Header Section -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-8">
      <div class="bg-gray-900 px-6 py-8 text-center">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-white mb-2">
          <%= icon %> <%= heading %>
        </h1>
        <p class="text-gray-300 text-lg">
          <%= subheading %>
        </p>
        <div class="mt-4 p-3 bg-white rounded-lg inline-block shadow-sm">
          <p class="text-gray-900 font-semibold"><%= @position.title %></p>
          <% if @position.organization %>
            <p class="text-gray-600 text-sm"><%= @position.organization.name %></p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Application Form -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 lg:p-8">
      <%= form_with model: @application_object, 
          url: position_applications_path(@position),
          local: true, 
          multipart: true, 
          class: "space-y-6" do |form| %>
        
        <!-- Error Messages -->
        <% if @application_object.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  <%= t('forms.errors.header', default: 'Please correct the following errors:') %>
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc list-inside space-y-1">
                    <% @application_object.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Render Appropriate Form Partial -->
        <% case @position.type %>
        <% when 'volunteering' %>
          <%= render 'positions/shared/volunteer_form', form: form %>
        <% when 'freetime' %>
          <%= render 'positions/shared/freetime_form', form: form %>
        <% when 'university_position' %>
          <%= render 'positions/shared/assistant_form', form: form %>
        <% end %>

        <!-- Submit Button -->
        <div class="pt-6 border-t border-gray-200">
          <div class="flex justify-between items-center">
            <!-- Back Button -->
            <%= link_to t('applications.forms.buttons.back_to_position'), position_path(@position), 
                class: "inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-50 transition-all duration-200" %>
            
            <!-- Submit Button -->
            <%= form.submit submit_text, 
                class: "bg-gray-900 text-white font-semibold py-3 px-8 rounded-xl border border-gray-900 shadow-sm hover:bg-gray-800 transition-all duration-200" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>