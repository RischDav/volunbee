<% 
  # Set up variables based on application type
  case @application_type
  when 'volunteer_application'
    page_title = t('applications.volunteer.success_title', default: 'Volunteer Application Submitted')
    gradient_from = 'from-green-50'
    gradient_to = 'to-emerald-100'
    header_gradient = 'from-green-600 to-emerald-600'
    text_color = 'text-green-600'
    icon = '✅'
    heading = t('applications.volunteer.success_heading', default: 'Volunteer Application Submitted Successfully!')
    subheading = t('applications.volunteer.success_subheading', default: 'Thank you for your interest in volunteering')
    application_type_text = t('applications.volunteer.type', default: 'Volunteer Application')
  when 'freetime_registration'
    page_title = t('applications.freetime.success_title', default: 'Activity Registration Submitted')
    gradient_from = 'from-blue-50'
    gradient_to = 'to-indigo-100'
    header_gradient = 'from-blue-600 to-indigo-600'
    text_color = 'text-blue-600'
    icon = '✅'
    heading = t('applications.freetime.success_heading', default: 'Activity Registration Submitted Successfully!')
    subheading = t('applications.freetime.success_subheading', default: 'Thank you for registering for this activity')
    application_type_text = t('applications.freetime.type', default: 'Activity Registration')
  when 'assistant_application'
    page_title = t('applications.assistant.success_title', default: 'Assistant Application Submitted')
    gradient_from = 'from-purple-50'
    gradient_to = 'to-violet-100'
    header_gradient = 'from-purple-600 to-violet-600'
    text_color = 'text-purple-600'
    icon = '✅'
    heading = t('applications.assistant.success_heading', default: 'Assistant Application Submitted Successfully!')
    subheading = t('applications.assistant.success_subheading', default: 'Thank you for your interest in this position')
    application_type_text = t('applications.assistant.type', default: 'Assistant Application')
  else
    page_title = 'Application Submitted'
    gradient_from = 'from-gray-50'
    gradient_to = 'to-slate-100'
    header_gradient = 'from-gray-600 to-slate-600'
    text_color = 'text-gray-600'
    icon = '✅'
    heading = 'Application Submitted Successfully!'
    subheading = 'Thank you for your application'
    application_type_text = 'Application'
  end
%>

<% content_for :title, page_title %>

<div class="min-h-screen bg-gradient-to-br <%= gradient_from %> <%= gradient_to %>">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <div class="bg-gradient-to-r <%= header_gradient %> text-white rounded-2xl shadow-xl p-8 mb-8">
        <div class="text-6xl mb-4"><%= icon %></div>
        <h1 class="text-4xl font-bold mb-2"><%= heading %></h1>
        <p class="text-xl opacity-90"><%= subheading %></p>
      </div>
    </div>

    <!-- Success Message -->
    <div class="max-w-4xl mx-auto">
      <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
        
        <!-- Application Status -->
        <div class="bg-gradient-to-r from-green-500 to-emerald-500 text-white p-6">
          <div class="flex items-center">
            <div class="text-3xl mr-4">📧</div>
            <div>
              <h2 class="text-2xl font-bold">Application Confirmed</h2>
              <p class="text-green-100">A confirmation email has been sent to your email address</p>
            </div>
          </div>
        </div>

        <!-- Position Information -->
        <div class="p-8">
          <div class="grid md:grid-cols-2 gap-8">
            
            <!-- Position Details -->
            <div class="space-y-6">
              <div>
                <h3 class="text-2xl font-bold <%= text_color %> mb-4 flex items-center">
                  <span class="text-2xl mr-3">📍</span>
                  Position Details
                </h3>
                <div class="bg-gray-50 rounded-xl p-6 space-y-4">
                  <div>
                    <span class="font-semibold text-gray-700">Title:</span>
                    <p class="text-gray-900 mt-1"><%= @application_object.position.title %></p>
                  </div>
                  <div>
                    <span class="font-semibold text-gray-700">Type:</span>
                    <p class="text-gray-900 mt-1"><%= application_type_text %></p>
                  </div>
                  <% if @application_object.position.weekly_time_commitment.present? %>
                    <div>
                      <span class="font-semibold text-gray-700">Time Commitment:</span>
                      <p class="text-gray-900 mt-1"><%= @application_object.position.weekly_time_commitment %> hours/week</p>
                    </div>
                  <% end %>
                  <% if @application_object.position.appointment.present? %>
                    <div>
                      <span class="font-semibold text-gray-700">Schedule:</span>
                      <p class="text-gray-900 mt-1"><%= @application_object.position.appointment %></p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Application Summary -->
            <div class="space-y-6">
              <div>
                <h3 class="text-2xl font-bold <%= text_color %> mb-4 flex items-center">
                  <span class="text-2xl mr-3">👤</span>
                  Your Application
                </h3>
                <div class="bg-gray-50 rounded-xl p-6 space-y-4">
                  <div>
                    <span class="font-semibold text-gray-700">Name:</span>
                    <p class="text-gray-900 mt-1"><%= @application_object.first_name %> <%= @application_object.last_name %></p>
                  </div>
                  <div>
                    <span class="font-semibold text-gray-700">Email:</span>
                    <p class="text-gray-900 mt-1"><%= @application_object.email %></p>
                  </div>
                  <div>
                    <span class="font-semibold text-gray-700">Phone:</span>
                    <p class="text-gray-900 mt-1"><%= @application_object.phone_number %></p>
                  </div>
                  <div>
                    <span class="font-semibold text-gray-700">Submitted:</span>
                    <p class="text-gray-900 mt-1"><%= @application_object.created_at.strftime('%B %d, %Y at %I:%M %p') %></p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Next Steps -->
          <div class="mt-8">
            <h3 class="text-2xl font-bold <%= text_color %> mb-4 flex items-center">
              <span class="text-2xl mr-3">🚀</span>
              What Happens Next?
            </h3>
            <div class="bg-blue-50 border-l-4 border-blue-400 p-6 rounded-r-xl">
              <div class="grid md:grid-cols-3 gap-6">
                <div class="text-center">
                  <div class="text-3xl mb-2">📧</div>
                  <h4 class="font-semibold text-blue-800">Email Confirmation</h4>
                  <p class="text-blue-600 text-sm mt-1">Check your email for confirmation details</p>
                </div>
                <div class="text-center">
                  <div class="text-3xl mb-2">📋</div>
                  <h4 class="font-semibold text-blue-800">Review Process</h4>
                  <p class="text-blue-600 text-sm mt-1">We'll review your application within 3-5 business days</p>
                </div>
                <div class="text-center">
                  <div class="text-3xl mb-2">📞</div>
                  <h4 class="font-semibold text-blue-800">Contact</h4>
                  <p class="text-blue-600 text-sm mt-1">We'll contact you with the next steps</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Important Notes -->
          <div class="mt-8 bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-r-xl">
            <div class="flex items-start">
              <div class="text-2xl mr-3">💡</div>
              <div>
                <h4 class="font-semibold text-yellow-800 mb-2">Important Notes:</h4>
                <ul class="text-yellow-700 text-sm space-y-1">
                  <li>• Please save this confirmation page for your records</li>
                  <li>• Check your email (including spam folder) for additional information</li>
                  <li>• If you don't hear from us within a week, please contact us</li>
                  <li>• You can contact us if you need to update any information</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="mt-8 flex flex-wrap gap-4 justify-center">
            <%= link_to position_path(@application_object.position), 
                class: "inline-flex items-center px-6 py-3 bg-gradient-to-r #{header_gradient} text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200" do %>
              <span class="mr-2">👀</span>
              View Position Again
            <% end %>
            
            <%= link_to positions_path, 
                class: "inline-flex items-center px-6 py-3 bg-gray-600 hover:bg-gray-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200" do %>
              <span class="mr-2">🔍</span>
              Browse More Positions
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>