<div class="min-h-screen bg-gradient-to-br from-purple-50 via-white to-pink-50 py-4 sm:py-8">
  <div class="max-w-2xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <div class="flex items-center gap-3 mb-4">
        <%= link_to @event, class: "text-purple-600 hover:text-purple-700 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        <% end %>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-purple-800">
          🎉 Event-Registrierung
        </h1>
      </div>
      <p class="text-sm sm:text-base text-purple-600">
        Anmeldung für: <strong><%= @event.title %></strong>
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-purple-500 to-pink-600 rounded-full mt-2"></div>
    </div>

    <!-- Registration Form -->
    <div class="bg-white rounded-xl shadow-xl border border-purple-100 overflow-hidden">
      <%= form_with model: @registration, url: event_event_registrations_path(@event), local: true, class: "p-6 sm:p-8" do |form| %>
        
        <!-- Error Messages -->
        <% if @registration.errors.any? %>
          <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
            <h3 class="font-bold mb-2">Bitte korrigiere folgende Fehler:</h3>
            <ul class="list-disc pl-5 text-sm space-y-1">
              <% @registration.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Form Fields -->
        <div class="space-y-6">
          <div>
            <%= form.label :first_name, "Vorname *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :first_name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "Max", required: true %>
          </div>

          <div>
            <%= form.label :last_name, "Nachname *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :last_name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "Mustermann", required: true %>
          </div>

          <div>
            <%= form.label :age, "Alter *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.number_field :age, min: 1, max: 120, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "z.B. 25", required: true %>
          </div>

          <!-- Hidden fields: E-Mail wird aus current_user übernommen -->
          <div class="bg-gray-50 p-4 rounded-lg text-sm text-gray-600">
            <p>Deine E-Mail-Adresse (<%= current_user.email %>) wird automatisch aus deinem Account übernommen.</p>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row justify-end gap-4 pt-8">
          <%= link_to "Abbrechen", @event, class: "text-center px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition" %>
          <%= form.submit "Jetzt anmelden", class: "px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition shadow-md" %>
        </div>
      <% end %>
    </div>
  </div>
</div>