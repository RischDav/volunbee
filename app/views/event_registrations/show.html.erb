<div class="min-h-screen bg-gradient-to-br from-purple-50 via-white to-pink-50 py-4 sm:py-8">
  <div class="max-w-2xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8">
    
    <div class="mb-6 sm:mb-8">
      <div class="flex items-center gap-3 mb-4">
        <%= link_to @registration.event, class: "text-purple-600 hover:text-purple-700 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        <% end %>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-purple-800">
          Anmeldebestätigung
        </h1>
      </div>
      <div class="w-20 h-1 bg-gradient-to-r from-purple-500 to-pink-600 rounded-full mt-2"></div>
    </div>

    <div class="bg-white rounded-xl shadow-xl border border-purple-100 overflow-hidden p-6 sm:p-8">
      <div class="text-center mb-6">
        <div class="text-6xl mb-4">✅</div>
        <h2 class="text-2xl font-bold text-gray-800">Du bist angemeldet!</h2>
        <p class="text-gray-600 mt-2">Vielen Dank für deine Anmeldung.</p>
      </div>

      <div class="border-t border-gray-200 pt-6 space-y-4">
        <div class="flex justify-between">
          <span class="font-medium text-gray-700">Event:</span>
          <span class="text-gray-900"><%= @registration.event.title %></span>
        </div>
        <div class="flex justify-between">
          <span class="font-medium text-gray-700">Name:</span>
          <span class="text-gray-900"><%= @registration.first_name %> <%= @registration.last_name %></span>
        </div>
        <div class="flex justify-between">
          <span class="font-medium text-gray-700">Alter:</span>
          <span class="text-gray-900"><%= @registration.age %></span>
        </div>
        <div class="flex justify-between">
          <span class="font-medium text-gray-700">E-Mail:</span>
          <span class="text-gray-900"><%= @registration.email %></span>
        </div>
        <div class="flex justify-between">
          <span class="font-medium text-gray-700">Status:</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
            Ausstehend
          </span>
        </div>
      </div>

      <div class="mt-8 text-center">
        <%= link_to "Zurück zum Event", @registration.event, class: "text-purple-600 hover:text-purple-800 font-medium" %>
      </div>
    </div>
  </div>
</div>