<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-800 mb-6">Bewerbungen & Anmeldungen verwalten</h1>

  <!-- Positionen-Bewerbungen -->
  <h2 class="text-2xl font-semibold text-gray-800 mb-4">📋 Bewerbungen auf Positionen</h2>
  <% if @positions.empty? %>
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
      <p class="text-yellow-700">Sie haben noch keine Positionen erstellt.</p>
      <%= link_to "Neue Position erstellen", new_position_path, class: "mt-2 inline-block text-blue-600 hover:underline" %>
    </div>
  <% else %>
    <% @positions.each do |position| %>
      <div class="bg-white rounded-lg shadow-md mb-8 overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="text-xl font-semibold text-gray-800"><%= position.title %></h2>
              <p class="text-sm text-gray-500">
                Typ: 
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= position.type == 'volunteering' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
                  <%= position.type == 'volunteering' ? '🤝 Ehrenamt' : '🎯 Freizeit' %>
                </span>
              </p>
            </div>
            <%= link_to "Zur Position", position_path(position), class: "text-blue-600 hover:underline text-sm" %>
          </div>
        </div>

        <% messages = position.messages %>
        <% if messages.empty? %>
          <div class="p-6 text-gray-500 italic">Noch keine Bewerbungen für diese Position.</div>
        <% else %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">E-Mail</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Aktionen</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% messages.each do |message| %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= message.first_name %> <%= message.last_name %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= message.email %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% if message.accepted.nil? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Ausstehend</span>
                      <% elsif message.accepted? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Akzeptiert</span>
                      <% else %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Abgelehnt</span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                      <div class="flex space-x-2">
                        <%= button_to "Akzeptieren", organization_application_path(message, accepted: true), method: :patch, class: "px-3 py-1 bg-green-600 text-white rounded-md hover:bg-green-700" %>
                        <%= button_to "Ablehnen", organization_application_path(message, accepted: false), method: :patch, class: "px-3 py-1 bg-red-600 text-white rounded-md hover:bg-red-700" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <!-- Event-Registrierungen -->
  <h2 class="text-2xl font-semibold text-gray-800 mb-4 mt-8">🎉 Anmeldungen für Events</h2>
  <% if @events.empty? %>
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
      <p class="text-yellow-700">Sie haben noch keine Events erstellt.</p>
      <%= link_to "Neues Event erstellen", new_event_path, class: "mt-2 inline-block text-purple-600 hover:underline" %>
    </div>
  <% else %>
    <% @events.each do |event| %>
      <div class="bg-white rounded-lg shadow-md mb-8 overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="text-xl font-semibold text-gray-800"><%= event.title %></h2>
              <p class="text-sm text-gray-500">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                  🎉 Event
                </span>
              </p>
            </div>
            <%= link_to "Zum Event", event, class: "text-purple-600 hover:underline text-sm" %>
          </div>
        </div>

        <% registrations = event.messages.where(type: 'event_registration') %>
        <% if registrations.empty? %>
          <div class="p-6 text-gray-500 italic">Noch keine Anmeldungen für dieses Event.</div>
        <% else %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">E-Mail</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Alter</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Aktionen</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% registrations.each do |registration| %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= registration.first_name %> <%= registration.last_name %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= registration.email %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= registration.age %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% if registration.accepted.nil? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Ausstehend</span>
                      <% elsif registration.accepted? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Akzeptiert</span>
                      <% else %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Abgelehnt</span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                      <div class="flex space-x-2">
                        <%= button_to "Akzeptieren", organization_application_path(registration, accepted: true), method: :patch, class: "px-3 py-1 bg-green-600 text-white rounded-md hover:bg-green-700" %>
                        <%= button_to "Ablehnen", organization_application_path(registration, accepted: false), method: :patch, class: "px-3 py-1 bg-red-600 text-white rounded-md hover:bg-red-700" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>