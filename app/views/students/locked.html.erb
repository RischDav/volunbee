<div class="max-w-lg mx-auto my-8 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold mb-4 text-[#003359]">Email Address Confirmation</h1>

  <% if @student_email %>
    <div class="mb-6">
      <p class="text-gray-700"><strong>Email:</strong> <%= @student_email %></p>
    </div>
    <div class="space-y-4 mb-6">
      <div class="p-4 border rounded-lg">
        <div class="flex justify-between items-center">
          <h2 class="font-semibold">Confirmation Status</h2>
          <% if @confirmed %>
            <span class="text-xl">✅</span>
          <% else %>
            <span class="text-xl">⚠️</span>
          <% end %>
        </div>
        <p class="mt-2 text-sm">
          <% if @confirmed %>
            Your email address has been confirmed.
          <% else %>
            We have sent a confirmation email to your address.<br>
            <%= link_to 'Resend confirmation email', new_student_confirmation_path, class: "text-blue-600 underline" %>.
          <% end %>
        </p>
      </div>
      <div class="mt-6 text-center space-y-3">
        <% if @confirmed %>
          <%= link_to 'Go to Login', new_student_session_path, class: "px-4 py-2 bg-[#003359] text-white rounded-md hover:bg-blue-700" %>
        <% else %>
          <p class="text-gray-600">Once this step is completed, you can log in and complete your information.</p>
        <% end %>
        <div class="mt-2">
          <%= link_to 'Back to Login', new_student_session_path, class: "text-blue-600 hover:text-blue-800 text-sm" %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="bg-yellow-100 p-4 rounded-lg">
      <p class="text-yellow-700">No student information available.</p>
    </div>
    <div class="mt-6 text-center">
      <%= link_to 'Back to Login', new_student_session_path, class: "text-blue-600 hover:text-blue-800 text-sm" %>
    </div>
  <% end %>
</div> 