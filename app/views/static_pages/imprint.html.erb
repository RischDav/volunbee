<div class="container mx-auto py-8 px-4 max-w-4xl">
  <h1 class="text-3xl font-bold mb-8 text-center"><%= t('static_pages.imprint.title') %></h1>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.tmg_section') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.company_name') %></p>
    <p class="mb-1"><%= t('static_pages.imprint.department') %></p>
    <p class="mb-1"><%= t('static_pages.imprint.address_line_1') %></p>
    <p class="mb-1"><%= t('static_pages.imprint.address_line_2') %></p>
    <p class="mb-4"><%= t('static_pages.imprint.country') %></p>
    
    <p class="mb-1"><span class="font-medium"><%= t('static_pages.imprint.phone_label') %>:</span> +49 (0) 7131 264180</p>
    <p class="mb-1"><span class="font-medium"><%= t('static_pages.imprint.email_label') %>:</span> info.hn@chn.tum.de</p>
    <p class="mb-1"><span class="font-medium"><%= t('static_pages.imprint.web_label') %>:</span> <a href="https://www.chn.tum.de" class="text-blue-600 hover:underline">www.chn.tum.de</a></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.executives_title') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.executives') %></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.headquarters_title') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.headquarters') %></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.legal_form_title') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.legal_form') %></p>
    <p class="mb-1"><%= t('static_pages.imprint.register') %></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.tax_id_title') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.tax_id') %></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.responsible_title') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.responsible') %></p>
    <p class="mb-1"><%= t('static_pages.imprint.responsible_address') %></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.dispute_resolution_title') %></h2>
    <p class="mb-4"><%= t('static_pages.imprint.dispute_resolution') %></p>
    <p class="mb-1"><%= t('static_pages.imprint.dispute_resolution_contact') %></p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 border-b pb-2"><%= t('static_pages.imprint.purpose_title') %></h2>
    <p class="mb-1"><%= t('static_pages.imprint.purpose') %></p>
  </div>
</div>
