<div class="mt-8 p-6 bg-white rounded-lg shadow-md border border-slate-200">
  <h2 class="text-2xl font-semibold mb-4"><%= organization.name %></h2>
  <% if organization.logo.attached? %>
    <div class="mt-4 flex justify-center">
      <%= image_tag organization.logo, style: "max-width: 200px;", class: "rounded my-2" %>
    </div>
  <% end %>

  <%= render partial: 'organization_info_grid', locals: { organization: organization } %>
  <%= render partial: 'social_media_links', locals: { organization: organization } %>

  <div class="mt-6 flex justify-end">
    <%= link_to t('organization.details.edit_data'), edit_organization_path(organization), class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
  </div>
</div>
