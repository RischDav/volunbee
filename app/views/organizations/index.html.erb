<% if current_user.admin? %>
  <h1 class="text-3xl my-4">Informationen zu Organisationen</h1>
    <% if @organizations.where(released: false).exists? %>
        <div class="bg-yellow-600 p-4 rounded-md">
      <div class="text-xl">Es gibt einige noch nicht freigegebene Organisationen!</div>
      <% @organizations.where(released: false).each do |organization| %>
        <div class="mt-8 p-6 bg-white rounded-lg shadow-md border broder-slate-200">
          <h2 class="text-2xl font-semibold mb-4"><%= organization.name %></h2>
          <p class="text-gray-700 mb-2"><strong>Email:</strong> <%= organization.email %></p>
          <p class="text-gray-700 mb-2"><strong>Contact Number:</strong> <%= organization.contact_number %></p>
          <p class="text-gray-700 mb-2"><strong>Approved:</strong> <%= organization.released ? 'Yes' : 'No' %></p>
          <%= link_to 'Daten einsehen', organization_path(organization.id), class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
          <%= link_to 'Freigeben', release_organization_path(organization), method: :patch, class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
        </div>
      <% end %>
        </div>
    <% end %>

  <% @organizations.where(released: true).each do |organization| %>
    <div class="mt-8 p-6 bg-white rounded-lg shadow-md border broder-slate-200">
      <h2 class="text-2xl font-semibold mb-4"><%= organization.name %></h2>
      <p class="text-gray-700 mb-2"><strong>Email:</strong> <%= organization.email %></p>
      <p class="text-gray-700 mb-2"><strong>Telefonnummer:</strong> <%= organization.contact_number %></p>
      <p class="text-gray-700 mb-2"><strong>Freigegeben:</strong> <%= organization.released ? 'Yes' : 'No' %></p>
      <%= link_to 'Daten einsehen', organization_path(organization.id), class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
      <%= link_to 'Sperren', lock_organization_path(organization), method: :patch, class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
    </div>
  <% end %>
<% else %>
  <h1 class="text-3xl">Informationen zu Ihrer Organisation</h1>
  <div class="mt-8 p-6 bg-white rounded-lg shadow-md border broder-slate-200">
    <h2 class="text-2xl font-semibold mb-4"><%= @organization.name %></h2>
    <p class="text-gray-700 mb-2"><strong>Email:</strong> <%= @organization.email %></p>
    <p class="text-gray-700 mb-2"><strong>Telefonnummer:</strong> <%= @organization.contact_number %></p>
    <p class="text-gray-700 mb-2"><strong>Freigegeben:</strong> <%= @organization.released ? 'Yes' : 'No' %></p>
    <%= link_to 'Daten bearbeiten', edit_organization_path(@organization), class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
  </div>
<% end %>