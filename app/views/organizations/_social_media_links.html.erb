<div class="bg-gray-100 p-4 rounded mt-4">
  <p class="text-gray-700 mb-2"><strong>Social Media:</strong></p>
  <ul class="list-disc list-inside">
    <% if organization.instagram_url.present? %>
      <li><%= link_to "Instagram", organization.instagram_url, target: "_blank", class: "text-blue-500 hover:underline" %></li>
    <% end %>
    <% if organization.linkedin_url.present? %>
      <li><%= link_to "LinkedIn", organization.linkedin_url, target: "_blank", class: "text-blue-500 hover:underline" %></li>
    <% end %>
    <% if organization.facebook_link.present? %>
      <li><%= link_to "Facebook", organization.facebook_link, target: "_blank", class: "text-blue-500 hover:underline" %></li>
    <% end %>
    <% if organization.instagram_url.blank? && organization.linkedin_url.blank? && organization.facebook_link.blank? %>
      <li>Keine Social-Media-Links verfügbar</li>
    <% end %>
  </ul>
</div>