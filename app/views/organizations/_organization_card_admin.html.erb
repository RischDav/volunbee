<div class="mt-8 p-6 bg-white rounded-lg shadow-md border broder-slate-200">
  <%= render partial: 'organization_logo', locals: { organization: organization } %>

  <h2 class="text-2xl font-semibold mb-4"><%= organization.name %></h2>

  <p class="text-gray-700 mb-2"><strong><%= t('organizations.admin_card.email') %>:</strong> <%= organization.email %></p>
  <p class="text-gray-700 mb-2"><strong><%= t('organizations.admin_card.phone') %>:</strong> <%= organization.contact_number %></p>
  <p class="text-gray-700 mb-2"><strong><%= t('organizations.admin_card.released') %>:</strong> <%= organization.released ? t('organizations.admin_card.yes') : t('organizations.admin_card.no') %></p>

  <%= link_to t('organizations.admin_card.view_data'), organization_path(organization.id), class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
  <%= link_to t('organizations.admin_card.lock'), lock_organization_path(organization), method: :patch, class: "mt-6 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
</div>
