<h1 class="text-3xl my-4">Organisation Details</h1>
<div class="mt-8 p-6 bg-white rounded-lg shadow-md border border-slate-200">
    <% if @organization.logo.attached? %>
        <div class="mt-4 flex justify-center">
            <%= image_tag @organization.logo, style: "max-width: 200px;", class: "rounded my-2" %>
        </div>
    <% end %>
    <h2 class="text-2xl font-semibold mb-4 text-center"><%= @organization.name.present? ? @organization.name : 'Nicht vorhanden' %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Email:</strong> <%= @organization.email.present? ? @organization.email : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Kontakt Nummer:</strong> <%= @organization.contact_number.present? ? @organization.contact_number : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Stadt:</strong> <%= @organization.city.present? ? @organization.city : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>PLZ:</strong> <%= @organization.zip.present? ? @organization.zip : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Straße:</strong> <%= @organization.street.present? ? @organization.street : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Hausnummer:</strong> <%= @organization.housenumber.present? ? @organization.housenumber : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Website:</strong> 
                <%= @organization.website.present? ? link_to(@organization.website, @organization.website, target: "_blank", class: "text-blue-500 hover:underline") : 'Nicht vorhanden' %>
            </p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Kontaktperson:</strong> <%= @organization.contact_person.present? ? @organization.contact_person : 'Nicht vorhanden' %></p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Beschreibung:</strong> <%= @organization.description.present? ? @organization.description : 'Nicht vorhanden' %></p>
        </div>
    </div>
            </p>
        </div>
        <div class="bg-gray-100 p-4 rounded">
            <p class="text-gray-700"><strong>Status:</strong> 
                <span class="<%= @organization.is_approved ? 'text-green-500' : 'text-red-500' %>">
                    <%= @organization.is_approved ? 'Organisation ist freigegeben. Somit sind alle veröffentlichte Stellen einsehbar.' : 'Die Organisation ist noch nicht von einem Administrator freigegeben. Die Freigabe erfolgt in den nächsten 24 Stunden. Bis zur Freigabe werden die geposteten Stellen nicht angezeigt.' %>
                </span>
            </p>
        </div>
    </div>
    <div class="mt-6 flex justify-end space-x-2">
        <%= link_to 'Nochmal bearbeiten', edit_organization_path(@organization), class: "px-4 py-2 bg-green-500 text-white rounded hover:bg-green-700" %>
        <%= link_to 'Zurück', organizations_path, class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700" %>
    </div>
</div>
