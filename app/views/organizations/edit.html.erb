<h1 class="text-3xl">Bearbeiten Sie Ihre Organisation</h1>
<div class="mt-8 p-6 bg-white rounded-lg shadow-md border broder-slate-200">
  <%= form_for @organization, url: organization_path, html: { method: :put, class: "space-y-4" } do |f| %>
<div class="bg-slate-100 rounded-lg p-6">
<h2 class="text-2xl font-bold">Allgemeine Informationen</h2>
<div class="grid grid-cols-3 gap-4">

  <div class="field">
    <%= f.label :name, "Name", class: "block text-lg font-medium text-gray-700" %>
    <%= f.text_field :name, class: "w-full my-3 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-700">Bitte geben sie den vollen Namen mit Rechtsform an (zum Beispiel gGmbH oder e.V.)</p>
  </div>

  <div class="field">
    <%= f.label :contact_person, "Ansprechpartner:in", class: "block text-lg font-medium text-gray-700" %>
    <%= f.text_field :contact_person, class: "w-full my-3 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-700">Geben Sie den Vor und Nachnamen der Ansprechpartner:in für interessierte ein.</p>
  </div>

  <div class="field">
    <%= f.label :email, "Kontakt-Email", class: "block text-lg font-medium text-gray-700" %>
    <%= f.email_field :email, class: "w-full my-3 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="field">
    <%= f.label :contact_number, "Telefonnummer", class: "block text-lg font-medium text-gray-700" %>
    <%= f.text_field :contact_number, class: "w-full my-3 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-700">Bitte geben Sie die Landesvorwahl mit an (Deutschland: +49)</p>
  </div>


</div>
</div>
<div class="bg-slate-100 rounded-lg p-6">
<h2 class="text-2xl font-bold">Beschreibung</h2>
<div class="gap-4">
    <div class="field">
    <%= f.text_area :description, class: "w-full mt-2 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    <div id="word-count-description" class="mt-1 text-sm rounded-md focus:outline-none"></div>
    <p class="text-sm text-gray-700">Bitte beschreiben Sie Ihre Organisation <b>auf Englisch</b>. Welche Schwerpunkte verfolgen Sie? Welchen Mehrwert bieten Sie? Denken Sie daran, dass Leserinnen und Leser Ihre Organisation möglicherweise noch nicht kennen.</p>
  </div>
</div>
</div>
<div class="bg-slate-100 rounded-lg p-6">
<h2 class="text-2xl font-bold">Admin-Email</h2>
<div class="grid grid-cols-3 gap-4">
  <div class="field">
    <%= f.text_field :admin_email, value: User.find_by(organization_id: @organization.id)&.email, disabled: true, class: "w-full my-3 px-3 py-2 border rounded-md shadow-sm bg-gray-100 text-gray-500 cursor-not-allowed" %>
    <p class="text-sm text-gray-700">Die Admin-Email ist unveränderlich und entspricht der Email, mit der Sie sich anmelden. Im Gegensatz zur angegebenen Kontakt-Email ist sie nicht öffentlich sichtbar.</p>
  </div>
</div>
</div>
<div class="bg-slate-100 rounded-lg p-6">
<h2 class="text-2xl font-bold">Logo</h2>
    <div>
      <div class="field">
      <p class="text-sm text-gray-700 mt-2">Bitte laden Sie das Logo Ihrer Organisation hoch. Achten Sie darauf, dass der Hintergrund transparent, weiß oder zumindest einfarbig ist.</p>
      <div class="border-2 border-gray-300 p-4 rounded-md my-3 w-1/2">
        <%= f.file_field :logo, accept: 'image/*' %>
        <p class="text-sm text-gray-500">Bitte ein Logo hochladen</p>
      </div>
      <% if @organization.logo.attached? %>
      <div class="mt-4">
      <%= image_tag @organization.logo, style: "max-width: 200px;", class: "rounded" %>
      </div>
    <% end %>
      </div>
    </div>
</div>

<div class="bg-slate-100 rounded-lg p-6">
<h2 class="text-2xl font-bold">Adresse</h2>
<div class="grid grid-cols-3 gap-4">


    <div class="field">
      <%= f.label :city, "Stadt", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :city, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :zip, "Postleitzahl", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :zip, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :street, "Strasse", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :street, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :housenumber, "Hausnummer", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :housenumber, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>
</div>
</div>
<div class="bg-slate-100 rounded-lg p-6">
        <h2 class="text-2xl font-bold">Social Media & Web (Optional)</h2>
<div class="grid grid-cols-3 gap-4">

    <div class="field">
      <%= f.label :website, "Website", class: "block text-sm font-medium text-gray-700" %>
      <%= f.url_field :website, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :instagram_url, "Instagram URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :instagram_url, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :linkedin_url, "LinkedIn URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :linkedin_url, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :facebook_link, "Facebook URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :facebook_link, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :tiktok_url, "TikTok URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :tiktok_url, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="field">
      <%= f.label :linktree_url, "LinkTree URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :linktree_url, class: "w-full mt-1 px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

</div>
</div>
<div class="my-3 flex space-x-4">
  <div class="actions">
    <%= f.submit "Speichern", class: "py-2 px-4 bg-blue-600 text-white font-medium text-lg rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
  </div>
  <div>
    <%= link_to "Zurück ohne zu speichern", organizations_path, class: "py-2 px-4 bg-slate-600 text-white font-medium text-lg rounded-md shadow-sm hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
  </div>
</div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function updateWordCount(field, counter, minLength, goodLength, perfectLength) {
      const charCount = field.value.length;

      if (charCount < minLength) {
        counter.textContent = `Sie benötigen noch mindestens ${minLength - charCount} Zeichen`;
        counter.style.color = 'red';
      } else if (charCount < goodLength) {
        counter.textContent = `Gute Länge (${charCount} von ${goodLength} Zeichen)`;
        counter.style.color = 'orange';
      } else if (charCount < perfectLength) {
        counter.textContent = `Perfekte Länge (${charCount} Zeichen)`;
        counter.style.color = 'green';
      } else {
        counter.textContent = `${charCount} Zeichen (Maximum empfohlen: ${perfectLength})`;
        counter.style.color = 'red';
      }
    }

    const descriptionField = document.getElementById('organization_description');
    const wordCountDescription = document.getElementById('word-count-description');

    if (descriptionField && wordCountDescription) {
      // Initial update
      updateWordCount(descriptionField, wordCountDescription, 300, 700, 1000);
      
      // Update on input
      descriptionField.addEventListener('input', function() {
        updateWordCount(descriptionField, wordCountDescription, 300, 700, 1000);
      });
    }
  });
</script>