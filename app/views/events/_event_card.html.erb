<div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-200">
  <% if event.main_picture.attached? %>
    <%= image_tag event.main_picture, class: "w-full h-48 object-cover" %>
  <% else %>
    <div class="w-full h-48 bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center">
      <svg class="w-12 h-12 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
  <% end %>
  
  <div class="p-4">
    <div class="flex justify-between items-start">
      <h3 class="text-lg font-semibold text-gray-900 mb-1">
        <%= link_to event.title, event, class: "hover:text-purple-600" %>
      </h3>
      <% if event.event_type.present? %>
        <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded-full">
          <%= event.event_type.humanize %>
        </span>
      <% end %>
    </div>
    
    <div class="space-y-1 text-sm text-gray-600 mt-2">
      <div class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span><%= event.location.presence || "Ort wird noch bekannt gegeben" %></span>
      </div>
      <div class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span><%= l(event.start_date, format: :short) %> – <%= l(event.end_date, format: :short) %></span>
      </div>
    </div>
    
    <p class="text-gray-700 text-sm mt-2 line-clamp-2"><%= event.description %></p>
    
    <div class="mt-3 flex justify-between items-center">
      <%= link_to "Details", event, class: "text-purple-600 hover:text-purple-800 text-sm font-medium" %>
      <% if user_signed_in? && (current_user.organization? && event.organization_id == current_user.organization&.id) %>
        <%= link_to "Bearbeiten", edit_event_path(event), class: "text-gray-500 hover:text-gray-700 text-sm" %>
      <% end %>
    </div>
  </div>
</div>