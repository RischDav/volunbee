<div class="min-h-screen bg-gray-50 py-4 sm:py-6">
  <div class="max-w-5xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8">
    
    <div class="mb-4 sm:mb-6 lg:mb-8">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-900 mb-2">
        Event-Details
      </h1>
      <div class="w-16 sm:w-20 h-1 bg-gray-900 rounded-full"></div>
    </div>

    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <!-- Dark Header -->
      <div class="bg-gray-900 px-4 sm:px-6 lg:px-8 py-8 sm:py-10 lg:py-12 text-white">
        <div class="max-w-4xl">
          <div class="mb-3 sm:mb-4">
            <span class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full text-xs sm:text-sm font-semibold bg-purple-700 text-white shadow-sm">
              🎉 Event
            </span>
          </div>
          
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold mb-3 sm:mb-4 leading-tight">
            <%= @event.title %>
          </h2>

          <div class="flex flex-col gap-4">
            <% if @event.organization&.name %>
              <div class="flex items-center gap-2 text-gray-300">
                <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2v8h12V6H4z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium text-sm sm:text-base">Veranstalter: <%= @event.organization.name %></span>
              </div>
            <% end %>

            <div class="flex items-center">
              <div class="relative inline-flex items-center bg-white/10 hover:bg-white/15 rounded-lg border border-white/10 transition-all group">
                <div class="pl-3 pointer-events-none text-gray-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                  </svg>
                </div>
                <select id="event-language-select" class="appearance-none bg-transparent text-sm font-semibold text-white py-1.5 pl-2 pr-10 focus:outline-none cursor-pointer">
                  <option value="de" <%= I18n.locale == :de ? 'selected' : '' %> class="text-gray-900">Deutsch</option>
                  <option value="en" <%= I18n.locale == :en ? 'selected' : '' %> class="text-gray-900">English</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-400 group-hover:text-white transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Sections -->
      <div class="p-4 sm:p-6 lg:p-8 space-y-8 sm:space-y-10 lg:space-y-12">

                <!-- Event Registration Button Section -->
<div class="mt-8 mb-8">
  <div class="bg-purple-50 border border-purple-200 rounded-xl p-4 sm:p-6 lg:p-8 mb-8 text-center">
    <div class="mb-4 sm:mb-6">
      <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-purple-800 mb-2">🎉 Jetzt für das Event anmelden</h3>
      <p class="text-sm sm:text-base text-purple-700 mb-4 sm:mb-6">Sichere dir deinen Platz und werde Teil dieser Veranstaltung</p>
    </div>
    <%= link_to "Jetzt anmelden", new_event_event_registration_path(@event), class: "inline-flex items-center gap-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold px-6 sm:px-8 py-3 sm:py-4 text-base sm:text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105" %>
  </div>
</div>
        
        <!-- General Information -->
        <div>
          <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-6 sm:mb-8 flex items-center gap-2 sm:gap-3">
            <div class="w-7 h-7 sm:w-8 sm:h-8 bg-gray-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            Allgemeine Informationen
          </h3>
          
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8">
            <!-- Description -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-xl border border-gray-200">
              <div class="flex items-start gap-2 sm:gap-3 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h4 class="font-semibold text-sm sm:text-base text-gray-900">Beschreibung</h4>
              </div>
              <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                <%= @event.description.present? ? simple_format(@event.description) : "Keine Beschreibung vorhanden." %>
              </p>
            </div>

            <!-- Benefits -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-xl border border-gray-200">
              <div class="flex items-start gap-2 sm:gap-3 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v6m0 6v6m11-7h-6m-6 0H1" />
                </svg>
                <h4 class="font-semibold text-sm sm:text-base text-gray-900">Was dich erwartet / Vorteile</h4>
              </div>
              <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                <%= @event.benefits.present? ? simple_format(@event.benefits) : "Keine Angabe." %>
              </p>
            </div>

            <!-- Location -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-xl border border-gray-200">
              <div class="flex items-start gap-2 sm:gap-3 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <h4 class="font-semibold text-sm sm:text-base text-gray-900">Ort</h4>
              </div>
              <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                <%= @event.location.presence || "Keine Angabe" %>
              </p>
            </div>

            <!-- Date & Time -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-xl border border-gray-200">
              <div class="flex items-start gap-2 sm:gap-3 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h4 class="font-semibold text-sm sm:text-base text-gray-900">Datum & Uhrzeit</h4>
              </div>
              <div class="text-sm sm:text-base text-gray-600 leading-relaxed space-y-1">
                <p><span class="font-medium">Beginn:</span> <%= l(@event.start_date, format: :long) %></p>
                <p><span class="font-medium">Ende:</span> <%= l(@event.end_date, format: :long) %></p>
              </div>
            </div>

            <!-- Category -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-xl border border-gray-200">
              <div class="flex items-start gap-2 sm:gap-3 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l5 5a2 2 0 01.586 1.414V19a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z" />
                </svg>
                <h4 class="font-semibold text-sm sm:text-base text-gray-900">Kategorie</h4>
              </div>
              <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                <%= @event.event_type.present? ? @event.event_type.humanize : "Keine Kategorie" %>
              </p>
            </div>

            <!-- Status -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-xl border border-gray-200">
              <div class="flex items-start gap-2 sm:gap-3 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h4 class="font-semibold text-sm sm:text-base text-gray-900">Status</h4>
              </div>
              <div class="flex flex-wrap gap-2">
                <% if @event.released? && @event.online? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Veröffentlicht</span>
                <% elsif !@event.released? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Nicht freigegeben</span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Offline</span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Images Section -->
        <% images = [@event.main_picture, @event.picture1, @event.picture2, @event.picture3].select(&:attached?) %>
        <% if images.any? %>
          <div>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-6 sm:mb-8 flex items-center gap-2 sm:gap-3">
              <div class="w-7 h-7 sm:w-8 sm:h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                </svg>
              </div>
              Bilder
            </h3>
            <div id="event-image-carousel" class="relative w-full max-w-2xl mx-auto">
              <div class="relative h-56 overflow-hidden rounded-lg md:h-96">
                <% images.each_with_index do |image, index| %>
                  <div class="carousel-slide-event <%= 'hidden' if index > 0 %> duration-700 ease-in-out">
                    <%= image_tag image.variant(resize_to_limit: [800, 800]).processed, class: "absolute block w-full h-full object-contain -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2" %>
                  </div>
                <% end %>
              </div>
              <% if images.length > 1 %>
                <button type="button" id="event-carousel-prev-btn" class="absolute top-0 left-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none">
                  <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 dark:bg-gray-800/30 group-hover:bg-white/50 transition">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 6 10">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 1 1 5l4 4"/>
                    </svg>
                  </span>
                </button>
                <button type="button" id="event-carousel-next-btn" class="absolute top-0 right-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none">
                  <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 dark:bg-gray-800/30 group-hover:bg-white/50 transition">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 6 10">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                    </svg>
                  </span>
                </button>
              <% end %>
            </div>
          </div>
          <% if images.length > 1 %>
            <script>
              document.addEventListener('DOMContentLoaded', function() {
                const carousel = document.getElementById('event-image-carousel');
                if (!carousel) return;
                const slides = Array.from(carousel.querySelectorAll('.carousel-slide-event'));
                const prevBtn = document.getElementById('event-carousel-prev-btn');
                const nextBtn = document.getElementById('event-carousel-next-btn');
                let currentIndex = 0;
                function showSlide(index) {
                  slides.forEach((slide, i) => slide.classList.toggle('hidden', i !== index));
                }
                if (prevBtn && nextBtn) {
                  prevBtn.addEventListener('click', () => {
                    currentIndex = (currentIndex - 1 + slides.length) % slides.length;
                    showSlide(currentIndex);
                  });
                  nextBtn.addEventListener('click', () => {
                    currentIndex = (currentIndex + 1) % slides.length;
                    showSlide(currentIndex);
                  });
                }
              });
            </script>
          <% end %>
        <% end %>

        <!-- Contact Information Section -->
        <% if user_signed_in? && @event.organization.present? %>
          <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 mt-6 sm:mt-8">
            <div class="p-4 sm:p-6 lg:p-8">
              <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-6 sm:mb-8 flex items-center gap-2 sm:gap-3">
                <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                Kontaktinformationen - <%= @event.organization.name %>
              </h3>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% if @event.contact_person.present? %>
                  <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-6 rounded-xl border border-blue-100">
                    <div class="flex items-center gap-3 mb-3">
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                      <h4 class="font-semibold text-gray-900">Ansprechperson</h4>
                    </div>
                    <p class="text-gray-600 text-lg font-medium"><%= @event.contact_person %></p>
                  </div>
                <% end %>

                <% if @event.contact_email.present? %>
                  <div class="bg-gradient-to-br from-emerald-50 to-green-50 p-6 rounded-xl border border-emerald-100">
                    <div class="flex items-center gap-3 mb-3">
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                      <h4 class="font-semibold text-gray-900">E-Mail</h4>
                    </div>
                    <a href="mailto:<%= @event.contact_email %>" class="text-gray-600 hover:text-gray-600 font-medium"><%= @event.contact_email %></a>
                  </div>
                <% end %>

                <% if @event.contact_phone.present? %>
                  <div class="bg-gradient-to-br from-purple-50 to-violet-50 p-6 rounded-xl border border-purple-100">
                    <div class="flex items-center gap-3 mb-3">
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.135a11.249 11.249 0 005.409 5.409l1.135-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                      <h4 class="font-semibold text-gray-900">Telefon</h4>
                    </div>
                    <a href="tel:<%= @event.contact_phone %>" class="text-gray-600 hover:text-gray-600 font-medium"><%= @event.contact_phone %></a>
                  </div>
                <% end %>

                <% if @event.website.present? %>
                  <div class="bg-gradient-to-br from-cyan-50 to-blue-50 p-6 rounded-xl border border-cyan-100">
                    <div class="flex items-center gap-3 mb-3">
                      <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9m0 9a9 9 0 01-9-9m9 9c0-2.5-4-5-9-5s-9 2.5-9 5m9 4a9 9 0 009-9m-9 9c2.5 0 5-4 5-9s-2.5-9-5-9" />
                      </svg>
                      <h4 class="font-semibold text-gray-900">Website</h4>
                    </div>
                    <a href="<%= @event.website %>" target="_blank" class="text-cyan-600 hover:text-cyan-800 font-medium inline-flex items-center gap-1"><%= @event.website %></a>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Event Registration Button Section -->
<div class="mt-8 mb-8">
  <div class="bg-purple-50 border border-purple-200 rounded-xl p-4 sm:p-6 lg:p-8 mb-8 text-center">
    <div class="mb-4 sm:mb-6">
      <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-purple-800 mb-2">🎉 Jetzt für das Event anmelden</h3>
      <p class="text-sm sm:text-base text-purple-700 mb-4 sm:mb-6">Sichere dir deinen Platz und werde Teil dieser Veranstaltung</p>
    </div>
    <%= link_to "Jetzt anmelden", new_event_event_registration_path(@event), class: "inline-flex items-center gap-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold px-6 sm:px-8 py-3 sm:py-4 text-base sm:text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105" %>
  </div>
</div>

        <!-- Back Button -->
        <div class="mt-8 flex justify-center">
          <%= link_to events_path, class: "inline-flex items-center gap-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Zurück zur Übersicht
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbolinks:load', function() {
    const langSelect = document.getElementById('event-language-select');
    if (langSelect) {
      langSelect.addEventListener('change', function() {
        const selectedLocale = this.value;
        const currentPath = window.location.pathname;
        const searchParams = window.location.search;
        let pathWithoutLocale = currentPath.replace(/^\/(de|en)/, '');
        window.location.href = '/' + selectedLocale + pathWithoutLocale + searchParams;
      });
    }
  });
</script>