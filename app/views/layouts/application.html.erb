<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t('application.title', default: "volunbee.com") %></title>
    <%= render 'shared/cookie_consent' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="<%= asset_path('favicon.png') %>" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload', defer: true %>
  </head>

  <% 
    # Check: Ist es die Positions-Show Seite und der User ist NICHT eingeloggt?
    @is_public_position_view = (controller_name == 'positions' && action_name == 'show' && !user_signed_in?)
  %>

  <body>
    <% if @custom_navbar %>
      <% unless controller_name == 'organizations' && action_name == 'edit' %>
        <%= render partial: "shared/organization_alert"%>   
      <% end %>
      
      <main class="m-4">
        <%= yield %>
      </main>
      
      <%= render partial: "shared/public_footer" %>
    <% else %>
      <div class="dashboard-container">
        
        <% # Sidebar nur ausblenden, wenn es die öffentliche Positions-Show ist %>
        <% unless @is_public_position_view %>
          <%= render partial: "shared/dashboard_sidebar" %>
        <% end %>
        
        <div class="dashboard-main <%= 'full-width' if @is_public_position_view %>">
          
          <% # Mobile Toggle nur zeigen, wenn Sidebar gerendert wurde %>
          <% unless @is_public_position_view %>
            <button class="mobile-menu-toggle" onclick="toggleSidebar()">
              <svg class="menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          <% end %>
          
          <% unless controller_name == 'organizations' && action_name == 'edit' %>
            <div class="dashboard-alerts">
              <%= render partial: "shared/organization_alert"%>   
            </div>
          <% end %>
          
          <main class="dashboard-content">
            <%= yield %>
          </main>
        </div>
      </div>
    <% end %>
    
    <style>
      body { display: flex; flex-direction: column; min-height: 99vh; }
      main { flex: 1; }
      
      .dashboard-container {
        display: flex;
        min-height: 100vh;
        background-color: #f8f9fa;
      }
      
      .dashboard-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        margin-left: 280px;
        position: relative;
        transition: margin-left 0.3s ease;
      }

      /* Diese Klasse wird nur auf der öffentlichen Positions-Show aktiv */
      .dashboard-main.full-width {
        margin-left: 0 !important;
      }
      
      .mobile-menu-toggle {
        display: none;
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 1001;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.5rem;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        color: #374151;
      }
      
      .dashboard-alerts { padding: 1rem 2rem 0; }
      .dashboard-content { flex: 1; padding: 2rem; overflow-y: auto; }
      
      @media (max-width: 768px) {
        .dashboard-main, .dashboard-main.full-width {
          margin-left: 0 !important;
          padding-top: 4rem;
        }
        .mobile-menu-toggle { display: block; }
        .dashboard-content { padding: 1rem; }
      }
    </style>

    <script>
      function toggleSidebar() {
        const sidebar = document.querySelector('.dashboard-sidebar');
        if (sidebar) { sidebar.classList.toggle('mobile-open'); }
      }
    </script>
  </body>
</html>